		.solution-card .card-badge.bg-info { background: rgba(46,125,50,0.85) !important; }
		.solution-card .card-badge.bg-purple { background: rgba(26,67,49,0.9) !important; color: #fff !important; }

		/* ---------- About (fond ag-bg / cream) ---------- */
