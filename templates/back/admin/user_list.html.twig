{% extends 'back/admin_base.html.twig' %}

{% block title %}User List - AgriSmart{% endblock %}

{% block body %}
<!-- Page content START -->
   <div class="d-flex">
    {% include 'back/components/sidebar.html.twig' %}
    
    <div class="flex-grow-1 p-3">

                         

    <!-- Page main content START -->

        <!-- Flash Messages -->
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
        
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}

        <!-- Title -->
        
        
<div class="row">
    <div class="col-12 mb-4 mb-sm-5">
        <div class="d-sm-flex justify-content-between align-items-center">
            <h1 class="h3 mb-0">User List</h1>

            <div class="d-flex gap-2">
                <!-- PDF -->
                <a href="{{ path('admin_users_pdf') }}"
                   class="btn btn-sm btn-danger"
                   title="Export PDF">
                    <i class="bi bi-file-earmark-pdf"></i>
                </a>

                <!-- Excel -->
                <a href="{{ path('admin_users_excel') }}"
                   class="btn btn-sm btn-success"
                   title="Export Excel">
                    <i class="bi bi-file-earmark-excel"></i>
                </a>
            </div>
        </div>
    </div>
</div>
        <!-- Filters START -->
        <div class="row g-4 align-items-center">
            <!-- Tabs -->
            <div class="col-lg-6">
                <ul class="nav nav-pills-shadow nav-responsive">
                    <li class="nav-item"> 
                        <a class="nav-link mb-0 {% if currentStatus is not defined or currentStatus is null %}active{% endif %}" 
                           href="{{ path('admin_users', {search: currentSearch, role: currentRole}) }}">
                            All Users
                        </a> 
                    </li>
                    <li class="nav-item">
                        <a class="nav-link mb-0 {% if currentStatus == 'active' %}active{% endif %}" 
                           href="{{ path('admin_users', {status: 'active', search: currentSearch, role: currentRole}) }}">
                            Active
                        </a>
                    </li>
                    <li class="nav-item"> 
                        <a class="nav-link mb-0 {% if currentStatus == 'pending' %}active{% endif %}" 
                           href="{{ path('admin_users', {status: 'pending', search: currentSearch, role: currentRole}) }}">
                            Pending
                        </a> 
                    </li>
                    <li class="nav-item"> 
                        <a class="nav-link mb-0 {% if currentStatus == 'disabled' %}active{% endif %}" 
                           href="{{ path('admin_users', {status: 'disabled', search: currentSearch, role: currentRole}) }}">
                            Disabled
                        </a> 
                    </li>
                </ul>
            </div>

            <!-- Search -->
            <div class="col-md-6 col-lg-3">
                <form class="rounded position-relative" method="get" action="{{ path('admin_users') }}">
                    {% if currentStatus %}
                        <input type="hidden" name="status" value="{{ currentStatus }}">
                    {% endif %}
                    {% if currentRole %}
                        <input type="hidden" name="role" value="{{ currentRole }}">
                    {% endif %}
                    <input class="form-control bg-transparent" type="search" name="search" 
                           placeholder="Search users" aria-label="Search" 
                           value="{{ currentSearch ?? '' }}">
                    <button class="bg-transparent p-2 position-absolute top-50 end-0 translate-middle-y border-0 text-primary-hover text-reset" type="submit">
                        <i class="fas fa-search fs-6"></i>
                    </button>
                </form>
            </div>

            <!-- Select -->
            <div class="col-md-6 col-lg-3">
                <form method="get" action="{{ path('admin_users') }}" id="roleFilterForm">
                    {% if currentStatus %}
                        <input type="hidden" name="status" value="{{ currentStatus }}">
                    {% endif %}
                    {% if currentSearch %}
                        <input type="hidden" name="search" value="{{ currentSearch }}">
                    {% endif %}
                    <select class="form-select" name="role" aria-label="Filter by role" onchange="this.form.submit()">
                        <option value="">Sort by role</option>
                        <option value="admin" {% if currentRole == 'admin' %}selected{% endif %}>Admin</option>
                        <option value="employee" {% if currentRole == 'employee' %}selected{% endif %}>Employee</option>
                        <option value="agriculteur" {% if currentRole == 'agriculteur' %}selected{% endif %}>Agriculteur</option>
                        <option value="fournisseur" {% if currentRole == 'fournisseur' %}selected{% endif %}>Fournisseur</option>
                    </select>
                </form>
            </div>
        </div>
        <!-- Filters END -->

        <!-- User list START -->
        <div class="card shadow mt-5">
            <!-- Card body START -->
            <div class="card-body">
                <!-- Table head -->
                <div class="bg-light rounded p-3 d-none d-lg-block">
                    <div class="row row-cols-6 g-4">
                        <div class="col"><h6 class="mb-0">User</h6></div>
                        <div class="col"><h6 class="mb-0">Email</h6></div>
                        <div class="col"><h6 class="mb-0">Role</h6></div>
                        <div class="col"><h6 class="mb-0">Registration Date</h6></div>
                        <div class="col"><h6 class="mb-0">Status</h6></div>
                        <div class="col"><h6 class="mb-0">Action</h6></div>
                    </div>
                </div>

                {% for user in users %}
                <!-- Table data -->
                <div class="row row-cols-xl-6 align-items-lg-center border-bottom g-4 px-2 py-4">
                    <!-- Data item - User -->
                    <div class="col">
                        <small class="d-block d-lg-none">User:</small>
                        <div class="d-flex align-items-center">
                            <!-- Avatar -->
                            <div class="avatar avatar-xs flex-shrink-0">
                                {% if user.image %}
                                <img class="avatar-img rounded-circle" src="{{ asset('uploads/images/' ~ user.image) }}" alt="avatar">
                                {% else %}
                                <div class="avatar-img rounded-circle bg-primary text-white d-flex align-items-center justify-content-center">
                                    {{ user.firstName|slice(0, 1)|upper }}{{ user.lastName|slice(0, 1)|upper }}
                                </div>
                                {% endif %}
                            </div>
                            <!-- Info -->
                            <div class="ms-2">
                                <h6 class="mb-0 fw-light">{{ user.firstName }} {{ user.lastName }}</h6>
                            </div>
                        </div>
                    </div>	

                    <!-- Data item - Email -->
                    <div class="col">
                        <small class="d-block d-lg-none">Email:</small>
                        <h6 class="mb-0 fw-normal">{{ user.email }}</h6>
                    </div>

                    <!-- Data item - Role -->
                    <div class="col">
                        <small class="d-block d-lg-none">Role:</small>
                        <h6 class="mb-0 fw-normal text-capitalize">{{ user.role }}</h6>
                    </div>

                    <!-- Data item - Registration Date -->
                    <div class="col">
                        <small class="d-block d-lg-none">Registration Date:</small>
                        <h6 class="mb-0 fw-normal">{{ user.createdAt|date('d M Y') }}</h6>
                    </div>

                    <!-- Data item - Status with Dropdown -->
                    <div class="col">
                        <small class="d-block d-lg-none">Status:</small>
                        <div class="dropdown">
                            <button class="btn btn-sm 
                                {% if user.status == 'active' %}
                                    bg-success bg-opacity-10 text-success
                                {% elseif user.status == 'pending' %}
                                    bg-orange bg-opacity-10 text-orange
                                {% else %}
                                    bg-danger bg-opacity-10 text-danger
                                {% endif %} 
                                dropdown-toggle" type="button" id="statusDropdown{{ user.id }}" data-bs-toggle="dropdown" aria-expanded="false">
                                {% if user.status == 'active' %}
                                    Active
                                {% elseif user.status == 'pending' %}
                                    Pending
                                {% else %}
                                    Disabled
                                {% endif %}
                            </button>
                            <ul class="dropdown-menu" aria-labelledby="statusDropdown{{ user.id }}">
                                <li>
                                    <a class="dropdown-item" href="{{ path('admin_user_status', {'id': user.id, 'status': 'active'}) }}">
                                        <i class="bi bi-check-circle text-success me-2"></i>Active
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="{{ path('admin_user_status', {'id': user.id, 'status': 'pending'}) }}">
                                        <i class="bi bi-clock text-warning me-2"></i>Pending
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="{{ path('admin_user_status', {'id': user.id, 'status': 'disabled'}) }}">
                                        <i class="bi bi-x-circle text-danger me-2"></i>Disabled
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <!-- Data item - Action -->
                    <div class="col">
                        <a href="{{ path('admin_user_detail', {'id': user.id}) }}" class="btn btn-sm btn-light mb-0">
                            <i class="bi bi-eye me-1"></i>View
                        </a>
                    </div>
                </div>
                {% else %}
                <!-- Empty state -->
                <div class="row">
                    <div class="col-12 text-center py-5">
                        <i class="bi bi-person-x fs-1 text-muted"></i>
                        <h5 class="mt-3">No users found</h5>
                        <p class="text-muted">There are no users to display at the moment.</p>
                    </div>
                </div>
                {% endfor %}

            </div>
            <!-- Card body END -->

            <!-- Card footer START -->
            <div class="card-footer pt-0">
                <!-- Pagination and content -->
                <div class="d-sm-flex justify-content-sm-between align-items-sm-center">
                    <!-- Content -->
                    <p class="mb-sm-0 text-center text-sm-start">
                        Showing {{ users.currentPageNumber == 1 ? 1 : ((users.currentPageNumber - 1) * users.itemNumberPerPage) + 1 }} 
                        to {{ users.currentPageNumber * users.itemNumberPerPage > users.totalItemCount ? users.totalItemCount : users.currentPageNumber * users.itemNumberPerPage }} 
                        of {{ users.totalItemCount }} entries
                    </p>
                    <!-- Pagination -->
                    <nav class="mb-sm-0 d-flex justify-content-center" aria-label="navigation">
                        {{ knp_pagination_render(users, 'pagination.html.twig', {}, {
                            'prev_label': 'Prev',
                            'next_label': 'Next',
                            'ul_class': 'pagination pagination-sm pagination-primary-soft mb-0',
                            'li_class': 'page-item',
                            'a_class': 'page-link'
                        }) }}
                    </nav>
                </div>
            </div>
            <!-- Card footer END -->
        </div>
        <!-- User list END -->
    </div>
    <!-- Page main content END -->
</div>
<!-- Page content END -->

<!-- Additional CSS for status dropdown styling -->
<style>
.dropdown-toggle::after {
    margin-left: 0.5em;
}

.avatar-img {
    width: 40px;
    height: 40px;
    object-fit: cover;
}

.bg-orange {
    background-color: #fd7e14;
}

.text-orange {
    color: #fd7e14;
}

/* Status badge button styling */
.dropdown .btn-sm {
    padding: 0.375rem 0.75rem;
    border: none;
    font-size: 0.875rem;
    min-width: 90px;
}

/* Dropdown menu styling */
.dropdown-menu {
    min-width: 140px;
}

.dropdown-item {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
}

.dropdown-item:hover {
    background-color: #f8f9fa;
}

/* Responsive table adjustments */
@media (max-width: 992px) {
    .row-cols-xl-6 > .col {
        margin-bottom: 0.5rem;
    }
}
</style>

<!-- JavaScript for status change confirmation -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Add confirmation for status changes
    const statusLinks = document.querySelectorAll('[href*="admin_user_status"]');
    
    statusLinks.forEach(link => {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            const href = this.getAttribute('href');
            const statusText = this.textContent.trim();
            
            if (confirm(`Are you sure you want to change the user status to ${statusText}?`)) {
                window.location.href = href;
            }
        });
    });
});
</script>

{% endblock %}
