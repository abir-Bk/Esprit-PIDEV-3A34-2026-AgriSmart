<script>
document.addEventListener('DOMContentLoaded', function() {
    window.map = L.map('map').setView([36.8, 10.2], 6);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(window.map);
    window.marker = null;

    var modalEl = document.getElementById('modalAjouterParcelle');
    if (modalEl) {
        modalEl.addEventListener('shown.bs.modal', function () {
            window.map.invalidateSize();
        });
        {% if showParcelleModal|default(false) %}
        var bsModal = bootstrap.Modal.getOrCreateInstance(modalEl);
        bsModal.show();
        {% endif %}
    }

    window.map.on('click', function(e) {
        var lat = e.latlng.lat.toFixed(6);
        var lng = e.latlng.lng.toFixed(6);
       
        if (window.marker) {
            window.marker.setLatLng([lat, lng]);
        } else {
            window.marker = L.marker([lat, lng]).addTo(window.map);
        }
        document.getElementById('parcelle_latitude').value = lat;
        document.getElementById('parcelle_longitude').value = lng;
        document.getElementById('parcelle_nom').value = "Recherche du lieu...";

        fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lng}&zoom=18`)
        .then(response => response.json())
        .then(data => {
            if (data && data.address) {
                const a = data.address;
                let name = a.neighbourhood || a.suburb || a.village || a.town || a.city || a.county || a.state || "Nouvelle Parcelle";
                let detail = a.suburb || a.neighbourhood ? (a.suburb || a.neighbourhood) : "";
                let city = a.village || a.town || a.city || "";
                let finalName = detail && city && detail !== city ? detail + ", " + city : (city || name);
                document.getElementById('parcelle_nom').value = finalName;
            }
        })
        .catch(function() { document.getElementById('parcelle_nom').value = "Nouvelle Parcelle"; });
    });
});
</script>


<script>
document.addEventListener('DOMContentLoaded', function() {
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SpeechRecognition) return;

    const recognition = new SpeechRecognition();
    recognition.lang = 'fr-FR';
    
    const btn = document.getElementById('start-voice-btn');
    const status = document.getElementById('voice-status');

    // Fonction de réponse vocale
    function speak(text) {
        window.speechSynthesis.cancel(); // Arrête toute voix en cours
        const utterance = new SpeechSynthesisUtterance(text);
        utterance.lang = 'fr-FR';
        window.speechSynthesis.speak(utterance);
    }

    btn.addEventListener('click', () => {
        recognition.start();
        status.classList.remove('d-none');
        btn.classList.add('pulse-animation'); // Optionnel: ajouter une classe CSS pulse
    });

    recognition.onresult = (event) => {
        const command = event.results[0][0].transcript.toLowerCase();
        status.classList.add('d-none');
        console.log("Commande : " + command);

        // --- 1. AJOUT & CRÉATION ---
        if (command.includes("ajouter") || command.includes("nouvelle")) {
            if (command.includes("parcelle")) {
                document.querySelector('[data-bs-target="#modalAjouterParcelle"]')?.click();
                speak("Ouverture du formulaire de nouvelle parcelle.");
            } else if (command.includes("culture")) {
                document.querySelector('.btn-parcelle-primary[data-bs-target="#modalAjouterCulture"]')?.click();
                speak("Ouverture du formulaire de culture.");
            }
        }

        // --- 2. MODIFICATION ---
        else if (command.includes("modifier") || command.includes("éditer")) {
            const editBtn = document.querySelector('[data-bs-target="#modalEditCulture"]');
            if (editBtn) {
                editBtn.click();
                speak("Modification de la culture activée.");
            }
        }

        // --- 3. SUPPRESSION ---
        else if (command.includes("supprimer") || command.includes("effacer")) {
            const delBtn = document.querySelector('[data-bs-target^="#modalDeleteParcelle"]');
            if (delBtn) {
                delBtn.click();
                speak("Attention, confirmez-vous la suppression ?");
            }
        }

        // --- 4. DIAGNOSTIC & IA ---
        else if (command.includes("diagnostic") || command.includes("santé") || command.includes("maladie")) {
            // Cherche le bouton IA Diagnostic (Partie 2)
            const diagBtn = document.querySelector('button[onclick*="analyzeHealth"]');
            if (diagBtn) {
                diagBtn.click();
                speak("Analyse de santé par intelligence artificielle en cours.");
            }
        }
        else if (command.includes("conseil") || command.includes("recommandation")) {
            document.querySelector('[data-bs-target="#modalConseillerIA"]')?.click();
            speak("J'ouvre le conseiller pour vos prochaines cultures.");
        }

        // --- 5. FILTRAGE ---
        else if (command.includes("filtrer") || command.includes("montre")) {
            const filterSelect = document.querySelector('select[x-model="filterStatus"]');
            if (filterSelect) {
                if (command.includes("croissance")) { filterSelect.value = "En croissance"; speak("Affichage des cultures en croissance."); }
                else if (command.includes("besoin d'eau")) { filterSelect.value = "Besoin d'eau"; speak("Affichage des cultures ayant soif."); }
                else if (command.includes("récolté")) { filterSelect.value = "Récolté"; speak("Affichage des récoltes terminées."); }
                else { filterSelect.value = "all"; speak("Affichage de toutes les parcelles."); }
                // Déclencher l'événement change pour Alpine.js
                filterSelect.dispatchEvent(new Event('change'));
            }
        }

        // --- 6. VALIDATION & FERMETURE ---
        else if (command.includes("valider") || command.includes("enregistrer") || command.includes("confirmer")) {
            const submitBtn = document.querySelector('.modal.show .btn-parcelle-primary, .modal.show .btn-danger');
            if (submitBtn) {
                speak("Action confirmée.");
                submitBtn.click();
            }
        }
        else if (command.includes("fermer") || command.includes("quitter")) {
            document.querySelectorAll('.btn-close, [data-bs-dismiss="modal"]').forEach(b => b.click());
            speak("Fermeture.");
        }
    };

    recognition.onerror = () => { status.classList.add('d-none'); };
});
</script>
