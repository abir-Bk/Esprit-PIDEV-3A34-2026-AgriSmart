{% extends 'front/base.html.twig' %}
{% block title %}Commande confirmée | AgriSmart{% endblock %}

{% block body %}
<section class="py-5 bg-light border-bottom">
  <div class="container">
    <h1 class="display-6 fw-bold mb-1">🎉 Commande confirmée</h1>
    <div class="text-muted">Merci ! Voici le récapitulatif.</div>
  </div>
</section>

<section class="py-5">
  <div class="container">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-4 p-md-5">

        <div class="row g-4">
          <div class="col-md-6">
            <h5 class="fw-bold mb-3">Infos commande</h5>

            <ul class="list-group list-group-flush">
              <li class="list-group-item d-flex justify-content-between">
                <span>ID</span><span class="fw-semibold">#{{ commande.id }}</span>
              </li>

              <li class="list-group-item d-flex justify-content-between">
                <span>Client</span>
                <span class="fw-semibold">
                  {# adapte si ton User a getNom/getPrenom #}
                  {{ commande.client.email ?? commande.client.userIdentifier }}
                </span>
              </li>

              <li class="list-group-item d-flex justify-content-between">
                <span>Paiement</span><span class="fw-semibold">{{ commande.modePaiement }}</span>
              </li>

              <li class="list-group-item d-flex justify-content-between">
                <span>Statut</span><span class="fw-semibold">{{ commande.statut }}</span>
              </li>

              <li class="list-group-item d-flex justify-content-between">
                <span>Total</span><span class="fw-bold">{{ commande.montantTotal|number_format(2, '.', ' ') }} TND</span>
              </li>

              {% if commande.paymentRef %}
              <li class="list-group-item d-flex justify-content-between">
                <span>Réf paiement</span><span class="fw-semibold">{{ commande.paymentRef }}</span>
              </li>
              {% endif %}
            </ul>

            <div class="mt-3">
              <div class="fw-bold mb-1">Adresse livraison</div>
              <div class="text-muted">{{ commande.adresseLivraison }}</div>
            </div>
          </div>

          <div class="col-md-6">
            <h5 class="fw-bold mb-3">Détails</h5>

            <div class="table-responsive">
              <table class="table align-middle">
                <thead class="bg-light">
                  <tr>
                    <th>Produit</th>
                    <th class="text-center">Qté</th>
                    <th class="text-end">Prix</th>
                  </tr>
                </thead>
                <tbody>
                  {% for item in commande.items %}
                    <tr>
                      <td>{{ item.produit.nom }}</td>
                      <td class="text-center fw-bold">{{ item.quantite }}</td>
                      <td class="text-end fw-bold">{{ (item.prixUnitaire * item.quantite)|number_format(2, '.', ' ') }} TND</td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>

            <div class="alert alert-success rounded-4 mb-3">
              Votre commande a été enregistrée. Si la config mail est OK, un email est envoyé.
            </div>

            <a href="{{ path('app_produit_index') }}" class="btn btn-outline-secondary rounded-pill">
              Retour marketplace
            </a>
            <a href="{{ path('app_panier_index') }}" class="btn btn-outline-dark rounded-pill ms-2">
              Voir panier
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
{% endblock %}
