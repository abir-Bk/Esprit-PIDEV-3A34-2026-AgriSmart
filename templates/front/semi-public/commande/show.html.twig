{% extends 'front/semi-public/produit/base_dashboard.html.twig' %}

{% block title %}Commande #{{ commande.id }} - AgriSmart{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h1 class="h3 mb-1">Commande #{{ commande.id }}</h1>
        <p class="text-muted mb-0 small">{{ commande.createdAt|date('d/m/Y H:i') }} · {{ commande.montantTotal|number_format(2, ',', ' ') }} TND</p>
    </div>
    <a href="{{ path('app_commande_facture_pdf', {id: commande.id}) }}" class="btn btn-danger rounded-pill" target="_blank">
        <i class="bi bi-file-pdf me-1"></i> Télécharger la facture PDF
    </a>
</div>

<div class="card shadow-sm rounded-4 border-0">
    <div class="card-body p-4">
        <div class="row mb-4">
            <div class="col-md-6">
                <h6 class="text-uppercase fw-bold text-muted small mb-2">Client</h6>
                {% set u = commande.client %}
                <p class="mb-0">{{ u ? (u.firstName ?? '') ~ ' ' ~ (u.lastName ?? '') : '—' }}</p>
                <p class="text-muted small mb-0">{{ u ? (u.email ?? u.userIdentifier) : '—' }}</p>
            </div>
            <div class="col-md-6">
                <h6 class="text-uppercase fw-bold text-muted small mb-2">Adresse de livraison</h6>
                <p class="mb-0">{{ commande.adresseLivraison ?: '—' }}</p>
            </div>
        </div>

        <hr>

        <h6 class="text-uppercase fw-bold text-muted small mb-3">Articles</h6>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Produit</th>
                        <th class="text-center">Qté</th>
                        <th class="text-end">Prix unitaire</th>
                        <th class="text-end">Sous-total</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in items %}
                        <tr>
                            <td>
                                <span class="fw-semibold">{{ item.produit.nom }}</span>
                                <span class="text-muted small d-block">{{ item.produit.categorie }} · {{ item.produit.type }}</span>
                            </td>
                            <td class="text-center">{{ item.quantite }}</td>
                            <td class="text-end">{{ item.prixUnitaire|number_format(2, ',', ' ') }} TND</td>
                            <td class="text-end fw-semibold">{{ (item.prixUnitaire * item.quantite)|number_format(2, ',', ' ') }} TND</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-end mt-3 pt-3 border-top">
            <div class="text-end">
                <p class="mb-1 text-muted small">Total</p>
                <p class="h4 mb-0 fw-bold" style="color: var(--ag-primary);">{{ commande.montantTotal|number_format(2, ',', ' ') }} TND</p>
            </div>
        </div>

        <div class="d-flex align-items-center gap-2 mt-4 flex-wrap">
            <span class="text-muted small">Statut :</span>
            {% set st = commande.statut ?? 'en_attente' %}
            {% if st == 'payee' %}
                <span class="badge bg-success">Payée</span>
            {% elseif st == 'annulee' %}
                <span class="badge bg-danger">Annulée</span>
            {% elseif st == 'livree' %}
                <span class="badge bg-primary">Livrée</span>
            {% else %}
                <span class="badge bg-warning text-dark">En attente</span>
            {% endif %}
            <span class="text-muted small">Paiement : {{ commande.modePaiement == 'carte' ? 'Carte bancaire' : 'À domicile' }}</span>
        </div>

        {% if can_change_status|default(false) %}
            <form method="post" action="{{ path('app_commande_changer_statut', {id: commande.id}) }}" class="mt-3 d-flex align-items-center gap-2 flex-wrap">
                <input type="hidden" name="_token" value="{{ csrf_token('changer_statut_' ~ commande.id) }}">
                <label for="statut" class="form-label mb-0 small text-muted">Changer le statut :</label>
                <select name="statut" id="statut" class="form-select form-select-sm" style="max-width: 12rem;">
                    {% for value, label in statuts|default([]) %}
                        <option value="{{ value }}" {{ (commande.statut ?? '') == value ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
                <button type="submit" class="btn btn-sm btn-primary rounded-pill">Mettre à jour</button>
            </form>
        {% endif %}

        {% if commande.client == app.user and commande.statut == 'en_attente' %}
            <form method="post" action="{{ path('app_commande_cancel', {id: commande.id}) }}" class="mt-4" onsubmit="return confirm('Annuler cette commande ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('cancel_commande_' ~ commande.id) }}">
                <button type="submit" class="btn btn-outline-danger rounded-pill">Annuler la commande</button>
            </form>
        {% endif %}
    </div>
</div>

<div class="mt-3">
    <a href="{{ path(retour_route) }}" class="btn btn-outline-secondary rounded-pill">
        <i class="bi bi-arrow-left me-1"></i> Retour
    </a>
</div>
{% endblock %}
