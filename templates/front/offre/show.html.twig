{% extends 'front/base.html.twig' %}

{% block title %}Détails - {{ offre.title }}{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">
    {# Bouton Retour : On pointe vers la liste publique des offres #}
    <a href="{{ path('app_offre_index_front') }}" class="btn btn-outline-secondary mb-3">
        <i class="bi bi-arrow-left"></i> Voir toutes les offres
    </a>

    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
            <h2 class="mb-0 h4">{{ offre.title }}</h2>
            <span class="badge bg-white text-primary px-3 py-2">{{ offre.typeContrat }}</span>
        </div>

        <div class="card-body p-4">
            <div class="row">
                {# Contenu Principal #}
                <div class="col-md-8">
                    <h5 class="fw-bold"><i class="bi bi-file-text me-2"></i>Description du poste</h5>
                    <p class="text-muted" style="white-space: pre-line;">{{ offre.description }}</p>
                    
                    <hr class="my-4">
                    
                    <h5 class="fw-bold"><i class="bi bi-info-circle me-2"></i>Détails logistiques</h5>
                    <ul class="list-unstyled mt-3">
                        <li class="mb-2"><strong>📍 Lieu:</strong> {{ offre.lieu }}</li>
                        <li class="mb-2"><strong>💼 Département:</strong> {{ offre.typePoste }}</li>
                        <li class="mb-2"><strong>💰 Salaire:</strong> {{ offre.salaire }} TND</li>
                    </ul>
                </div>
                
                {# Barre latérale #}
                <div class="col-md-4 border-start">
                    <div class="ps-md-3">
                        <h5 class="fw-bold mb-3">Informations Clés</h5>
                        <p class="mb-2"><strong>Statut:</strong> 
                            <span class="badge {{ offre.statut|lower == 'ouvert' ? 'bg-success' : 'bg-danger' }}">
                                {{ offre.statut }}
                            </span>
                        </p>
                        <p class="mb-2"><strong>Début:</strong> {{ offre.dateDebut|date('d/m/Y') }}</p>
                        <p class="mb-4"><strong>Fin:</strong> {{ offre.dateFin|date('d/m/Y') }}</p>
                        
                        <div class="d-grid gap-2">
                            {% set isExpired = offre.dateFin < date("now") %}
                            {% set isCloture = offre.statut|lower == 'clôturée' or offre.statut|lower == 'fermé' %}
                            {% set hasAlreadyApplied = false %}

                            {# La logique de vérification app.user pourra être activée ici plus tard #}

                            {% if isExpired or isCloture %}
                                <button class="btn btn-danger btn-lg shadow-sm" disabled>
                                    <i class="bi bi-lock-fill me-2"></i>Offre clôturée
                                </button>
                            {% elseif hasAlreadyApplied %}
                                <button class="btn btn-info btn-lg text-white shadow-sm" disabled>
                                    <i class="bi bi-check-circle-fill me-2"></i>Déjà postulé
                                </button>
                            {% else %}
                                <a href="{{ path('app_demande_postuler', {'id': offre.id}) }}" class="btn btn-success btn-lg shadow-sm">
                                    <i class="bi bi-send me-2"></i>Postuler maintenant
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div> 

        <div class="card-footer bg-light text-muted py-3">
            <i class="bi bi-people me-2"></i>{{ offre.demandes|length }} candidature(s) déjà déposée(s)
        </div>
    </div>
</div>
{% endblock %}