          </div>
          <div class="kpi-icon-wrap amber"><i class="bi bi-key-fill"></i></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-info">
            <div class="kpi-value">{{ produitsPromo }}</div>
            <div class="kpi-label">En promotion</div>
            <div class="kpi-trend up"><i class="bi bi-percent"></i> Promo</div>
          </div>
          <div class="kpi-icon-wrap green"><i class="bi bi-percent"></i></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-info">
            <div class="kpi-value">{{ produitsBanned }}</div>
            <div class="kpi-label">Bannis</div>
            <div class="kpi-trend down"><i class="bi bi-slash-circle"></i> Retirés</div>
          </div>
          <div class="kpi-icon-wrap red"><i class="bi bi-slash-circle-fill"></i></div>
