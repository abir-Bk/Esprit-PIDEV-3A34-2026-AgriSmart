{% extends 'front/base.html.twig' %}
{% block title %}Checkout | AgriSmart{% endblock %}

{% block body %}
<section class="py-4 bg-light border-bottom">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center gap-3">
      <div>
        <h1 class="display-6 fw-bold mb-1">Checkout</h1>
        <p class="text-muted mb-0">Informations client + choix du mode de paiement.</p>
      </div>
      <a href="{{ path('app_panier_index') }}" class="btn btn-outline-secondary rounded-pill">
        <i class="bi bi-arrow-left me-1"></i> Retour panier
      </a>
    </div>
  </div>
</section>

<section class="py-5">
  <div class="container">

    {% if items is empty %}
      <div class="alert alert-warning rounded-4">
        Votre panier est vide. <a href="{{ path('app_produit_index') }}">Retour marketplace</a>.
      </div>
    {% else %}

      <div class="row g-4">

        <div class="col-lg-7">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
              <h4 class="fw-bold mb-3">Récapitulatif commande</h4>

              <div class="table-responsive">
                <table class="table align-middle mb-0">
                  <thead class="bg-light">
                    <tr>
                      <th>Produit</th>
                      <th class="text-center">Qté</th>
                      <th class="text-end">Total</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for row in items %}
                      <tr>
                        <td>
                          <div class="d-flex align-items-center gap-2">
                            <img
                              src="{{ asset(row.produit.image ?: 'assets/images/placeholder-product.png') }}"
                              alt="{{ row.produit.nom }}"
                              width="44" height="44"
                              class="rounded-3 border"
                              style="object-fit: cover;"
                            >
                            <div>
                              <div class="fw-semibold">{{ row.produit.nom }}</div>
                              <div class="small text-muted">{{ row.unitPrice }} TND / unité</div>
                            </div>
                          </div>
                        </td>
                        <td class="text-center fw-bold">{{ row.qty }}</td>
                        <td class="text-end fw-bold">{{ row.lineTotal }} TND</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>

              <hr class="my-3">
              <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted">Articles : {{ count }}</span>
                <span class="h5 fw-bold mb-0">{{ total }} TND</span>
              </div>
            </div>
          </div>
        </div>

        <div class="col-lg-5">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
              <h4 class="fw-bold mb-3">Paiement</h4>

              <form method="post" action="{{ path('app_checkout_process') }}" class="row g-3">
                <input type="hidden" name="_token" value="{{ csrf_token('checkout_submit') }}">

                <div class="col-12">
                  <label class="form-label">Nom complet</label>
                  <input name="customer_name" class="form-control" required placeholder="Ex: Ali Ben Salah">
                </div>

                <div class="col-12">
                  <label class="form-label">Email</label>
                  <input type="email" name="customer_email" class="form-control" required placeholder="exemple@gmail.com">
                </div>

                <div class="col-12">
                  <label class="form-label">Téléphone</label>
                  <input name="customer_phone" class="form-control" required placeholder="+216 ...">
                </div>

                <div class="col-12">
                  <label class="form-label">Adresse de livraison</label>
                  <textarea name="customer_address" class="form-control" rows="2" required placeholder="Adresse complète"></textarea>
                </div>

                <div class="col-12">
                  <label class="form-label mb-2">Mode de paiement</label>

                  <div class="border rounded-4 p-3">
                    <div class="form-check mb-2">
                      <input class="form-check-input" type="radio" name="payment_method" id="pay_cod" value="cod" checked>
                      <label class="form-check-label" for="pay_cod">
                        Paiement à la livraison (COD)
                      </label>
                    </div>

                    <div class="form-check">
                      <input class="form-check-input" type="radio" name="payment_method" id="pay_stripe" value="stripe">
                      <label class="form-check-label" for="pay_stripe">
                        Carte bancaire (Stripe)
                        <div class="small text-muted">Redirection vers Stripe Checkout sécurisé.</div>
                      </label>
                    </div>
                  </div>
                </div>

                <div class="col-12 d-grid">
                  <button class="btn btn-success rounded-pill py-2" type="submit">
                    <i class="bi bi-lock me-1"></i> Confirmer
                  </button>
                </div>

              </form>

            </div>
          </div>
        </div>

      </div>
    {% endif %}
  </div>
</section>
{% endblock %}
