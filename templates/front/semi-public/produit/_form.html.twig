        }) }}
        {% if form.imageFile.vars.errors|length %}
            <div class="invalid-feedback d-block">
                {{ form_errors(form.imageFile) }}
            </div>
        {% endif %}
        <div class="form-text">Formats acceptés: jpg / png / webp (max 3MB).</div>
    </div>

    <div class="col-12 mt-4 pb-2">
        <button type="submit" class="btn btn-success w-100 py-3 rounded-pill fw-bold" style="background:#1a4331; border:none;">
            {{ button_label|default("Publier l'annonce") }}
        </button>
    </div>

</div>

{{ form_end(form) }}

<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('produit-form');
    if (!form) return;

    const typeSelector = form.querySelector('.js-type-selector');
    const promoSwitch  = form.querySelector('.js-promo-switch');

    const sectionLocation = document.getElementById('section-location');
    const sectionPromoPrice = document.getElementById('section-promo-price');

    const startInput = form.querySelector('.js-loc-start');
    const endInput   = form.querySelector('.js-loc-end');
    let locPicker = null;

    function toggleSections() {
        const isLocation = typeSelector && typeSelector.value === 'location';

        if (sectionLocation) {
            sectionLocation.style.display = isLocation ? 'block' : 'none';
        }

        // Disable + clear dates when not location (évite incohérences + évite envoyer des valeurs)
        if (startInput) {
            startInput.disabled = !isLocation;
            if (!isLocation) startInput.value = '';
        }
        if (endInput) {
            endInput.disabled = !isLocation;
            endInput.min = startInput && startInput.value ? startInput.value : '';
            if (!isLocation) endInput.value = '';
        }

        if (!isLocation && locPicker) {
            locPicker.clear();
        }

        // Promo price
        if (promoSwitch && sectionPromoPrice) {
            sectionPromoPrice.style.display = promoSwitch.checked ? 'block' : 'none';
        }
    }

    const locCalendar = document.querySelector('[data-loc-calendar]');
    if (locCalendar && startInput && endInput) {
        const pickerInput = locCalendar.querySelector('[data-loc-picker]');
        const clearBtn = locCalendar.querySelector('[data-loc-clear]');

        const parseDate = (str) => {
            if (!str) return null;
            const [y, m, d] = String(str).split('-').map(Number);
            if (!y || !m || !d) return null;
            return new Date(y, m - 1, d);
        };
        const strip = (d) => new Date(d.getFullYear(), d.getMonth(), d.getDate());
        const iso = (d) => `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
        const today = strip(new Date());

        const syncInputs = (selectedDates = []) => {
            const start = selectedDates[0] ? strip(selectedDates[0]) : null;
            const end = selectedDates[1] ? strip(selectedDates[1]) : null;
            startInput.value = start ? iso(start) : '';
            endInput.value = end ? iso(end) : '';
            endInput.min = startInput.value || '';
            startInput.dispatchEvent(new Event('input', { bubbles: true }));
            endInput.dispatchEvent(new Event('input', { bubbles: true }));
        };

        const flatpickr = window.flatpickr;
        if (!flatpickr) {
            return;
        }

        const defaultDates = [];
        const start = parseDate(startInput.value);
        const end = parseDate(endInput.value);
        if (start) defaultDates.push(start);
        if (end) defaultDates.push(end);

        locPicker = flatpickr(pickerInput, {
            mode: 'range',
            inline: true,
            dateFormat: 'Y-m-d',
            minDate: today,
            defaultDate: defaultDates,
            onDayCreate: (_dObj, _dStr, _fp, dayElem) => {
                const d = strip(dayElem.dateObj);
                if (d < today) dayElem.classList.add('amp-past');
            },
            onChange: (selectedDates) => syncInputs(selectedDates),
        });

        clearBtn?.addEventListener('click', () => {
            locPicker.clear();
            syncInputs([]);
        });

        if (defaultDates.length > 0) {
            syncInputs(defaultDates);
        }
    }

    toggleSections();
    form.addEventListener('change', toggleSections);
    form.addEventListener('input', toggleSections);
});
</script>
