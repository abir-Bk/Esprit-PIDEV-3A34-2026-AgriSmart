		@media (min-width: 768px) { .h-sm-600px { min-height: 600px; } .landing-hero { min-height: 90vh; } }

		/* ---------- Section titles ---------- */
		.section-label { display: inline-block; padding: 0.4rem 1rem; background: rgba(26,67,49,0.1); color: var(--ag-primary); border-radius: 999px; font-weight: 600; font-size: 0.8rem; letter-spacing: 0.05em; margin-bottom: 0.75rem; text-transform: uppercase; }
		.section-title { font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 800; color: var(--ag-text); letter-spacing: -0.02em; }
		.section-subtitle { color: var(--ag-muted); font-size: 1.05rem; max-width: 580px; margin-left: auto; margin-right: auto; }

		/* ---------- Solutions cards (style .ag-card app) ---------- */
		#solutions { scroll-margin-top: 80px; }
		.solution-card { border: 1px solid rgba(17,24,39,0.06); border-radius: 20px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.04); transition: transform 0.3s ease, box-shadow 0.3s ease; height: 100%; background: #fff; }
