{% extends 'front/offre/layout.html.twig' %}

{% block title %}{{ offre.title }} | Offres d'emploi AgriSmart{% endblock %}

{% block candidature_content %}
<section class="ag-hero">
  <div class="container">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
    <div>
      <nav aria-label="breadcrumb" class="mb-2">
        <ol class="breadcrumb mb-0 small">
          <li class="breadcrumb-item"><a href="{{ path('app_offre_index_front') }}" class="text-decoration-none" style="color: var(--ag-primary);">Offres d'emploi</a></li>
          <li class="breadcrumb-item active" aria-current="page">Détails</li>
        </ol>
      </nav>
      <h1 class="ag-title">{{ offre.title }}</h1>
      <p class="ag-subtitle mb-0">
        <span class="badge rounded-pill {{ offre.statut|lower == 'ouvert' ? 'bg-success' : 'bg-secondary' }} me-2">{{ offre.statut }}</span>
        {{ offre.typeContrat }} · {{ offre.lieu }}
      </p>
    </div>
    <a href="{{ path('app_offre_index_front') }}" class="btn btn-outline-dark rounded-pill">
      <i class="bi bi-arrow-left me-1"></i>Retour aux offres
    </a>
  </div>
  </div>
</section>

<section class="ag-content mt-0">
  <div class="container">
  <div class="row g-4">
    <div class="col-lg-7">
      <div class="ag-card">
        <div class="p-4 p-lg-5">
          <h2 class="h5 fw-bold mb-3" style="color: var(--ag-primary);">Description du poste</h2>
          <div class="mb-4" style="color: var(--ag-text); line-height: 1.7;">{{ offre.description|nl2br }}</div>

          <h2 class="h5 fw-bold mb-3" style="color: var(--ag-primary);">Détails</h2>
          <div class="row g-3">
            <div class="col-md-6">
              <div class="ag-mini">
                <div class="small ag-meta mb-1">Lieu</div>
                <div class="fw-semibold"><i class="bi bi-geo-alt me-1 text-danger"></i>{{ offre.lieu }}</div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="ag-mini">
                <div class="small ag-meta mb-1">Salaire</div>
                <div class="fw-semibold"><i class="bi bi-cash-stack me-1 text-success"></i>{{ offre.salaire|number_format(0, ',', ' ') }} TND <small class="ag-meta">mensuel</small></div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="ag-mini">
                <div class="small ag-meta mb-1">Début</div>
                <div class="fw-semibold"><i class="bi bi-calendar-event me-1"></i>{{ offre.dateDebut ? offre.dateDebut|date('d/m/Y') : '—' }}</div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="ag-mini">
                <div class="small ag-meta mb-1">Fin / Limite</div>
                <div class="fw-semibold"><i class="bi bi-calendar-check me-1"></i>{{ offre.dateFin ? offre.dateFin|date('d/m/Y') : '—' }}</div>
              </div>
            </div>
            <div class="col-12">
              <div class="ag-mini">
                <div class="small ag-meta mb-1">Type de poste</div>
                <div class="fw-semibold">{{ offre.typePoste }}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="ag-card sticky-top" style="top: 1.25rem;">
        <div class="p-4">
          <h3 class="h6 fw-bold mb-3" style="color: var(--ag-text);">Résumé</h3>
          <div class="d-flex justify-content-between py-2 border-bottom"><span class="ag-meta small">Statut</span><span class="badge {{ offre.statut|lower == 'ouvert' ? 'bg-success' : 'bg-secondary' }}">{{ offre.statut }}</span></div>
          <div class="d-flex justify-content-between py-2 border-bottom"><span class="ag-meta small">Date limite</span><span class="fw-semibold">{{ offre.dateFin|date('d/m/Y') }}</span></div>
          <div class="d-flex justify-content-between py-2 border-bottom"><span class="ag-meta small">Candidatures</span><span class="fw-semibold">{{ offre.demandes|length }}</span></div>

          {% set isClosed = offre.statut|lower == 'clôturée' or offre.statut|lower == 'clôture' %}
          {% set isExpired = offre.dateFin < date("now") %}
          {% set canApply = not isExpired and not isClosed %}

          <div class="mt-4 pt-3">
            {% if not canApply %}
              <button class="btn btn-secondary rounded-pill w-100 py-2" disabled><i class="bi bi-slash-circle me-2"></i>Offre fermée</button>
              <p class="text-center ag-meta small mt-2 mb-0">Cette offre n'accepte plus de candidatures.</p>
            {% else %}
              <a href="{{ path('app_demande_postuler', {id: offre.id}) }}" class="btn ag-btn-primary text-white rounded-pill w-100 py-2">
                <i class="bi bi-send-fill me-2"></i>Postuler
              </a>
              <p class="text-center ag-meta small mt-2 mb-0">Clôture le {{ offre.dateFin|date('d/m/Y') }}</p>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
  </div>
</section>
{% endblock %}
