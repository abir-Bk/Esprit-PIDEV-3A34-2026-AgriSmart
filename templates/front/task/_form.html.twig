			<div class="col-md-4">
				{{ form_label(form.localisation, null, {label_attr: label_attr}) }}
				<div class="input-icon-wrap">
					<i class="bi bi-geo-alt input-icon"></i>
					{{ form_widget(form.localisation, {'attr': {'class': 'form-control ag-input ps-icon', 'placeholder': 'Ex: Parcelle Nord…'}}) }}
				</div>
				{{ form_errors(form.localisation) }}
			</div>
		</div>
