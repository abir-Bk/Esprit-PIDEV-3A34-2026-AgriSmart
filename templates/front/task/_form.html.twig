{# ═══════════════════════════════════════════════
   SCRIPTS (AI features)
   ═══════════════════════════════════════════════ #}
<script>
	(function () {
let _aiInitialized = false;

function initAiFeatures() {
if (_aiInitialized) 
return;

_aiInitialized = true;

const btnSummarize = document.getElementById('btn-ai-summarize');
const btnTranslate = document.getElementById('btn-ai-translate');
const btnRecommend = document.getElementById('btn-ai-recommend');
const langSelect = document.getElementById('select-ai-lang');
const spinner = document.getElementById('ai-spinner');
const descriptionInput = document.getElementById('task-description') || document.getElementById('task_description') || document.querySelector('[id$="_description"]');
const resumeInput = document.getElementById('task-resume') || document.getElementById('task_resume') || document.querySelector('[id$="_resume"]');
const errorDiv = document.getElementById('ai-error');

function toggleUI(loading) {
if (btnSummarize) 
btnSummarize.disabled = loading;

if (btnTranslate) 
btnTranslate.disabled = loading;

if (btnRecommend) 
btnRecommend.disabled = loading;

if (spinner) 
spinner.classList.toggle('d-none', ! loading);

if (descriptionInput) 
descriptionInput.classList.toggle('opacity-50', loading);

if (resumeInput) 
resumeInput.classList.toggle('opacity-50', loading);

}

function showError(msg) {
if (errorDiv) {
const span = errorDiv.querySelector('span') || errorDiv;
span.textContent = msg || 'Une erreur est survenue';
errorDiv.classList.remove('d-none');
}
}

function hideError() {
if (errorDiv) 
errorDiv.classList.add('d-none');

}

if (! btnSummarize) {
console.warn('AI buttons not found, AI features disabled.');
} else { // Logic for Summarize
btnSummarize.addEventListener('click', async function () {
const text = descriptionInput.value.trim();
if (text.length < 10) {
showError('Le texte doit contenir au moins 10 caractères pour être résumé.');
return;
}
toggleUI(true);
try {
const response = await fetch('{{ path('task_ai_summarize') }}', {
method: 'POST',
headers: {
'Content-Type': 'application/json'
},
body: JSON.stringify({text})
});
const data = await response.json();
if (data.summary) {
resumeInput.value = data.summary;
hideError();
} else if (data.error) {
showError(data.error);
}
} catch (e) {
console.error('Summarize Error', e);
showError('Erreur lors de la génération du résumé.');
} finally {
toggleUI(false);
}
});

// Logic for Translate
if (btnTranslate) {
btnTranslate.addEventListener('click', async function () {
const text = descriptionInput.value.trim();
const targetLang = langSelect.value;
if (text.length < 2) {
showError('Le texte doit contenir au moins 2 caractères pour être traduit.');
return;
}
toggleUI(true);
try {
const response = await fetch('{{ path('task_ai_translate') }}', {
method: 'POST',
headers: {
'Content-Type': 'application/json'
},
body: JSON.stringify(
{text, target: targetLang}
)
});
const data = await response.json();
if (data.translation) {
descriptionInput.value = data.translation;
hideError();
} else if (data.error) {
showError(data.error);
}
} catch (e) {
console.error('Translate Error', e);
showError('Erreur lors de la traduction.');
} finally {
toggleUI(false);
}
});
}

// Logic for Recommend
if (btnRecommend) {
btnRecommend.addEventListener('click', async function () {
const titreEl = document.getElementById('task-titre') || document.getElementById('task_titre') || document.querySelector('[id$="_titre"]');
if (! titreEl) {
showError('Champ titre introuvable.');
return;
}
const title = titreEl.value.trim();
const typeSelect = document.querySelector('[name$="[type]"]');
const type = typeSelect ? typeSelect.value : '';
if (title.length < 3) {
showError('Le titre doit contenir au moins 3 caractères pour générer une recommandation.');
return;
}
toggleUI(true);
try {
const response = await fetch('{{ path('task_ai_recommend') }}', {
method: 'POST',
headers: {
'Content-Type': 'application/json'
},
body: JSON.stringify(
{title, type}
)
});
const data = await response.json();
if (data.recommendation) {
descriptionInput.value = data.recommendation;
hideError();
} else if (data.error) {
showError(data.error);
}
} catch (e) {
console.error('Recommend Error', e);
showError('Erreur lors de la génération de la recommandation.');
} finally {
toggleUI(false);
}
});
}
}

// Emergency Detective (Priority Analysis)
const titleInput = document.getElementById('task-titre') || document.getElementById('task_titre') || document.querySelector('[id$="_titre"]');
const prioritySelect = document.getElementById('task-priorite') || document.getElementById('task_priorite') || document.querySelector('[id$="_priorite"]');
const priorityHint = document.getElementById('priority-hint');

if (titleInput && prioritySelect) {
let timeout = null;
const analyzeUrgency = () => {
clearTimeout(timeout);
timeout = setTimeout(async () => {
const title = titleInput.value.trim();
const description = descriptionInput ? descriptionInput.value.trim() : '';
if (title.length < 3) 
return;

try {
const response = await fetch('{{ path('task_ai_analyze_priority') }}', {
method: 'POST',
headers: {
'Content-Type': 'application/json'
},
body: JSON.stringify(
{title, description}
)
});
const data = await response.json();
if (data.priority === 'high') {
for (let option of prioritySelect.options) {
if (option.value.toLowerCase().includes('high') || option.text.toLowerCase().includes('haut')) {
prioritySelect.value = option.value;
prioritySelect.dispatchEvent(new Event('change'));
break;
}
}
if (priorityHint) 
priorityHint.classList.remove('d-none');

} else {
if (priorityHint) 
priorityHint.classList.add('d-none');

}
} catch (e) {
console.error('Local Analysis Error', e);
}
}, 500);
};
titleInput.addEventListener('input', analyzeUrgency);
if (descriptionInput) 
descriptionInput.addEventListener('input', analyzeUrgency);

}
}

document.addEventListener('DOMContentLoaded', initAiFeatures);
document.addEventListener('turbo:load', function () {
_aiInitialized = false;
initAiFeatures();
});
})();
</script>
