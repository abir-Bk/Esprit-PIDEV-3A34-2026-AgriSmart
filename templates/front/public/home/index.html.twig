		.solution-card:hover .card-img-wrap img { transform: scale(1.05); }
		.solution-card .card-badge { position: absolute; top: 1rem; right: 1rem; font-weight: 600; font-size: 0.8rem; padding: 0.35rem 0.85rem; border-radius: 999px; }
		.solution-card .card-body { padding: 1.5rem 1.5rem 2rem; }
