{% extends 'base.html.twig' %}

{% block title %}Nouvelle annonce{% endblock %}

{% block body %}

<section class="pt-4 pt-md-5">
  <div class="container">

    {# HERO #}
    <div class="am-hero card shadow-sm am-hero-soft mb-4">
      <div class="card-body p-4 p-md-5">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
          <div>
            <span class="badge rounded-pill text-bg-light border am-badge-pill">
              <i class="bi bi-plus-circle me-2"></i>Publier
            </span>
            <h1 class="mt-3 mb-2 am-hero-title">Nouvelle annonce</h1>
            <p class="text-muted mb-0">
              Créez une annonce claire : titre, catégorie, type, prix, stock, image — et si c’est une location : dates & emplacement.
            </p>
          </div>

          <a class="btn btn-outline-dark am-btn" href="{{ path('app_produit_index') }}">
            <i class="bi bi-arrow-left me-2"></i>Retour Marketplace
          </a>
        </div>

        <div class="row g-3 mt-4">
          <div class="col-md-4">
            <div class="am-tip">
              <div class="am-tip-k">Astuce</div>
              <div class="am-tip-v">Une bonne description = + de contacts</div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="am-tip">
              <div class="am-tip-k">Promo</div>
              <div class="am-tip-v">Activez seulement si utile</div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="am-tip">
              <div class="am-tip-k">Image</div>
              <div class="am-tip-v">Format carré conseillé</div>
            </div>
          </div>
        </div>

      </div>
    </div>

    {# FORM + PREVIEW (dynamic) #}
    <div class="row g-4 align-items-start">
      <div class="col-lg-7">
        <div class="card shadow-sm am-card-soft">
          <div class="card-header bg-transparent border-0 pb-0">
            <div class="d-flex align-items-center gap-2">
              <i class="bi bi-pencil-square"></i>
              <h5 class="mb-0">Informations de l’annonce</h5>
            </div>
            <small class="text-muted">Les champs marqués <b>*</b> sont obligatoires</small>
          </div>
          <div class="card-body pt-3">
            {{ include('produit/_form.html.twig', { form: form }) }}
          </div>
        </div>
      </div>

      <div class="col-lg-5" id="previewCol">
        <div class="card shadow-sm am-card-soft sticky-lg-top" style="top: 110px;">
          <div class="card-header bg-transparent border-0 pb-0">
            <div class="d-flex align-items-center gap-2">
              <i class="bi bi-eye"></i>
              <h6 class="mb-0">Aperçu</h6>
            </div>
          </div>

          <div class="card-body pt-3">
            <div class="am-preview-img">
              <img id="previewImage" src="{{ asset('assets/images/placeholder-product.png') }}" alt="preview">
            </div>

            <div class="mt-3">
              <div class="am-preview-title" id="previewTitle">Titre du produit</div>
              <div class="am-preview-sub" id="previewSub">Catégorie • Type</div>

              <div class="am-preview-pills mt-3">
                <span class="am-pill2"><i class="bi bi-tag me-2"></i><span id="previewPrice">Prix</span></span>
                <span class="am-pill2"><i class="bi bi-box-seam me-2"></i><span id="previewStock">Stock</span></span>
              </div>

              <div class="mt-3" id="previewLocationBox" class="d-none">
                <div class="am-preview-sub fw-semibold mb-1">Location</div>
                <div class="text-muted small" id="previewLocationText">Dates + emplacement</div>
              </div>

              <div class="mt-3">
                <button class="btn btn-dark am-btn w-100" type="button" disabled>
                  <i class="bi bi-check2-circle me-2"></i>Publier
                </button>
                <small class="text-muted d-block mt-2">
                  Aperçu live — mis à jour automatiquement.
                </small>
              </div>
            </div>

            <div class="alert alert-warning mt-3 mb-0">
              <i class="bi bi-shield-check me-2"></i>
              Vérifiez le prix, le stock, la promo et les infos location avant publication.
            </div>
          </div>
        </div>

        <button class="btn btn-light am-btn w-100 mt-3 d-lg-none" type="button" id="togglePreviewBtn">
          <i class="bi bi-eye me-2"></i>Afficher/Masquer l’aperçu
        </button>
      </div>
    </div>

  </div>
</section>

{% endblock %}
