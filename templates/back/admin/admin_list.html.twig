{% extends 'back/admin_base.html.twig' %}

{% block title %}Offres d'emploi - Admin AgriSmart{% endblock %}

{% block body %}
<div class="d-flex back-offres-layout">
    {% include 'back/components/sidebar.html.twig' %}

    <div class="flex-grow-1 p-4 am-content back-offres-content">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show am-alert" role="alert">
                <i class="fa-solid fa-check-circle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show am-alert" role="alert">
                <i class="fa-solid fa-exclamation-circle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
            </div>
        {% endfor %}

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3 mt-0">
            <div>
                <h1 class="h3 mb-1 am-title">
                    <i class="fa-solid fa-briefcase me-2"></i>Offres d'emploi
                </h1>
                <p class="text-muted mb-0 small">Consulter, approuver ou refuser les offres.</p>
            </div>
        </div>

        {% set count_attente = 0 %}
        {% set count_approuvee = 0 %}
        {% set count_refusee = 0 %}
        {% for o in offres %}
            {% if o.statutValidation|default('en_attente') == 'en_attente' %}{% set count_attente = count_attente + 1 %}{% endif %}
            {% if o.statutValidation|default('en_attente') == 'approuvée' %}{% set count_approuvee = count_approuvee + 1 %}{% endif %}
            {% if o.statutValidation|default('en_attente') == 'refusée' %}{% set count_refusee = count_refusee + 1 %}{% endif %}
        {% endfor %}

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card border-0 am-card h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="am-icon-wrap am-icon-warning me-3">
                            <i class="fa-solid fa-clock"></i>
                        </div>
                        <div>
                            <span class="text-muted small d-block">En attente</span>
                            <span class="fw-bold fs-4 am-text">{{ count_attente }}</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 am-card h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="am-icon-wrap am-icon-success me-3">
                            <i class="fa-solid fa-check"></i>
                        </div>
                        <div>
                            <span class="text-muted small d-block">Approuvées</span>
                            <span class="fw-bold fs-4 am-text-success">{{ count_approuvee }}</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 am-card h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="am-icon-wrap am-icon-danger me-3">
                            <i class="fa-solid fa-times"></i>
                        </div>
                        <div>
                            <span class="text-muted small d-block">Refusées</span>
                            <span class="fw-bold fs-4 text-danger">{{ count_refusee }}</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 am-card">
            <div class="card-body p-4">
                <div class="row g-3 mb-4">
                    <div class="col-md-8">
                        <div class="input-group am-input-group">
                            <span class="input-group-text bg-white border-end-0">
                                <i class="fa-solid fa-search am-text-muted"></i>
                            </span>
                            <input id="offreSearchInput" class="form-control border-start-0" type="search"
                                   placeholder="Rechercher par titre ou lieu..." aria-label="Recherche">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <select id="filterValidation" class="form-select am-select">
                            <option value="">Tous les statuts</option>
                            <option value="en_attente">En attente</option>
                            <option value="approuvée">Approuvées</option>
                            <option value="refusée">Refusées</option>
                        </select>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 am-table">
                        <thead>
                            <tr>
                                <th class="am-th">#</th>
                                <th class="am-th">Titre / Lieu</th>
                                <th class="am-th">Type</th>
                                <th class="am-th">Salaire</th>
                                <th class="am-th">Validation</th>
                                <th class="am-th text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="offreList">
                            {% for offre in offres %}
                                {% set validation = offre.statutValidation|default('en_attente') %}
                                <tr class="am-row"
                                    data-title="{{ offre.title|lower }}"
                                    data-lieu="{{ offre.lieu|default('')|lower }}"
                                    data-validation="{{ validation }}">
                                    <td class="py-3"><span class="text-muted fw-medium">{{ loop.index }}</span></td>
                                    <td class="py-3">
                                        <div>
                                            <strong class="am-text">{{ offre.title }}</strong>
                                            <div class="small text-muted"><i class="fa-solid fa-location-dot me-1"></i>{{ offre.lieu|default('—') }}</div>
                                        </div>
                                    </td>
                                    <td class="py-3">
                                        <span class="badge am-badge">{{ offre.typeContrat|default('CDI') }}</span>
                                    </td>
                                    <td class="py-3 fw-medium">
                                        {{ offre.salaire ? (offre.salaire|number_format(0, ',', ' ') ~ ' DT') : '—' }}
                                    </td>
                                    <td class="py-3">
                                        {% if validation == 'approuvée' %}
                                            <span class="badge am-badge-success"><i class="fa-solid fa-check me-1"></i>Approuvée</span>
                                        {% elseif validation == 'refusée' %}
                                            <span class="badge am-badge-danger"><i class="fa-solid fa-times me-1"></i>Refusée</span>
                                        {% else %}
                                            <span class="badge am-badge-warning"><i class="fa-solid fa-clock me-1"></i>En attente</span>
                                        {% endif %}
                                    </td>
                                    <td class="py-3 text-end am-actions-cell">
                                        <div class="d-flex justify-content-end gap-2 flex-nowrap align-items-center">
                                            <a href="{{ path('app_admin_offre_details', {id: offre.id}) }}" class="btn btn-sm am-btn-outline text-nowrap">
                                                <i class="fa-solid fa-eye me-1"></i>Voir
                                            </a>
                                            {% if validation == 'en_attente' %}
                                                <form method="post" action="{{ path('app_offre_approuver', {id: offre.id}) }}" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('approuver' ~ offre.id) }}">
                                                    <button type="submit" class="btn btn-sm am-btn-success text-nowrap"><i class="fa-solid fa-check me-1"></i>Approuver</button>
                                                </form>
                                                <form method="post" action="{{ path('app_offre_refuser', {id: offre.id}) }}" class="d-inline" onsubmit="return confirm('Refuser cette offre ?');">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('refuser' ~ offre.id) }}">
                                                    <button type="submit" class="btn btn-sm am-btn-danger text-nowrap"><i class="fa-solid fa-times me-1"></i>Refuser</button>
                                                </form>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">
                                        <i class="fa-solid fa-briefcase fa-2x mb-2 d-block"></i>
                                        Aucune offre.
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
/* Palette identique à l'interface utilisateur (login, register) */
.back-offres-layout { min-height: 100vh; }
.back-offres-content { margin-top: 0; padding-top: 1.25rem; }
.am-content { background: #f0f7f2; }
.am-title { color: #1F3D2B; font-weight: 700; }
.am-text { color: #1F3D2B; }
.am-text-success { color: #28a745; }
.am-text-muted { color: #5a6c5d; }
.am-card { box-shadow: 0 2px 16px rgba(31, 61, 43, 0.08); border-radius: 14px; border: 1px solid rgba(31, 61, 43, 0.08); }
.am-card .card-body { border-radius: 14px; }
.am-icon-wrap { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; }
.am-icon-success { background: rgba(40, 167, 69, 0.14); color: #28a745; }
.am-icon-warning { background: rgba(230, 191, 74, 0.22); color: #b8860b; }
.am-icon-danger { background: rgba(220, 53, 69, 0.12); color: #dc3545; }
.am-input-group .form-control:focus { border-color: #E6BF4A; box-shadow: 0 0 0 0.2rem rgba(230, 191, 74, 0.22); }
.am-select { border-radius: 10px; border: 1px solid #e2e8e6; }
.am-select:focus { border-color: #E6BF4A; box-shadow: 0 0 0 0.2rem rgba(230, 191, 74, 0.2); }
.am-th { color: #1F3D2B; font-weight: 600; padding: 0.75rem 1rem; border-bottom: 1px solid #e2e8e6; background: rgba(31, 61, 43, 0.04); }
.am-table tbody tr { border-bottom: 1px solid #e8edea; }
.am-table tbody tr:hover { background: rgba(31, 61, 43, 0.04); }
.am-actions-cell { min-width: 200px; white-space: nowrap; }
.am-badge { background: rgba(31, 61, 43, 0.12); color: #1F3D2B; padding: 0.35rem 0.65rem; border-radius: 8px; font-weight: 500; }
.am-badge-success { background: rgba(40, 167, 69, 0.14); color: #28a745; padding: 0.35rem 0.65rem; border-radius: 8px; font-weight: 500; }
.am-badge-warning { background: rgba(230, 191, 74, 0.22); color: #b8860b; padding: 0.35rem 0.65rem; border-radius: 8px; font-weight: 500; }
.am-badge-danger { background: rgba(220, 53, 69, 0.12); color: #dc3545; padding: 0.35rem 0.65rem; border-radius: 8px; font-weight: 500; }
.am-btn-outline { border: 1px solid #1F3D2B; color: #1F3D2B; border-radius: 8px; }
.am-btn-outline:hover { background: #1F3D2B; color: #fff; }
.am-btn-success { background: linear-gradient(135deg, #1F3D2B 0%, #2d5a3d 100%); color: #fff; border: none; border-radius: 8px; }
.am-btn-success:hover { background: linear-gradient(135deg, #1a4331 0%, #28a745 100%); color: #fff; }
.am-btn-danger { background: #dc3545; color: #fff; border: none; border-radius: 8px; }
.am-btn-danger:hover { background: #c82333; color: #fff; }
.am-alert { border-radius: 12px; border-left: 4px solid #28a745; }
.alert-success { background: rgba(40, 167, 69, 0.1); }
</style>

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    var searchInput = document.getElementById('offreSearchInput');
    var filterValidation = document.getElementById('filterValidation');
    var rows = document.querySelectorAll('#offreList tr.am-row');
    function filterTable() {
        var search = (searchInput && searchInput.value) ? searchInput.value.toLowerCase().trim() : '';
        var validation = filterValidation ? filterValidation.value : '';
        rows.forEach(function(row) {
            var title = (row.dataset.title || '');
            var lieu = (row.dataset.lieu || '');
            var val = (row.dataset.validation || '');
            var matchSearch = !search || title.indexOf(search) !== -1 || lieu.indexOf(search) !== -1;
            var matchVal = !validation || val === validation;
            row.style.display = (matchSearch && matchVal) ? '' : 'none';
        });
    }
    if (searchInput) searchInput.addEventListener('input', filterTable);
    if (filterValidation) filterValidation.addEventListener('change', filterTable);
});
</script>
{% endblock %}
{% endblock %}
