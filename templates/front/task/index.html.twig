{% extends 'front/task/layout.html.twig' %}

{% block title %}Liste des tâches - AgriSmart {% endblock %}

{% block task_content %}
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Tâches agricoles</h5>
            <div class="d-flex gap-2">
                <a href="{{ path('tasks_calendar') }}" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-calendar3 me-1"></i> Calendrier
                </a>
                <a href="{{ path('tasks_new') }}" class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-circle me-1"></i> Nouvelle tâche
                </a>
            </div>
        </div>
        <div class="card-body">
            <form method="get" action="{{ path('tasks_index') }}" class="row g-2 mb-3">
                <div class="col-md-5">
                    <input
                        type="text"
                        name="q"
                        class="form-control"
                        placeholder="Rechercher par titre, type, statut..."
                        value="{{ q|default('') }}"
                    >
                </div>
                <div class="col-md-3">
                    <select name="sort" class="form-select">
                        <option value="dateDebut" {{ (sort|default('dateDebut')) == 'dateDebut' ? 'selected' : '' }}>Trier par date debut</option>
                        <option value="dateFin" {{ (sort|default('dateDebut')) == 'dateFin' ? 'selected' : '' }}>Trier par date fin</option>
                        <option value="titre" {{ (sort|default('dateDebut')) == 'titre' ? 'selected' : '' }}>Trier par titre</option>
                        <option value="type" {{ (sort|default('dateDebut')) == 'type' ? 'selected' : '' }}>Trier par type</option>
                        <option value="priorite" {{ (sort|default('dateDebut')) == 'priorite' ? 'selected' : '' }}>Trier par priorite</option>
                        <option value="statut" {{ (sort|default('dateDebut')) == 'statut' ? 'selected' : '' }}>Trier par statut</option>
                        <option value="id" {{ (sort|default('dateDebut')) == 'id' ? 'selected' : '' }}>Trier par ID</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="direction" class="form-select">
                        <option value="DESC" {{ (direction|default('DESC')) == 'DESC' ? 'selected' : '' }}>Decroissant</option>
                        <option value="ASC" {{ (direction|default('DESC')) == 'ASC' ? 'selected' : '' }}>Croissant</option>
                    </select>
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-outline-primary">Appliquer</button>
                </div>
            </form>

            <table class="table table-striped align-middle">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Titre</th>
                    <th>Type</th>
                    <th>Priorité</th>
                    <th>Statut</th>
                    <th>Date début</th>
                    <th>Date fin</th>
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for task in tasks %}
                    <tr>
                        <td>{{ task.idTask }}</td>
                        <td>{{ task.titre }}</td>
                        <td>{{ task.type }}</td>
                        <td>{{ task.priorite }}</td>
                        <td>{{ task.statut }}</td>
                        <td>{{ task.dateDebut ? task.dateDebut|date('d/m/Y H:i') : '' }}</td>
                        <td>{{ task.dateFin ? task.dateFin|date('d/m/Y H:i') : '' }}</td>
                        <td class="text-end">
                            <a href="{{ path('tasks_show', {id: task.idTask}) }}" class="btn btn-sm btn-outline-secondary">Voir</a>
                            <a href="{{ path('tasks_edit', {id: task.idTask}) }}" class="btn btn-sm btn-outline-primary">Modifier</a>
                            <form method="post" action="{{ path('tasks_delete', {id: task.idTask}) }}" class="d-inline" onsubmit="return confirm('Supprimer cette tâche ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ task.idTask) }}">
                                <button class="btn btn-sm btn-outline-danger">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center text-muted">Aucune tâche enregistrée.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}


