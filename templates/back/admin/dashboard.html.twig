{% extends 'back/admin_base.html.twig' %}

{% block title %}Tableau de bord — AgriConnect Admin{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<style>
  :root {
    --green-900: #1a3d28;
    --green-700: #2d6a42;
    --green-500: #3d8b5a;
    --green-400: #52a872;
    --green-100: #e8f5ee;
    --green-50:  #f3faf6;
    --amber-500: #d97706;
    --amber-100: #fef3c7;
    --red-500:   #dc2626;
    --red-100:   #fee2e2;
    --blue-500:  #2563eb;
    --blue-100:  #dbeafe;
    --slate-900: #0f172a;
    --slate-700: #334155;
    --slate-500: #64748b;
    --slate-300: #cbd5e1;
    --slate-100: #f1f5f9;
    --slate-50:  #f8fafc;
    --white:     #ffffff;
    --shadow-sm: 0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.04);
    --shadow-md: 0 4px 12px rgba(0,0,0,.08), 0 2px 4px rgba(0,0,0,.04);
    --radius-sm: 8px;
    --radius:    12px;
    --radius-lg: 16px;
  }

  *, *::before, *::after { box-sizing: border-box; }

  .dash-wrapper {
    background: var(--slate-50);
    min-height: 100vh;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: var(--slate-900);
  }
/* ── Calm Milky Header ───────────────────────────────────────── */

.page-header {
  background: linear-gradient(
    135deg,
    #ffffff 0%,
    #f8fafc 40%,
    #f3f6f9 100%
  );
  border-bottom: 1px solid #e9eef3;
  position: relative;
  overflow: hidden;
}

/* very soft light texture */
.page-header::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(rgba(0,0,0,0.02) 1px, transparent 1px);
  background-size: 24px 24px;
  pointer-events: none;
}

/* soft right glow */
.page-header::after {
  content: '';
  position: absolute;
  top: -60px;
  right: -60px;
  width: 280px;
  height: 280px;
  background: radial-gradient(circle, rgba(168,145,106,0.08) 0%, transparent 70%);
  pointer-events: none;
}

/* subtle gold line */
.page-header-gold-line {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(168,145,106,.15) 25%,
    rgba(168,145,106,.4) 50%,
    rgba(168,145,106,.15) 75%,
    transparent 100%
  );
}

.page-header-inner {
  position: relative;
  z-index: 1;
  padding: 32px 36px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  flex-wrap: wrap;
}

/* accent bar */
.page-header-accent {
  width: 3px;
  height: 50px;
  border-radius: 4px;
  background: linear-gradient(
    180deg,
    #a8916a 0%,
    #c4b08a 50%,
    #a8916a 100%
  );
}

.page-header-text h1 {
  font-family: 'Playfair Display', serif;
  font-size: 26px;
  font-weight: 700;
  margin: 0 0 6px;
  color: #1e293b;
  letter-spacing: -0.02em;
}

.page-header-text p {
  font-size: 13px;
  margin: 0;
  color: #64748b;
  font-weight: 400;
}

.page-header-text p strong {
  color: #334155;
  font-weight: 600;
}

/* badges (date & time) */
.header-badge {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #ffffff;
  border: 1px solid #e5eaf0;
  border-radius: 10px;
  padding: 8px 15px;
  font-size: 12.5px;
  font-weight: 500;
  color: #475569;
  box-shadow: 0 2px 6px rgba(0,0,0,0.04);
}

.header-badge i {
  font-size: 13px;
  color: #a8916a;
}
  .dash-content { padding: 28px 32px 48px; max-width: 1400px; }

  .section-label {
    display: flex; align-items: center; justify-content: space-between;
    margin: 32px 0 16px;
  }
  .section-label h2 {
    font-family: 'Playfair Display', serif; font-size: 17px; font-weight: 600;
    color: var(--slate-900); margin: 0; display: flex; align-items: center; gap: 8px;
  }
  .section-label h2 i { font-size: 16px; color: var(--green-500); }
  .section-label a {
    font-size: 13px; font-weight: 500; color: var(--green-500); text-decoration: none;
    display: flex; align-items: center; gap: 4px; padding: 6px 12px;
    border: 1px solid var(--green-100); border-radius: var(--radius-sm);
    background: var(--green-50); transition: all .15s;
  }
  .section-label a:hover { background: var(--green-100); color: var(--green-700); }

  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
    gap: 16px;
  }
  .kpi-card {
    background: var(--white); border-radius: var(--radius-lg);
    border: 1px solid var(--slate-100); padding: 20px 22px;
    box-shadow: var(--shadow-sm); display: flex; align-items: center;
    justify-content: space-between; gap: 16px;
    transition: box-shadow .2s, transform .2s;
    animation: fadeSlideUp .4s ease both;
  }
  .kpi-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .kpi-card:nth-child(1) { animation-delay: .05s; }
  .kpi-card:nth-child(2) { animation-delay: .10s; }
  .kpi-card:nth-child(3) { animation-delay: .15s; }
  .kpi-card:nth-child(4) { animation-delay: .20s; }
  .kpi-card:nth-child(5) { animation-delay: .25s; }

  .kpi-info { flex: 1; min-width: 0; }
  .kpi-value {
    font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 700;
    line-height: 1; color: var(--slate-900); margin-bottom: 4px;
  }
  .kpi-label { font-size: 12px; font-weight: 500; color: var(--slate-500); }
  .kpi-icon-wrap {
    width: 48px; height: 48px; border-radius: var(--radius);
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; flex-shrink: 0;
  }
  .kpi-icon-wrap.green  { background: var(--green-100); color: var(--green-700); }
  .kpi-icon-wrap.amber  { background: var(--amber-100); color: var(--amber-500); }
  .kpi-icon-wrap.red    { background: var(--red-100);   color: var(--red-500); }
  .kpi-icon-wrap.blue   { background: var(--blue-100);  color: var(--blue-500); }
  .kpi-icon-wrap.slate  { background: var(--slate-100); color: var(--slate-500); }

  .kpi-trend {
    display: inline-flex; align-items: center; gap: 3px;
    font-size: 11px; font-weight: 600; padding: 2px 7px;
    border-radius: 20px; margin-top: 5px;
  }
  .kpi-trend.up      { background: var(--green-100); color: var(--green-700); }
  .kpi-trend.warn    { background: var(--amber-100); color: var(--amber-500); }
  .kpi-trend.down    { background: var(--red-100);   color: var(--red-500); }
  .kpi-trend.neutral { background: var(--slate-100); color: var(--slate-500); }

  .charts-grid {
    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px;
  }
  @media (max-width: 1100px) { .charts-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 700px)  { .charts-grid { grid-template-columns: 1fr; } }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 800px) { .two-col { grid-template-columns: 1fr; } }

  .card {
    background: var(--white); border-radius: var(--radius-lg);
    border: 1px solid var(--slate-100); box-shadow: var(--shadow-sm);
    overflow: hidden; animation: fadeSlideUp .45s ease both;
  }
  .card-header {
    padding: 16px 20px; border-bottom: 1px solid var(--slate-100);
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
  }
  .card-header-title {
    font-family: 'Playfair Display', serif; font-size: 15px; font-weight: 600;
    color: var(--slate-900); margin: 0; display: flex; align-items: center; gap: 7px;
  }
  .card-header-title i { color: var(--green-500); font-size: 15px; }
  .card-header a { font-size: 12px; font-weight: 500; color: var(--green-500); text-decoration: none; }
  .card-header a:hover { text-decoration: underline; }
  .card-body { padding: 20px; }
  .card-body-sm { padding: 0; }

  .chart-subtitle { font-size: 12px; color: var(--slate-500); margin: 0 0 16px; }

  /* ── This is the key part for UX bundle charts ── */
  /* render_chart() outputs a <canvas> inside a div[data-controller] */
  .chart-wrap canvas { max-height: 200px; }
  .chart-wrap-tall canvas { max-height: 220px; }

  .role-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
  .role-item {
    background: var(--green-50); border: 1px solid var(--green-100);
    border-radius: var(--radius-sm); padding: 12px 14px;
    display: flex; align-items: center; gap: 10px;
  }
  .role-icon {
    width: 34px; height: 34px; border-radius: 8px;
    background: var(--green-100); color: var(--green-700);
    display: flex; align-items: center; justify-content: center; font-size: 15px; flex-shrink: 0;
  }
  .role-count {
    font-family: 'Playfair Display', serif; font-size: 20px;
    font-weight: 700; line-height: 1; color: var(--slate-900);
  }
  .role-name { font-size: 11px; color: var(--slate-500); font-weight: 500; }

  .pill {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 9px; border-radius: 20px;
    font-size: 11px; font-weight: 600; white-space: nowrap;
  }
  .pill.active   { background: var(--green-100); color: var(--green-700); }
  .pill.pending  { background: var(--amber-100); color: var(--amber-500); }
  .pill.disabled { background: var(--red-100);   color: var(--red-500); }

  .dash-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .dash-table thead th {
    padding: 10px 18px; text-align: left; font-size: 10px; font-weight: 700;
    letter-spacing: .07em; text-transform: uppercase; color: var(--slate-500);
    background: var(--slate-50); border-bottom: 1px solid var(--slate-100);
  }
  .dash-table tbody td {
    padding: 13px 18px; border-bottom: 1px solid var(--slate-100);
    vertical-align: middle; color: var(--slate-700);
  }
  .dash-table tbody tr:last-child td { border-bottom: none; }
  .dash-table tbody tr:hover td { background: var(--slate-50); }

  .user-cell { display: flex; align-items: center; gap: 10px; }
  .avatar {
    width: 34px; height: 34px; border-radius: 50%;
    background: linear-gradient(135deg, var(--green-500), var(--green-400));
    color: var(--white); display: inline-flex; align-items: center;
    justify-content: center; font-size: 12px; font-weight: 700; flex-shrink: 0;
  }
  .user-name  { font-weight: 600; color: var(--slate-900); font-size: 13px; }
  .user-role  { font-size: 11px; color: var(--slate-500); margin-top: 1px; }

  .btn-action {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 11px; border-radius: var(--radius-sm);
    font-size: 11px; font-weight: 600; text-decoration: none;
    border: none; cursor: pointer; transition: opacity .15s, transform .1s;
  }
  .btn-action:hover { opacity: .82; transform: translateY(-1px); }
  .btn-action.view    { background: var(--blue-100);  color: var(--blue-500); }
  .btn-action.approve { background: var(--green-100); color: var(--green-700); }

  .legend-list { display: flex; flex-direction: column; gap: 8px; margin-top: 14px; }
  .legend-item { display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--slate-700); }
  .legend-dot { width: 10px; height: 10px; border-radius: 3px; flex-shrink: 0; }
  .legend-item span:last-child {
    margin-left: auto; font-weight: 700; color: var(--slate-900);
    font-family: 'Playfair Display', serif; font-size: 14px;
  }

  .empty-state { text-align: center; padding: 36px 20px; color: var(--slate-500); }
  .empty-state i { font-size: 32px; color: var(--slate-300); display: block; margin-bottom: 8px; }
  .empty-state p { font-size: 13px; margin: 0; }

  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 640px) {
    .page-header-inner { padding: 20px 20px; }
    .dash-content { padding: 20px 16px 40px; }
  }
</style>
{% endblock %}

{% block body %}
<div class="dash-wrapper">

  {# ── Sidebar ──────────────────────────────────────────────────── #}
  {% include 'back/components/sidebar.html.twig' %}

  {# ── Main ─────────────────────────────────────────────────────── #}
  <main>

      {# Page Header #}
    <div class="page-header">
      <div class="page-header-gold-line"></div>
      <div class="page-header-inner">
        <div class="page-header-left">
          <div class="page-header-accent"></div>
          <div class="page-header-text">
            <h1>Tableau de bord</h1>
            <p>Bonjour <strong>{{ app.user.firstName ?? 'Administrateur' }}</strong> — aperçu de la plateforme AgriConnect</p>
          </div>
        </div>
        <div class="page-header-right">
          <div class="header-badge">
            <i class="bi bi-clock"></i>
            <span id="js-clock">—</span>
          </div>
          <div class="header-badge">
            <i class="bi bi-calendar3"></i>
            <span id="js-date">—</span>
          </div>
        </div>
      </div>
    </div>
    <div class="dash-content">

      {# ══════════════════════ USERS ══════════════════════ #}
      <div class="section-label">
        <h2><i class="bi bi-people-fill"></i> Utilisateurs</h2>
        <a href="{{ path('admin_users') }}">Voir tout <i class="bi bi-arrow-right"></i></a>
      </div>

      <div class="kpi-grid">
        <div class="kpi-card">
          <div class="kpi-info">
            <div class="kpi-value">{{ totalUsers }}</div>
            <div class="kpi-label">Total utilisateurs</div>
            <div class="kpi-trend neutral"><i class="bi bi-people"></i> Tous rôles</div>
          </div>
          <div class="kpi-icon-wrap green"><i class="bi bi-people-fill"></i></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-info">
            <div class="kpi-value">{{ activeUsers }}</div>
            <div class="kpi-label">Comptes actifs</div>
            <div class="kpi-trend up"><i class="bi bi-check-circle-fill"></i> Actifs</div>
          </div>
          <div class="kpi-icon-wrap green"><i class="bi bi-person-check-fill"></i></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-info">
            <div class="kpi-value">{{ pendingUsers }}</div>
            <div class="kpi-label">En attente</div>
            <div class="kpi-trend warn"><i class="bi bi-hourglass-split"></i> À valider</div>
          </div>
          <div class="kpi-icon-wrap amber"><i class="bi bi-hourglass-split"></i></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-info">
            <div class="kpi-value">{{ disabledUsers }}</div>
            <div class="kpi-label">Désactivés</div>
            <div class="kpi-trend down"><i class="bi bi-slash-circle"></i> Inactifs</div>
          </div>
          <div class="kpi-icon-wrap red"><i class="bi bi-person-x-fill"></i></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-info">
            <div class="kpi-value">{{ newUsersThisMonth }}</div>
            <div class="kpi-label">Nouveaux (30 j.)</div>
            <div class="kpi-trend up"><i class="bi bi-graph-up-arrow"></i> Ce mois</div>
          </div>
          <div class="kpi-icon-wrap blue"><i class="bi bi-person-plus-fill"></i></div>
        </div>
      </div>

      {# Users charts row #}
      <div class="charts-grid" style="margin-top:16px;">

        {# Donut — status #}
        <div class="card">
          <div class="card-header">
            <h5 class="card-header-title"><i class="bi bi-pie-chart-fill"></i> Statuts des comptes</h5>
          </div>
          <div class="card-body">
            <p class="chart-subtitle">Répartition active / en attente / désactivé</p>
            <div id="chartUserStatus" style="min-height:200px;"></div>
            <div class="legend-list">
              <div class="legend-item">
                <div class="legend-dot" style="background:#3d8b5a"></div> Actifs <span>{{ activeUsers }}</span>
              </div>
              <div class="legend-item">
                <div class="legend-dot" style="background:#d97706"></div> En attente <span>{{ pendingUsers }}</span>
              </div>
              <div class="legend-item">
                <div class="legend-dot" style="background:#dc2626"></div> Désactivés <span>{{ disabledUsers }}</span>
              </div>
            </div>
          </div>
        </div>

        {# Roles card #}
        <div class="card">
          <div class="card-header">
            <h5 class="card-header-title"><i class="bi bi-diagram-3-fill"></i> Répartition par rôle</h5>
          </div>
          <div class="card-body">
            <div class="role-grid">
              <div class="role-item">
                <div class="role-icon"><i class="bi bi-flower1"></i></div>
                <div>
                  <div class="role-count">{{ usersByRole.agriculteur ?? 0 }}</div>
                  <div class="role-name">Agriculteurs</div>
                </div>
              </div>
              <div class="role-item">
                <div class="role-icon"><i class="bi bi-building"></i></div>
                <div>
                  <div class="role-count">{{ usersByRole.fournisseur ?? 0 }}</div>
                  <div class="role-name">Fournisseurs</div>
                </div>
              </div>
              <div class="role-item">
                <div class="role-icon"><i class="bi bi-briefcase-fill"></i></div>
                <div>
                  <div class="role-count">{{ usersByRole.employee ?? 0 }}</div>
                  <div class="role-name">Employés</div>
                </div>
              </div>
              <div class="role-item">
                <div class="role-icon"><i class="bi bi-shield-fill-check"></i></div>
                <div>
                  <div class="role-count">{{ usersByRole.admin ?? 0 }}</div>
                  <div class="role-name">Admins</div>
                </div>
              </div>
            </div>
            <div id="chartUserRole" style="min-height:130px;"></div>
          </div>
        </div>

        {# Recent users mini-table #}
        <div class="card">
          <div class="card-header">
            <h5 class="card-header-title"><i class="bi bi-person-lines-fill"></i> Derniers inscrits</h5>
            <a href="{{ path('admin_users') }}">Voir tout</a>
          </div>
          <div class="card-body-sm">
            {% if recentUsers|length > 0 %}
            <table class="dash-table">
              <thead>
                <tr>
                  <th>Utilisateur</th>
                  <th>Statut</th>
                </tr>
              </thead>
              <tbody>
                {% for u in recentUsers %}
                <tr>
                  <td>
                    <div class="user-cell">
                      <div class="avatar">{{ u.firstName|first|upper }}{{ u.lastName|first|upper }}</div>
                      <div>
                        <div class="user-name">{{ u.firstName }} {{ u.lastName }}</div>
                        <div class="user-role">{{ u.role ?? '—' }}</div>
                      </div>
                    </div>
                  </td>
                  <td>
                    {% if u.status == 'active' %}
                      <span class="pill active"><i class="bi bi-check-circle-fill"></i> Actif</span>
                    {% elseif u.status == 'pending' %}
                      <span class="pill pending"><i class="bi bi-hourglass-split"></i> En attente</span>
                    {% else %}
                      <span class="pill disabled"><i class="bi bi-slash-circle"></i> Désactivé</span>
                    {% endif %}
                  </td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
            {% else %}
            <div class="empty-state">
              <i class="bi bi-person-slash"></i>
              <p>Aucun utilisateur récent.</p>
            </div>
            {% endif %}
          </div>
        </div>

      </div>{# /charts-grid users #}


      {# ══════════════════════ OFFRES ══════════════════════ #}
      <div class="section-label">
        <h2><i class="bi bi-file-earmark-text-fill"></i> Offres d'emploi</h2>
        <a href="{{ path('app_offre_admin_index') }}">Voir tout <i class="bi bi-arrow-right"></i></a>
      </div>

      <div class="kpi-grid">
        <div class="kpi-card">
          <div class="kpi-info">
            <div class="kpi-value">{{ totalOffres }}</div>
            <div class="kpi-label">Total offres</div>
            <div class="kpi-trend neutral"><i class="bi bi-file-text"></i> Toutes</div>
          </div>
          <div class="kpi-icon-wrap green"><i class="bi bi-file-earmark-text-fill"></i></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-info">
            <div class="kpi-value">{{ offresApproved }}</div>
            <div class="kpi-label">Approuvées</div>
            <div class="kpi-trend up"><i class="bi bi-check-circle-fill"></i> Publiées</div>
          </div>
          <div class="kpi-icon-wrap green"><i class="bi bi-file-earmark-check-fill"></i></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-info">
            <div class="kpi-value">{{ offresPending }}</div>
            <div class="kpi-label">En attente</div>
            <div class="kpi-trend warn"><i class="bi bi-hourglass-split"></i> À traiter</div>
          </div>
          <div class="kpi-icon-wrap amber"><i class="bi bi-file-earmark-minus-fill"></i></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-info">
            <div class="kpi-value">{{ offresRefused }}</div>
            <div class="kpi-label">Refusées</div>
            <div class="kpi-trend down"><i class="bi bi-x-circle-fill"></i> Rejetées</div>
          </div>
          <div class="kpi-icon-wrap red"><i class="bi bi-file-earmark-x-fill"></i></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-info">
            <div class="kpi-value">{{ offresActive }}</div>
            <div class="kpi-label">Actives / visibles</div>
            <div class="kpi-trend up"><i class="bi bi-broadcast"></i> En ligne</div>
          </div>
          <div class="kpi-icon-wrap blue"><i class="bi bi-broadcast-pin"></i></div>
        </div>
      </div>

      <div class="two-col" style="margin-top:16px;">

        {# Offres donut #}
        <div class="card">
          <div class="card-header">
            <h5 class="card-header-title"><i class="bi bi-pie-chart-fill"></i> Validation des offres</h5>
          </div>
          <div class="card-body">
            <p class="chart-subtitle">Approuvées · En attente · Refusées</p>
            <div id="chartOffres" style="min-height:200px;"></div>
            <div class="legend-list">
              <div class="legend-item">
                <div class="legend-dot" style="background:#3d8b5a"></div> Approuvées <span>{{ offresApproved }}</span>
              </div>
              <div class="legend-item">
                <div class="legend-dot" style="background:#d97706"></div> En attente <span>{{ offresPending }}</span>
              </div>
              <div class="legend-item">
                <div class="legend-dot" style="background:#dc2626"></div> Refusées <span>{{ offresRefused }}</span>
              </div>
            </div>
          </div>
        </div>

        {# Pending offres quick-action table #}
        <div class="card">
          <div class="card-header">
            <h5 class="card-header-title"><i class="bi bi-lightning-charge-fill"></i> Offres en attente</h5>
            <a href="{{ path('app_offre_admin_index') }}">Gérer tout</a>
          </div>
          <div class="card-body-sm">
            {% if recentOffres|length > 0 %}
            <table class="dash-table">
              <thead>
                <tr>
                  <th>Offre</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for offre in recentOffres %}
                <tr>
                  <td>
                    <div class="user-name">{{ offre.title|length > 32 ? offre.title|slice(0,32) ~ '…' : offre.title }}</div>
                    <div class="user-role"><i class="bi bi-geo-alt"></i> {{ offre.lieu ?? '—' }}</div>
                  </td>
                  <td>
                    <div style="display:flex;gap:6px;flex-wrap:wrap;">
                      <a class="btn-action view" href="{{ path('app_admin_offre_details', {id: offre.id}) }}">
                        <i class="bi bi-eye-fill"></i> Voir
                      </a>
                      <form method="post" action="{{ path('app_offre_approuver', {id: offre.id}) }}" style="margin:0;">
                        <input type="hidden" name="_token" value="{{ csrf_token('approuver'~offre.id) }}">
                        <button type="submit" class="btn-action approve">
                          <i class="bi bi-check-lg"></i> Approuver
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
            {% else %}
            <div class="empty-state">
              <i class="bi bi-check2-circle"></i>
              <p>Toutes les offres ont été traitées.</p>
            </div>
            {% endif %}
          </div>
        </div>

      </div>{# /two-col offres #}


      {# ══════════════════════ PRODUITS ══════════════════════ #}
      <div class="section-label">
        <h2><i class="bi bi-shop-window"></i> Marketplace — Produits</h2>
        <a href="{{ path('app_produit_index') }}">Voir tout <i class="bi bi-arrow-right"></i></a>
      </div>

      <div class="kpi-grid">
        <div class="kpi-card">
          <div class="kpi-info">
            <div class="kpi-value">{{ totalProduits }}</div>
            <div class="kpi-label">Total produits</div>
            <div class="kpi-trend neutral"><i class="bi bi-box-seam"></i> Tous</div>
          </div>
          <div class="kpi-icon-wrap green"><i class="bi bi-shop-window"></i></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-info">
            <div class="kpi-value">{{ produitsVente }}</div>
            <div class="kpi-label">À vendre</div>
            <div class="kpi-trend up"><i class="bi bi-tag-fill"></i> Vente</div>
          </div>
          <div class="kpi-icon-wrap blue"><i class="bi bi-tag-fill"></i></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-info">
            <div class="kpi-value">{{ produitsLocation }}</div>
            <div class="kpi-label">En location</div>
            <div class="kpi-trend warn"><i class="bi bi-key-fill"></i> Location</div>
          </div>
          <div class="kpi-icon-wrap amber"><i class="bi bi-key-fill"></i></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-info">
            <div class="kpi-value">{{ produitsPromo }}</div>
            <div class="kpi-label">En promotion</div>
            <div class="kpi-trend up"><i class="bi bi-percent"></i> Promo</div>
          </div>
          <div class="kpi-icon-wrap green"><i class="bi bi-percent"></i></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-info">
            <div class="kpi-value">{{ produitsBanned }}</div>
            <div class="kpi-label">Bannis</div>
            <div class="kpi-trend down"><i class="bi bi-slash-circle"></i> Retirés</div>
          </div>
          <div class="kpi-icon-wrap red"><i class="bi bi-slash-circle-fill"></i></div>
        </div>
      </div>

      <div class="two-col" style="margin-top:16px;">

        {# Produits type bar #}
        <div class="card">
          <div class="card-header">
            <h5 class="card-header-title"><i class="bi bi-bar-chart-fill"></i> Types d'annonces</h5>
          </div>
          <div class="card-body">
            <p class="chart-subtitle">Vente · Location · Promotion · Bannis</p>
            <div class="chart-meta">
              <div class="chart-meta-item">
                <div class="chart-meta-dot" style="background:#3d8b5a;border-radius:3px;width:10px;height:10px;"></div> Vente
              </div>
              <div class="chart-meta-item">
                <div class="chart-meta-dot" style="background:#2563eb;border-radius:3px;width:10px;height:10px;"></div> Location
              </div>
              <div class="chart-meta-item">
                <div class="chart-meta-dot" style="background:#d97706;border-radius:3px;width:10px;height:10px;"></div> Promo
              </div>
              <div class="chart-meta-item">
                <div class="chart-meta-dot" style="background:#dc2626;border-radius:3px;width:10px;height:10px;"></div> Bannis
              </div>
            </div>
            <div id="chartProduitType" style="min-height:220px;"></div>
          </div>
        </div>

        {# Produits by category #}
        <div class="card">
          <div class="card-header">
            <h5 class="card-header-title"><i class="bi bi-bar-chart-steps"></i> Top catégories</h5>
          </div>
          <div class="card-body">
            <p class="chart-subtitle">Produits par catégorie (top 6)</p>
            <div id="chartProduitCat" style="min-height:220px;"></div>
          </div>
        </div>

      </div>{# /two-col produits #}

    </div>{# /dash-content #}
  </main>

</div>{# /dash-wrapper #}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/apexcharts@3.46.0/dist/apexcharts.min.js"></script>
<script>
// ── Live clock ────────────────────────────────────────────────────
(function() {
  const days   = ['Dim','Lun','Mar','Mer','Jeu','Ven','Sam'];
  const months = ['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];
  function tick() {
    const now = new Date();
    document.getElementById('js-clock').textContent =
      now.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit', second:'2-digit'});
    document.getElementById('js-date').textContent =
      days[now.getDay()] + ' ' + now.getDate() + ' ' + months[now.getMonth()] + ' ' + now.getFullYear();
  }
  tick(); setInterval(tick, 1000);
})();

// ── Shared palette ────────────────────────────────────────────────
const C = {
  green:  '#3d8b5a',
  greenL: '#52a872',
  amber:  '#d97706',
  red:    '#dc2626',
  blue:   '#2563eb',
  blueL:  '#60a5fa',
  slate:  '#64748b',
  sand:   '#a8916a',
};

const fontFamily = "'Plus Jakarta Sans', sans-serif";

// ── User status donut ─────────────────────────────────────────────
new ApexCharts(document.getElementById('chartUserStatus'), {
  chart: { type: 'donut', height: 200, fontFamily, toolbar: { show: false } },
  series: [{{ activeUsers }}, {{ pendingUsers }}, {{ disabledUsers }}],
  labels: ['Actifs', 'En attente', 'Désactivés'],
  colors: [C.green, C.amber, C.red],
  plotOptions: { pie: { donut: { size: '68%', labels: {
    show: true,
    total: { show: true, label: 'Total', color: '#64748b',
      formatter: (w) => w.globals.seriesTotals.reduce((a,b) => a+b, 0)
    }
  } } } },
  dataLabels: { enabled: false },
  legend: { show: false },
  stroke: { width: 0 },
}).render();

// ── User roles bar ────────────────────────────────────────────────
new ApexCharts(document.getElementById('chartUserRole'), {
  chart: { type: 'bar', height: 130, fontFamily, toolbar: { show: false },
    sparkline: { enabled: false } },
  series: [{ name: 'Utilisateurs', data: [
    {{ usersByRole.agriculteur ?? 0 }},
    {{ usersByRole.fournisseur ?? 0 }},
    {{ usersByRole.employee   ?? 0 }},
    {{ usersByRole.admin      ?? 0 }}
  ]}],
  xaxis: { categories: ['Agriculteurs','Fournisseurs','Employés','Admins'],
    labels: { style: { fontSize: '10px', colors: '#64748b' } } },
  yaxis: { labels: { style: { fontSize: '10px', colors: '#64748b' } } },
  colors: [C.green],
  plotOptions: { bar: { borderRadius: 5, columnWidth: '55%' } },
  dataLabels: { enabled: false },
  grid: { borderColor: '#f1f5f9', strokeDashArray: 3 },
  tooltip: { y: { formatter: v => v + ' utilisateurs' } },
}).render();

// ── Offres donut ──────────────────────────────────────────────────
new ApexCharts(document.getElementById('chartOffres'), {
  chart: { type: 'donut', height: 200, fontFamily, toolbar: { show: false } },
  series: [{{ offresApproved }}, {{ offresPending }}, {{ offresRefused }}],
  labels: ['Approuvées', 'En attente', 'Refusées'],
  colors: [C.green, C.amber, C.red],
  plotOptions: { pie: { donut: { size: '68%', labels: {
    show: true,
    total: { show: true, label: 'Total', color: '#64748b',
      formatter: (w) => w.globals.seriesTotals.reduce((a,b) => a+b, 0)
    }
  } } } },
  dataLabels: { enabled: false },
  legend: { show: false },
  stroke: { width: 0 },
}).render();

// ── Produits type bar ─────────────────────────────────────────────
new ApexCharts(document.getElementById('chartProduitType'), {
  chart: { type: 'bar', height: 220, fontFamily, toolbar: { show: false } },
  series: [{ name: 'Produits', data: [
    {{ produitsVente }}, {{ produitsLocation }}, {{ produitsPromo }}, {{ produitsBanned }}
  ]}],
  xaxis: { categories: ['Vente', 'Location', 'Promotion', 'Bannis'],
    labels: { style: { fontSize: '11px', colors: '#64748b' } } },
  yaxis: { labels: { style: { fontSize: '11px', colors: '#64748b' } } },
  colors: [C.green, C.blue, C.amber, C.red],
  fill: { type: 'solid' },
  plotOptions: { bar: {
    borderRadius: 6,
    columnWidth: '50%',
    distributed: true,
  } },
  dataLabels: { enabled: true, style: { fontSize: '11px', fontWeight: 600 } },
  legend: { show: false },
  grid: { borderColor: '#f1f5f9', strokeDashArray: 3 },
  tooltip: { y: { formatter: v => v + ' produits' } },
}).render();

// ── Produits categories horizontal bar ────────────────────────────
const catLabels = {{ produitCategories|raw }};
const catCounts = {{ produitCatCounts|raw }};
new ApexCharts(document.getElementById('chartProduitCat'), {
  chart: { type: 'bar', height: 220, fontFamily, toolbar: { show: false } },
  series: [{ name: 'Produits', data: catCounts.length ? catCounts : [0] }],
  xaxis: {
    categories: catLabels.length ? catLabels : ['Aucune donnée'],
    labels: { style: { fontSize: '11px', colors: '#64748b' } }
  },
  yaxis: { labels: { style: { fontSize: '11px', colors: '#64748b' } } },
  plotOptions: { bar: { borderRadius: 5, horizontal: true, barHeight: '60%' } },
  colors: [C.green],
  dataLabels: { enabled: true, style: { fontSize: '11px', fontWeight: 600 } },
  grid: { borderColor: '#f1f5f9', strokeDashArray: 3 },
  tooltip: { y: { formatter: v => v + ' produits' } },
}).render();
</script>
{% endblock %}
