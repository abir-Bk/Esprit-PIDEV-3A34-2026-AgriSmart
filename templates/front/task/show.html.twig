{% extends 'front/task/layout.html.twig' %}

{% block title %}Détail de la tâche - AgriSmart{% endblock %}

{% block task_content %}
  <div class="container py-3 py-md-4">
  <div class="ag-card p-4 mb-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
      <h5 class="mb-0 fw-bold" style="color: var(--ag-text);">Détails de la tâche</h5>
      <div class="d-flex gap-2">
        {% if task.statut == 'en_cours' %}
          <a href="{{ path('suivi_tache_new', {id: task.idTask}) }}" class="btn btn-sm btn-success text-white rounded-pill">Terminer la tâche</a>
        {% endif %}
        <a href="{{ path('tasks_edit', {id: task.idTask}) }}" class="btn btn-sm ag-btn-primary text-white rounded-pill">Modifier</a>
        <a href="{{ path('tasks_index') }}" class="btn btn-sm btn-outline-secondary rounded-pill">Retour à la liste</a>
      </div>
    </div>
    <dl class="row mb-0">
      <dt class="col-sm-3 ag-meta">ID</dt>
      <dd class="col-sm-9">{{ task.idTask }}</dd>
      <dt class="col-sm-3 ag-meta">Titre</dt>
      <dd class="col-sm-9">{{ task.titre }}</dd>
      <dt class="col-sm-3 ag-meta">
        Description
        <div class="input-group input-group-sm mt-2" style="width: auto;">
            <select id="select-ai-lang-show" class="form-select form-select-sm border-0 bg-light-info text-info fw-bold">
                <option value="en">EN</option>
                <option value="ar">AR</option>
                <option value="fr">FR</option>
                <option value="es">ES</option>
            </select>
            <button type="button" id="btn-ai-translate-show" class="btn btn-sm btn-outline-info border-0 bg-light-info">
                <i class="bi bi-translate text-info"></i>
            </button>
        </div>
      </dt>
      <dd class="col-sm-9" id="task-description-show">{{ task.description }}</dd>
      <dt class="col-sm-3 ag-meta">Type</dt>
      <dd class="col-sm-9">{{ task.type }}</dd>
      <dt class="col-sm-3 ag-meta">Priorité</dt>
      <dd class="col-sm-9">{{ task.priorite }}</dd>
      <dt class="col-sm-3 ag-meta">Statut</dt>
      <dd class="col-sm-9">
        {% if task.statut == 'todo' %}
          <span class="badge bg-secondary">À faire</span>
        {% elseif task.statut == 'en_cours' %}
          <span class="badge bg-primary">En cours</span>
        {% elseif task.statut == 'a_valider' %}
          <span class="badge bg-warning text-dark">À valider</span>
        {% elseif task.statut == 'termine' %}
          <span class="badge bg-success">Terminé</span>
        {% else %}
          <span class="badge bg-dark">{{ task.statut }}</span>
        {% endif %}
      </dd>
      <dt class="col-sm-3 ag-meta">Date début</dt>
      <dd class="col-sm-9">{{ task.dateDebut ? task.dateDebut|date('d/m/Y H:i') : '' }}</dd>
      <dt class="col-sm-3 ag-meta">Date fin</dt>
      <dd class="col-sm-9">{{ task.dateFin ? task.dateFin|date('d/m/Y H:i') : '' }}</dd>
      <dt class="col-sm-3 ag-meta">Localisation</dt>
      <dd class="col-sm-9">{{ task.localisation }}</dd>
      <dt class="col-sm-3 ag-meta">ID Parcelle</dt>
      <dd class="col-sm-9">{{ task.parcelleId }}</dd>
      <dt class="col-sm-3 ag-meta">ID Culture</dt>
      <dd class="col-sm-9">{{ task.cultureId }}</dd>
      <dt class="col-sm-3 ag-meta">Créée par (ID utilisateur)</dt>
      <dd class="col-sm-9">{{ task.createdBy }}</dd>
    </dl>
  </div>

  <form method="post" action="{{ path('tasks_delete', {id: task.idTask}) }}" class="d-inline" onsubmit="return confirm('Supprimer cette tâche ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ task.idTask) }}">
    <button class="btn btn-outline-danger rounded-pill">Supprimer</button>
  </form>
  </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    (function() {
        function initAiTranslateShow() {
            const btn = document.getElementById('btn-ai-translate-show');
            const langSelect = document.getElementById('select-ai-lang-show');
            const descElement = document.getElementById('task-description-show');

            if (!btn || !descElement) return;

            btn.addEventListener('click', async function() {
                const text = descElement.innerText.trim();
                const targetLang = langSelect.value;
                if (text.length < 2) return;

                btn.disabled = true;
                descElement.classList.add('opacity-50');

                try {
                    const response = await fetch('{{ path('task_ai_translate') }}', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({ text: text, target: targetLangMapping(targetLang) })
                    });
                    const data = await response.json();
                    if (response.ok) {
                        descElement.textContent = data.translation;
                        descElement.classList.add('text-info');
                        setTimeout(() => descElement.classList.remove('text-info'), 2000);
                    }
                } catch (e) {
                    console.error('Translation error', e);
                } finally {
                    btn.disabled = false;
                    descElement.classList.remove('opacity-50');
                }
            });

            function targetLangMapping(code) {
                const map = { 'en': 'anglais', 'ar': 'arabe', 'fr': 'français', 'es': 'espagnol' };
                return map[code] || code;
            }
        }
        document.addEventListener('turbo:load', initAiTranslateShow);
        initAiTranslateShow();
    })();
    </script>
    <style>
        .bg-light-info { background-color: rgba(13, 202, 240, 0.1); }
    </style>
{% endblock %}
