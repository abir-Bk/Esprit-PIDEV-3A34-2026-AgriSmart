{% set label_attr = {'class': 'form-label fw-semibold small text-uppercase letter-spacing-1', 'style': 'color: var(--ag-muted); font-size: 0.72rem; letter-spacing: 0.05em;'} %}

{# Désactivation de la validation HTML5 #}
{{ form_start(form, { attr: { novalidate: 'novalidate', class: 'task-form-enhanced' } }) }}

{# ═══════════════════════════════════════════════
   SECTION 1 : Informations de base
   ═══════════════════════════════════════════════ #}
<div class="form-section mb-4">
	<div class="form-section-header">
		<div class="form-section-icon">
			<i class="bi bi-pencil-square"></i>
		</div>
		<div>
			<h6 class="form-section-title mb-0">Informations de base</h6>
			<span class="form-section-subtitle">Titre, type et description de la tâche</span>
		</div>
	</div>
	<div class="form-section-body">
		<div class="row g-3">
			<div class="col-md-7">
				{{ form_label(form.titre, null, {label_attr: label_attr}) }}
				<div class="input-icon-wrap">
					<i class="bi bi-type-h1 input-icon"></i>
					{{ form_widget(form.titre, {'attr': {'class': 'form-control ag-input ps-icon', 'id': 'task-titre', 'placeholder': 'Ex: Arrosage parcelle Nord...'}}) }}
				</div>
				{{ form_errors(form.titre) }}
			</div>
			<div class="col-md-5">
				{{ form_label(form.type, null, {label_attr: label_attr}) }}
				<div class="input-icon-wrap">
					<i class="bi bi-tag input-icon"></i>
					{{ form_widget(form.type, {'attr': {'class': 'form-select ag-input ps-icon'}}) }}
				</div>
				{{ form_errors(form.type) }}
			</div>
		</div>
	</div>
</div>

{# ═══════════════════════════════════════════════
   SECTION 2 : Description & IA
   ═══════════════════════════════════════════════ #}
<div class="form-section mb-4">
	<div class="form-section-header">
		<div class="form-section-icon ai-glow">
			<i class="bi bi-stars"></i>
		</div>
		<div class="flex-grow-1">
			<h6 class="form-section-title mb-0">Description & Assistance IA</h6>
			<span class="form-section-subtitle">Rédigez ou laissez l'IA vous aider</span>
		</div>
		<div class="ai-toolbar d-flex flex-wrap gap-2">
			<div class="input-group input-group-sm ai-btn-group">
				<select id="select-ai-lang" class="form-select form-select-sm ai-lang-select">
					<option value="en">EN</option>
					<option value="ar">AR</option>
					<option value="fr">FR</option>
					<option value="es">ES</option>
				</select>
				<button type="button" id="btn-ai-translate" class="btn btn-sm ai-action-btn" title="Traduire la description">
					<i class="bi bi-translate me-1"></i>Traduire
				</button>
			</div>
			<button type="button" id="btn-ai-recommend" class="btn btn-sm ai-action-btn" title="Générer une description recommandée">
				<i class="bi bi-lightbulb me-1"></i>Recommander
			</button>
			<button type="button" id="btn-ai-summarize" class="btn btn-sm ai-action-btn ai-primary-btn" title="Générer un résumé automatique">
				<i class="bi bi-magic me-1"></i>Résumer
				<span id="ai-spinner" class="spinner-border spinner-border-sm ms-1 d-none" role="status" aria-hidden="true"></span>
			</button>
		</div>
	</div>
	<div class="form-section-body">
		<div class="row g-3">
			<div class="col-12">
				{{ form_label(form.description, null, {label_attr: label_attr}) }}
				{{ form_widget(form.description, {'attr': {'class': 'form-control ag-input', 'rows': 5, 'id': 'task-description', 'placeholder': 'Décrivez la tâche en détail…'}}) }}
				{{ form_errors(form.description) }}
			</div>
			<div class="col-12">
				{{ form_label(form.resume, null, {label_attr: label_attr}) }}
				<div class="resume-field-wrap">
					<i class="bi bi-robot resume-icon"></i>
					{{ form_widget(form.resume, {'attr': {'class': 'form-control ag-input resume-input', 'rows': 2, 'id': 'task-resume', 'placeholder': 'Cliquez sur « Résumer » ou saisissez manuellement…'}}) }}
				</div>
				{{ form_errors(form.resume) }}
				<div id="ai-error" class="ai-error-box d-none mt-2">
					<i class="bi bi-exclamation-circle me-1"></i>
					<span></span>
				</div>
			</div>
		</div>
	</div>
</div>

{# ═══════════════════════════════════════════════
   SECTION 3 : Planification
   ═══════════════════════════════════════════════ #}
