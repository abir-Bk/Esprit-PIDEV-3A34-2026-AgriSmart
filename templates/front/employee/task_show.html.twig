{% extends 'front/task/layout.html.twig' %}

{% block title %}Détail de la tâche - AgriSmart{% endblock %}

{% block task_content %}
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="mb-0 fw-bold" style="color: var(--ag-text);">Détails de la tâche</h3>
            <a href="{{ path('employee_tasks_index') }}" class="btn btn-outline-secondary rounded-pill">
                <i class="bi bi-arrow-left me-1"></i> Retour à mes tâches
            </a>
        </div>

        <div class="ag-card mb-4">
            <div class="p-3 text-white" style="background-color: var(--ag-primary);">
                <h5 class="mb-0 fw-bold">{{ task.titre }}</h5>
            </div>
            <div class="card-body p-4">
                <div class="row g-4">
                    <div class="col-md-8">
                        <section class="mb-4">
                            <h6 class="text-muted text-uppercase small fw-bold mb-2">Description</h6>
                            <p class="lead">{{ task.description ?: 'Aucune description fournie.' }}</p>
                        </section>

                        <div class="row row-cols-1 row-cols-sm-2 g-3">
                            <div class="col">
                                <h6 class="text-muted text-uppercase small fw-bold mb-1">Type de tâche</h6>
                                <p>{{ task.type }}</p>
                            </div>
                            <div class="col">
                                <h6 class="text-muted text-uppercase small fw-bold mb-1">Priorité</h6>
                                <span class="badge {% if task.priorite == 'high' %}bg-danger{% elseif task.priorite == 'medium' %}bg-warning text-dark{% else %}bg-info{% endif %}">
                                    {{ task.priorite|upper }}
                                </span>
                            </div>
                            <div class="col">
                                <h6 class="text-muted text-uppercase small fw-bold mb-1">Date début</h6>
                                <p>{{ task.dateDebut ? task.dateDebut|date('d/m/Y H:i') : '—' }}</p>
                            </div>
                            <div class="col">
                                <h6 class="text-muted text-uppercase small fw-bold mb-1">Date fin estimée</h6>
                                <p>{{ task.dateFin ? task.dateFin|date('d/m/Y H:i') : '—' }}</p>
                            </div>
                        </div>

                        {% if task.localisation %}
                        <section class="mt-4">
                            <h6 class="text-muted text-uppercase small fw-bold mb-1">Localisation</h6>
                            <p><i class="bi bi-geo-alt me-1"></i> {{ task.localisation }}</p>
                        </section>
                        {% endif %}
                    </div>
                    
                    <div class="col-md-4">
                        <div class="bg-light p-3 rounded-3 h-100">
                            <h6 class="text-muted text-uppercase small fw-bold mb-3">Statut de l'affectation</h6>
                            <div class="d-flex align-items-center mb-4">
                                <div class="p-2 bg-white rounded-circle shadow-sm me-3">
                                    <i class="bi bi-activity text-success fs-4"></i>
                                </div>
                                <h5 class="mb-0 text-success fw-bold">{{ assignment.statut|upper }}</h5>
                            </div>

                            <hr>

                            <h6 class="text-muted text-uppercase small fw-bold mb-2">Action requise</h6>
                            {% if task.statut == 'todo' %}
                                <p class="small text-muted mb-3">La tâche n'a pas encore commencé. Vous devez la démarrer avant de pouvoir la terminer.</p>
                                <form method="post" action="{{ path('employee_tasks_start', {id: assignment.idAssignment}) }}" class="d-inline">
                                    <button class="btn btn-primary w-100 rounded-pill py-2">
                                        <i class="bi bi-play-fill me-1"></i> Commencer la tâche
                                    </button>
                                </form>
                            {% elseif task.statut == 'en_cours' %}
                                <p class="small text-muted mb-3">La tâche est actuellement en cours. Une fois terminée, vous devez soumettre un suivi pour validation.</p>
                                <a href="{{ path('suivi_tache_new', {id: task.idTask}) }}" class="btn btn-success w-100 rounded-pill py-2">
                                    <i class="bi bi-check2-circle me-1"></i> Terminer la tâche
                                </a>
                            {% elseif task.statut == 'a_valider' %}
                                <p class="small text-muted mb-0">
                                    <i class="bi bi-clock-history me-1"></i> En attente de validation par l'agriculteur.
                                </p>
                            {% elseif task.statut == 'termine' %}
                                <p class="small text-muted mb-0">
                                    <i class="bi bi-check-all me-1"></i> Tâche clôturée avec succès.
                                </p>
                            {% else %}
                                <p class="small text-muted mb-0">Aucune action immédiate requise.</p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
