{% extends 'base.html.twig' %}

{% block title %}Inscription - AgriSmart{% endblock %}

{% block body %}
<main class="vh-100 d-flex align-items-center">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-10 col-xl-9">
                <div class="bg-mode shadow rounded-3 overflow-hidden">
                    <div class="row g-0">

                        <!-- Illustration -->
                        <div class="col-lg-6 d-none d-lg-flex align-items-center">
                            <div class="p-5">
                                <img src="{{ asset('assets/images/element/signin.svg') }}" class="img-fluid">
                            </div>
                            <div class="vr opacity-1 d-none d-lg-block"></div>
                        </div>

                        <!-- Form -->
                        <div class="col-lg-6">
                            <div class="p-4 p-lg-5">

                                {% for message in app.flashes('success') %}
                                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                                        {{ message }}
                                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                    </div>
                                {% endfor %}

                                {{ form_start(registrationForm, {
                                    'attr': {
                                        'class': 'mt-4 text-start',
                                        'enctype': 'multipart/form-data',
                                        'novalidate': 'novalidate'
                                    }
                                }) }}

                                <!-- STEP 1 -->
                                <div id="step1">

                                    <h4 class="mb-4">Informations personnelles</h4>

                                    {{ form_row(registrationForm.firstName) }}
                                    {{ form_row(registrationForm.lastName) }}
                                    {{ form_row(registrationForm.email) }}
                                    {{ form_row(registrationForm.role) }}

                                    <div class="position-relative mb-3">
                                        {{ form_row(registrationForm.plainPassword.first, {
                                            'attr': {'id': 'psw-input', 'class': 'form-control'}
                                        }) }}
                                        <span class="position-absolute top-50 end-0 translate-middle-y pe-3">
                                            <i class="fakepasswordicon fas fa-eye-slash cursor-pointer"></i>
                                        </span>
                                    </div>

                                    {{ form_row(registrationForm.plainPassword.second) }}

                                    <button type="button" class="btn btn-primary w-100" onclick="nextStep()">
                                        Suivant
                                    </button>

                                </div>

                                <!-- STEP 2 -->
                                <div id="step2" style="display:none;">

                                    <h4 class="mb-4">Informations complémentaires</h4>

                                    {{ form_row(registrationForm.phone) }}
                                    {{ form_row(registrationForm.address) }}

                                    <div class="mb-3">
                                        {{ form_row(registrationForm.imageFile, {
                                            'label': 'Photo de profil',
                                            'attr': {'accept': '.jpg,.jpeg,.png'}
                                        }) }}
                                        <small class="text-muted">JPG ou PNG – max 5MB</small>
                                    </div>

                                    <div class="mb-3">
                                        {{ form_row(registrationForm.documentFileFile, {
                                            'label': 'Document justificatif',
                                            'attr': {'accept': '.pdf,.jpg,.jpeg,.png'}
                                        }) }}
                                        <small class="text-muted">PDF, JPG, PNG – max 5MB</small>
                                    </div>

                                    <button type="button" class="btn btn-outline-secondary w-100 mb-2" onclick="prevStep()">
                                        Retour
                                    </button>

                                    <button type="submit" class="btn btn-success w-100">
                                        Créer mon compte
                                    </button>

                                </div>

                                {{ form_end(registrationForm) }}

                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
function nextStep() {
    document.getElementById('step1').style.display = 'none';
    document.getElementById('step2').style.display = 'block';
}
function prevStep() {
    document.getElementById('step1').style.display = 'block';
    document.getElementById('step2').style.display = 'none';
}
document.addEventListener('click', function(e) {
    if (e.target.classList.contains('fakepasswordicon')) {
        let input = document.getElementById('psw-input');
        input.type = input.type === 'password' ? 'text' : 'password';
    }
});
</script>

{% endblock %}