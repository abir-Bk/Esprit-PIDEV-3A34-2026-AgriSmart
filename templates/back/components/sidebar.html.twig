        </a>
        <button class="ag-burger" type="button" data-bs-toggle="offcanvas" data-bs-target="#agSidebarCanvas" aria-label="Menu">
            <span></span><span></span><span></span>
        </button>
    </div>

    <!-- Offcanvas -->
    <div class="offcanvas-xl offcanvas-start ag-canvas" tabindex="-1" id="agSidebarCanvas" data-bs-backdrop="true">

        <div class="offcanvas-header d-xl-none ag-canvas__header">
            <a href="#" class="ag-brand">
                <img src="{{ asset('assets/images/logo.png') }}" alt="AgriSmart" style="height:28px;">
                <span class="ag-brand__name">Agri<em>Smart</em></span>
            </a>
            <button class="ag-close" type="button" data-bs-dismiss="offcanvas" data-bs-target="#agSidebarCanvas" aria-label="Close">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="ag-body">

            <!-- Logo desktop -->
            <div class="ag-logo d-none d-xl-flex">
                <a href="#" class="ag-brand">
                    <img src="{{ asset('assets/images/logo.png') }}" alt="AgriSmart" style="height:30px;">
                    <span class="ag-brand__name">Agri<em>Smart</em></span>
                </a>
            </div>

            <!-- User chip -->
            {% if app.user %}
            <div class="ag-user">
                <div class="ag-user__avatar">
                    {% if app.user.image %}
                        <img src="{{ asset('uploads/images/' ~ app.user.image) }}" alt="">
                    {% else %}
                        <i class="fa-solid fa-user"></i>
                    {% endif %}
                </div>
                <div class="ag-user__info">
                    <span class="ag-user__name">{{ app.user.firstName }}</span>
                    <span class="ag-user__role">{{ app.user.roles[0]|replace({'ROLE_': '', '_': ' '})|title }}</span>
                </div>
            </div>
            {% endif %}

            <!-- Nav -->
            <ul class="ag-nav">

                <li>
                    <a href="{{ is_granted('ROLE_ADMIN') ? path('admin_dashboard') : path('user_dashboard') }}"
                       class="ag-link {% if app.request.attributes.get('_route') in ['user_dashboard','admin_dashboard'] %}ag-link--active{% endif %}">
                        <span class="ag-link__icon"><i class="fa-solid fa-house"></i></span>
                        <span>Dashboard</span>
                    </a>
                </li>

                {% if is_granted('ROLE_ADMIN') %}
                <li>
                    <a href="{{ path('admin_users') }}"
                       class="ag-link {% if app.request.attributes.get('_route') == 'admin_users' %}ag-link--active{% endif %}">
                        <span class="ag-link__icon"><i class="fa-solid fa-users"></i></span>
                        <span>Utilisateurs</span>
                    </a>
                </li>
                {% endif %}

                <li>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_offre_admin_index') }}"
                           class="ag-link {% if app.request.attributes.get('_route') == 'app_offre_admin_index' %}ag-link--active{% endif %}">
                            <span class="ag-link__icon"><i class="fa-solid fa-briefcase"></i></span>
                            <span>Offres d'emploi</span>
                        </a>
                    {% else %}
                        <a href="{{ path('app_admin_offres') }}"
                           class="ag-link {% if app.request.attributes.get('_route') == 'app_admin_offres' %}ag-link--active{% endif %}">
                            <span class="ag-link__icon"><i class="fa-solid fa-briefcase"></i></span>
                            <span>Mes offres</span>
                        </a>
                    {% endif %}
                </li>

                {% if is_granted('ROLE_ADMIN') %}
                <li class="ag-section-label">Marketplace</li>

                <li>
                    <a href="{{ path('admin_marketplace_dashboard') }}"
                       class="ag-link {% if app.request.attributes.get('_route') == 'admin_marketplace_dashboard' %}ag-link--active{% endif %}">
                        <span class="ag-link__icon"><i class="fa-solid fa-chart-line"></i></span>
                        <span>Statistiques</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('admin_marketplace_commandes') }}"
                       class="ag-link {% if app.request.attributes.get('_route') == 'admin_marketplace_commandes' %}ag-link--active{% endif %}">
                        <span class="ag-link__icon"><i class="fa-solid fa-cart-shopping"></i></span>
                        <span>Commandes</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('admin_marketplace_produits') }}"
                       class="ag-link {% if app.request.attributes.get('_route') == 'admin_marketplace_produits' %}ag-link--active{% endif %}">
                        <span class="ag-link__icon"><i class="fa-solid fa-box"></i></span>
                        <span>Catalogue produits</span>
                    </a>
                </li>

                <!-- Section TÂCHES -->
                <li class="nav-item mt-4 mb-2">
                    <span class="sidebar-heading text-uppercase text-muted small fw-semibold px-3">Tâches</span>
