<!DOCTYPE html>
<html lang="en">
<head>
    <title>Ajouter une Offre - AgriSmart</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Poppins:wght@400;500;700&display=swap">
    <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/bootstrap-icons/bootstrap-icons.css') }}">
    <link rel="stylesheet" type="text/css" href="{{ asset('assets/css/style.css') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>

<body class="bg-light">
<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            
            {# 1. Added Flash Messages Block #}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }} alert-dismissible fade show shadow-sm mb-4" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            <div class="card shadow border-0">
                
                {# Green Header for New Offre #}
                <div class="card-header bg-success text-white py-3">
                    <h4 class="mb-0 text-center">Nouvelle Offre d'Emploi</h4>
                </div>

                <div class="card-body p-4">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                        
                        <div class="mb-3">{{ form_row(form.title) }}</div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">{{ form_row(form.typePoste) }}</div>
                            <div class="col-md-6">{{ form_row(form.typeContrat) }}</div>
                        </div>

                        <div class="mb-4">{{ form_row(form.description) }}</div>

                        <hr class="text-muted">
                        <h6 class="text-uppercase small fw-bold mb-3 text-secondary">Détails Logistiques</h6>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">{{ form_row(form.lieu) }}</div>
                            <div class="col-md-6">{{ form_row(form.salaire) }}</div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-4">{{ form_row(form.statut) }}</div>
                            <div class="col-md-4">{{ form_row(form.dateDebut) }}</div>
                            <div class="col-md-4">{{ form_row(form.dateFin) }}</div>
                        </div>

                        <div class="d-grid gap-2 mt-5">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm">Publier l'offre</button>
                            
                            {# 2. Corrected path to point to your list index instead of the form itself #}
                            <a href="{{ path('app_admin_offres') }}" class="btn btn-link text-muted text-decoration-none text-center">Annuler</a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

{# 3. Added Bootstrap JS for Alert dismissals #}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>