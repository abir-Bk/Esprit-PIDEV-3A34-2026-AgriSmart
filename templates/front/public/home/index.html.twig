{% block javascripts %}
	{{ parent() }}
	<script src="{{ asset('assets/vendor/tiny-slider/tiny-slider.js') }}"></script>
	<script>
		document.addEventListener('DOMContentLoaded', function() {
			if (typeof tns !== 'undefined') {
				var hero = document.querySelector('#heroSlider .tiny-slider-inner');
				if (hero) tns({ container: hero, items: 1, slideBy: 1, autoplay: true, autoplayTimeout: 5000, autoplayButtonOutput: false, arrowKeys: true, controls: true, nav: false, mouseDrag: true });
				var solutions = document.querySelector('#solutionsSlider .tiny-slider-inner');
				if (solutions) tns({ container: solutions, items: 3, slideBy: 1, autoplay: true, autoplayTimeout: 4000, autoplayButtonOutput: false, arrowKeys: true, controls: true, nav: false, mouseDrag: true, responsive: { 320: { items: 1 }, 576: { items: 2 }, 992: { items: 3 } } });
			}
		});
	</script>
{% endblock %}
