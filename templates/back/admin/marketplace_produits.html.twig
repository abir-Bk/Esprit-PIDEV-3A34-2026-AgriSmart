{% extends 'back/admin_base.html.twig' %}

{% block title %}Catalogue produits - Marketplace Admin - AgriSmart{% endblock %}

{% block body %}
<div class="d-flex">
    {% include 'back/components/sidebar.html.twig' %}
    <div class="flex-grow-1 ag-admin-content">
        <div class="container-fluid px-4">

            <section class="py-4 pb-2">
                <h1 class="h2 fw-bold mb-1" style="color: var(--ag-text);">Catalogue produits</h1>
                <p class="text-muted mb-0">Gérer et modérer les annonces du marketplace.</p>
            </section>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fa-solid fa-check-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}

            <div class="ag-admin-card p-4">
                <p class="ag-meta mb-3"><strong>{{ produits|length }}</strong> résultat(s)</p>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 60px;">Image</th>
                                <th>Nom</th>
                                <th>Prix</th>
                                <th>Type</th>
                                <th>Vendeur</th>
                                <th>Statut</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for p in produits %}
                                <tr class="{{ p.banned ? 'table-secondary' : '' }}">
                                    <td>
                                        {% if p.image %}
                                            <img src="{{ asset(p.image) }}" alt="{{ p.nom }}" class="rounded" style="width: 48px; height: 48px; object-fit: cover;">
                                        {% else %}
                                            <div class="rounded bg-light d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;"><i class="fa-solid fa-image text-muted"></i></div>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <span class="fw-medium" style="color: var(--ag-text);">{{ p.nom }}</span>
                                    </td>
                                    <td>{{ p.prix|number_format(2, ',', ' ') }} TND</td>
                                    <td><span class="badge {{ p.type == 'vente' ? 'bg-success' : 'bg-info' }}">{{ p.type }}</span></td>
                                    <td>
                                        {% if p.vendeur %}
                                            {{ p.vendeur.firstName }} {{ p.vendeur.lastName }}
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if p.banned %}
                                            <span class="badge bg-danger">Banni</span>
                                        {% else %}
                                            <span class="badge bg-success">Actif</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        <form method="post" action="{{ path('admin_marketplace_produit_ban', { id: p.id }) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('produit_ban_' ~ p.id) }}">
                                            {% if p.banned %}
                                                <button type="submit" class="btn btn-sm btn-outline-success">Débannir</button>
                                            {% else %}
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Bannir</button>
                                            {% endif %}
                                        </form>
                                    </td>
                                </tr>
                            {% else %}
                                <tr><td colspan="7" class="text-center text-muted py-4">Aucun produit.</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
