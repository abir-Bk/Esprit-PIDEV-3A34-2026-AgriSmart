{% extends 'front/task/layout.html.twig' %}

{% block title %}Détail de l'affectation - AgriSmart {% endblock %}

{% block task_content %}
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Détails de l'affectation</h5>
            <div>
                <a href="{{ path('task_assignments_edit', {id: assignment.idAssignment}) }}" class="btn btn-sm btn-primary">Modifier</a>
                <a href="{{ path('task_assignments_index') }}" class="btn btn-sm btn-outline-secondary">Retour à la liste</a>
            </div>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">ID</dt>
                <dd class="col-sm-9">{{ assignment.idAssignment }}</dd>

                <dt class="col-sm-3">Tâche</dt>
                <dd class="col-sm-9">{{ assignment.task ? assignment.task.titre : '' }}</dd>

                <dt class="col-sm-3">Ouvrier (ID)</dt>
                <dd class="col-sm-9">{{ assignment.workerId }}</dd>

                <dt class="col-sm-3">Date d'affectation</dt>
                <dd class="col-sm-9">{{ assignment.dateAssignment ? assignment.dateAssignment|date('d/m/Y H:i') : '' }}</dd>

                <dt class="col-sm-3">Statut</dt>
                <dd class="col-sm-9">{{ assignment.statut }}</dd>
            </dl>
        </div>
    </div>

    <form method="post" action="{{ path('task_assignments_delete', {id: assignment.idAssignment}) }}" onsubmit="return confirm('Supprimer cette affectation ?');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ assignment.idAssignment) }}">
        <button class="btn btn-danger">Supprimer</button>
    </form>
{% endblock %}

