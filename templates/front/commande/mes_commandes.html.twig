{% extends 'front/produit/base_dashboard.html.twig' %}

{% block title %}Mes Commandes - AgriSmart{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Mes commandes</h1>
        <p class="text-muted mb-0 small">Suivi de tes achats / locations.</p>
    </div>
</div>

<div class="card shadow-sm rounded-4 border-0">
    <div class="card-body">
        {% if commandes is empty %}
            <div class="text-center py-5">
                <i class="bi bi-bag display-5 text-muted"></i>
                <h5 class="mt-3">Aucune commande</h5>
                <p class="text-muted mb-0">Quand tu commandes un produit, il apparaîtra ici.</p>
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Produit</th>
                            <th>Total</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for c in commandes %}
                        <tr>
                            <td class="text-muted">#{{ c.id }}</td>
                            <td>
                                <div class="fw-bold">{{ c.produit.nom }}</div>
                                <div class="text-muted small">{{ c.produit.categorie }} • {{ c.produit.type }}</div>
                            </td>
                            <td class="fw-bold">{{ c.montantTotal }} TND</td>
                            <td>
                                {% set st = c.statut ?? 'en_attente' %}
                                {% if st == 'payee' %}
                                    <span class="badge bg-success">Payée</span>
                                {% elseif st == 'annulee' %}
                                    <span class="badge bg-danger">Annulée</span>
                                {% else %}
                                    <span class="badge bg-warning text-dark">En attente</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
