{% extends 'back/admin_base.html.twig' %}

{% block title %}Détails Offre - {{ offre.title }}{% endblock %}

{% block body %}
<div class="container-fluid px-4 mt-4">
    {# Bouton Retour #}
    <div class="mb-4">
        <a href="{{ path('app_admin_offres') }}" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour à la liste
        </a>
    </div>

    <div class="row g-4">
        {# Colonne GAUCHE : Détails de l'Offre #}
        <div class="col-lg-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Détails de l'Offre</h5>
                </div>
                <div class="card-body">
                    <h4 class="text-primary fw-bold">{{ offre.title }}</h4>
                    <p class="text-muted mb-4"><i class="bi bi-geo-alt me-1"></i> {{ offre.lieu }}</p>
                    
                    <ul class="list-group list-group-flush mb-4">
                        <li class="list-group-item d-flex justify-content-between px-0">
                            <span class="text-secondary">Type contrat:</span> <strong>{{ offre.typeContrat }}</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between px-0">
                            <span class="text-secondary">Salaire:</span> <strong>{{ offre.salaire }} DT</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between px-0">
                            <span class="text-secondary">Statut:</span> 
                            <span class="badge {{ offre.statut|lower == 'ouvert' ? 'bg-success' : 'bg-danger' }}">
                                {{ offre.statut|upper }}
                            </span>
                        </li>
                    </ul>

                    <div class="bg-light p-3 rounded">
                        <h6 class="fw-bold small text-uppercase">Description du poste :</h6>
                        <p class="small text-dark mb-0">{{ offre.description|nl2br }}</p>
                    </div>
                </div>
            </div>
        </div>

        {# Colonne DROITE : Tableau des Candidatures #}
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-dark">Candidatures Reçues <span class="badge bg-secondary ms-2">{{ demandes|length }}</span></h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Candidat</th>
                                    <th>Date</th>
                                    <th>Statut</th>
                                    <th class="text-end pe-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for demande in demandes %}
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="avatar bg-light rounded-circle p-2 me-3 border">
                                                    <i class="bi bi-person text-primary"></i>
                                                </div>
                                                <div>
                                                    <div class="fw-bold text-dark">{{ demande.nom }} {{ demande.prenom }}</div>
                                                    <small class="text-muted"><i class="bi bi-telephone me-1"></i>{{ demande.phoneNumber }}</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="small">{{ demande.datePostulation|date('d/m/Y') }}</td>
                                        <td>
                                            {% set d_status = demande.statut|lower %}
                                            <span class="badge rounded-pill {% if d_status == 'acceptée' %}bg-success{% elseif d_status == 'refusée' %}bg-danger{% else %}bg-warning text-dark{% endif %}">
                                                {{ demande.statut }}
                                            </span>
                                        </td>
                                        <td class="text-end pe-4">
                                            <a href="{{ path('app_admin_demande_details', {'id': demande.id}) }}" class="btn btn-sm btn-info text-white shadow-sm" title="Gérer la candidature">
                                                <i class="bi bi-eye-fill me-1"></i> Voir
                                            </a>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="4" class="text-center py-5">
                                            <div class="text-muted">
                                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                                Aucune candidature reçue pour le moment.
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}