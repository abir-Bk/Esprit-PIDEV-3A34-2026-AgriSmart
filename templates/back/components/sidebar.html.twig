                </li>
                {% endif %}

            </ul>

            <!-- Footer -->
            <div class="ag-footer">
                <a href="{{ path('app_logout') }}" class="ag-footer__link">
                    <i class="fa-solid fa-arrow-right-from-bracket"></i>
                    <span>Déconnexion</span>
                </a>
                <a href="#" class="ag-footer__icon" title="Paramètres">
                    <i class="fa-solid fa-gear"></i>
                </a>
            </div>

        </div>
    </div>
</nav>
<!-- Sidebar END -->

<style>
/* ── CSS Variables — adapts to light & dark browser themes ── */
:root {
    --ag-bg:        #ffffff;
    --ag-border:    #e8eceb;
    --ag-text:      #374151;
    --ag-muted:     #9ca3af;
    --ag-accent:    #1a4331;
    --ag-accent-lt: #eaf3ee;
    --ag-active-tx: #1a4331;
    --ag-hover-bg:  #f4f8f5;
    --ag-user-bg:   #f4f8f5;
    --ag-width:     260px;
    --ag-radius:    10px;
    --ag-transition: 0.18s ease;
}

@media (prefers-color-scheme: dark) {
    :root {
        --ag-bg:        #111827;
        --ag-border:    #1f2d24;
        --ag-text:      #d1d5db;
        --ag-muted:     #6b7280;
        --ag-accent:    #34d399;
        --ag-accent-lt: #052e1a;
        --ag-active-tx: #34d399;
        --ag-hover-bg:  #1a2e22;
        --ag-user-bg:   #1a2e22;
    }
}

/* ── Sidebar shell ── */
.ag-sidebar {
    position: fixed;
    top: 0; left: 0;
    width: var(--ag-width);
    height: 100vh;
    background: var(--ag-bg);
    border-right: 1px solid var(--ag-border);
    z-index: 1040;
    display: flex;
    flex-direction: column;
}

/* ── Canvas (offcanvas) ── */
.ag-canvas {
    width: var(--ag-width) !important;
    background: var(--ag-bg) !important;
    border-right: 1px solid var(--ag-border) !important;
}

.ag-canvas__header {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--ag-border);
}

/* ── Body ── */
.ag-body {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--ag-border) transparent;
}
.ag-body::-webkit-scrollbar { width: 4px; }
.ag-body::-webkit-scrollbar-thumb { background: var(--ag-border); border-radius: 4px; }

/* ── Logo ── */
.ag-logo {
    padding: 1.125rem 1.25rem;
    border-bottom: 1px solid var(--ag-border);
    flex-shrink: 0;
}

.ag-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
}

.ag-brand__name {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ag-accent);
    letter-spacing: -0.01em;
}

.ag-brand__name em {
    font-style: normal;
    color: var(--ag-muted);
    font-weight: 500;
}

/* ── User chip ── */
.ag-user {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 1rem 1rem 0.5rem;
    padding: 0.75rem;
    background: var(--ag-user-bg);
    border-radius: var(--ag-radius);
}

.ag-user__avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: var(--ag-border);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
    color: var(--ag-muted);
    font-size: 0.9rem;
}

.ag-user__avatar img { width: 100%; height: 100%; object-fit: cover; }

.ag-user__name {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ag-text);
    line-height: 1.2;
}

.ag-user__role {
    display: block;
    font-size: 0.72rem;
    color: var(--ag-muted);
}

/* ── Nav ── */
.ag-nav {
    list-style: none;
    padding: 0.75rem 0.75rem;
    margin: 0;
    flex: 1;
}

.ag-section-label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ag-muted);
    padding: 1rem 0.75rem 0.4rem;
}

.ag-link {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.6rem 0.75rem;
    border-radius: var(--ag-radius);
    color: var(--ag-text);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: background var(--ag-transition), color var(--ag-transition);
    margin-bottom: 2px;
}

.ag-link:hover {
    background: var(--ag-hover-bg);
    color: var(--ag-accent);
}

.ag-link--active {
    background: var(--ag-accent-lt);
    color: var(--ag-active-tx);
    font-weight: 600;
}

.ag-link__icon {
    width: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    opacity: 0.7;
    flex-shrink: 0;
}

.ag-link:hover .ag-link__icon,
.ag-link--active .ag-link__icon {
    opacity: 1;
}

/* ── Footer ── */
.ag-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 1.25rem;
    border-top: 1px solid var(--ag-border);
    flex-shrink: 0;
}

.ag-footer__link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--ag-muted);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    transition: color var(--ag-transition);
}

.ag-footer__link:hover { color: var(--ag-text); }

.ag-footer__icon {
    color: var(--ag-muted);
    font-size: 0.95rem;
    text-decoration: none;
    transition: color var(--ag-transition);
}

.ag-footer__icon:hover { color: var(--ag-text); }

/* ── Mobile topbar ── */
.ag-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    width: 100%;
}

.ag-burger {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
}

.ag-burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ag-text);
    border-radius: 2px;
    transition: all 0.2s;
}

.ag-close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--ag-muted);
    font-size: 1.1rem;
    padding: 4px;
    transition: color var(--ag-transition);
}

.ag-close:hover { color: var(--ag-text); }

/* ── Responsive ── */
@media (min-width: 1200px) {
    body { padding-left: var(--ag-width); }
    .ag-body { height: 100vh; }
}

@media (max-width: 1199px) {
    .ag-sidebar { position: static; width: 100%; height: auto; border-right: none; border-bottom: 1px solid var(--ag-border); }
}

@media print {
    .ag-sidebar { display: none; }
    body { padding-left: 0 !important; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
    // Bootstrap tooltips
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => new bootstrap.Tooltip(el));

    // Close mobile offcanvas on nav link click
    document.querySelectorAll('.ag-link').forEach(link => {
        link.addEventListener('click', () => {
            const canvas = bootstrap.Offcanvas.getInstance(document.getElementById('agSidebarCanvas'));
            if (canvas && window.innerWidth < 1200) canvas.hide();
        });
    });
});
</script>
