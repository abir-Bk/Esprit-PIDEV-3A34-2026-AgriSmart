{% extends 'back/admin_base.html.twig' %}

{% block title %}Détails Candidature - {{ demande.nom }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Intégration du style AgriSmart dans l'interface Admin */
        .agri-card {
            border: 1px solid #e0eadd;
            border-left: 5px solid #1e5631;
            background-color: #ffffff;
            border-radius: 8px;
        }
        .section-title-agri {
            color: #1e5631;
            font-size: 14px;
            font-weight: bold;
            text-transform: uppercase;
            margin-bottom: 15px;
            border-left: 3px solid #a4c639;
            padding-left: 10px;
        }
        .brand-text { color: #1e5631; font-weight: bold; letter-spacing: -1px; }
        .dot { color: #a4c639; }
        .badge-agri { padding: 8px 15px; border-radius: 5px; font-weight: bold; }
    </style>
{% endblock %}

{% block body %}
<div class="container mt-5">
    {# Header Style AgriSmart #}
    <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 agri-card shadow-sm">
        <div>
            <h1 class="brand-text m-0">AGRISMART<span class="dot">.</span></h1>
        </div>
        <a href="{{ path('app_admin_offre_details', {'id': demande.offre.id}) }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour à l'offre
        </a>
    </div>

    <div class="row g-4">
        {# Colonne Gauche : Profil & Statut #}
        <div class="col-md-5">
            <div class="card shadow-sm border-0 p-4 agri-card">
                <div class="section-title-agri">Informations Candidat</div>
                
                <div class="text-center">
                    <div class="bg-light rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; border: 2px solid #a4c639;">
                        <i class="bi bi-person-fill fs-1" style="color: #1e5631;"></i>
                    </div>
                    <h3 class="mb-1">{{ demande.nom|upper }} {{ demande.prenom }}</h3>
                    <p class="text-muted mb-3"><i class="bi bi-telephone"></i> {{ demande.phoneNumber }}</p>
                    
                    {% if demande.statut == 'Acceptée' %}
                        <span class="badge bg-success badge-agri text-white">DOSSIER ACCEPTÉ</span>
                    {% elseif demande.statut == 'Refusée' %}
                        <span class="badge bg-danger badge-agri text-white">DOSSIER REFUSÉ</span>
                    {% else %}
                        <span class="badge bg-warning badge-agri text-dark">EN COURS D'EXAMEN</span>
                    {% endif %}
                </div>

                <hr class="my-4">

                <div class="mt-3">
                    <label class="form-label fw-bold text-success">Décision Administrative :</label>
                    <form action="{{ path('app_admin_demande_update_status', {'id': demande.id}) }}" method="POST">
                        <div class="input-group">
                            <select name="statut" class="form-select border-success">
                                <option value="En cours" {{ demande.statut == 'En cours' ? 'selected' : '' }}>⏳ Maintien en cours</option>
                                <option value="Acceptée" {{ demande.statut == 'Acceptée' ? 'selected' : '' }}>✅ Accepter le candidat</option>
                                <option value="Refusée" {{ demande.statut == 'Refusée' ? 'selected' : '' }}>❌ Refuser le candidat</option>
                            </select>
                            <button type="submit" class="btn btn-dark">Valider</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        {# Colonne Droite : Offre & Documents #}
        <div class="col-md-7">
            {# Détails de l'offre #}
            <div class="card shadow-sm border-0 p-4 mb-4 agri-card">
                <div class="section-title-agri">Détails du Poste</div>
                <table class="table table-sm table-borderless mt-2">
                    <tr>
                        <td class="fw-bold" style="width: 30%;">Intitulé :</td>
                        <td class="text-primary fw-bold">{{ demande.offre.title }}</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Lieu :</td>
                        <td>📍 {{ demande.offre.lieu }}</td>
                    </tr>
                </table>
            </div>

            {# Documents PDF #}
            <div class="card shadow-sm border-0 p-4 agri-card">
                <div class="section-title-agri">Pièces Justificatives</div>
                
                <div class="list-group mt-2">
                    {# CV #}
                    <div class="list-group-item d-flex align-items-center justify-content-between border-0 bg-light mb-2 rounded">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-file-earmark-pdf-fill text-danger fs-2 me-3"></i>
                            <div>
                                <h6 class="mb-0">Curriculum Vitae</h6>
                                <small class="text-muted">Format PDF sécurisé</small>
                            </div>
                        </div>
                        <a href="{{ asset('uploads/cv/' ~ demande.cv) }}" target="_blank" class="btn btn-sm btn-success">
                            <i class="bi bi-eye"></i> Consulter
                        </a>
                    </div>

                    {# Lettre de motivation #}
                    <div class="list-group-item d-flex align-items-center justify-content-between border-0 bg-light rounded">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-file-earmark-text-fill text-primary fs-2 me-3"></i>
                            <div>
                                <h6 class="mb-0">Lettre de Motivation</h6>
                                <small class="text-muted">Format PDF/Texte</small>
                            </div>
                        </div>
                        <a href="{{ asset('uploads/lettres/' ~ demande.lettreMotivation) }}" target="_blank" class="btn btn-sm btn-success">
                            <i class="bi bi-eye"></i> Consulter
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}