{% extends 'front/offre/layout.html.twig' %}

{% block title %}Offres d'emploi | AgriSmart{% endblock %}

{% block candidature_content %}
<section class="ag-hero">
  <div class="container">
    <div class="row align-items-center g-4">
      <div class="col-12">
        <h1 class="ag-title">Offres d'emploi</h1>
        <p class="ag-subtitle">
          Consultez les <strong>offres d'emploi agricole</strong> et postulez en quelques clics.
        </p>
      </div>
    </div>
  </div>
</section>

<section class="ag-content mt-0">
  <div class="container">
    <div class="row mb-4">
      <div class="col-12">
      <div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm p-4 text-white" style="background: linear-gradient(90deg, #126d46 0%, #17884a 100%); border-radius: 15px;">
            <div class="d-flex flex-column flex-md-row align-items-center justify-content-between">
                <div>
                    <h4 class="fw-bold mb-1"><i class="bi bi-cpu-fill me-2"></i>Entraînement Vocal IA</h4>
                    <p class="mb-0 opacity-75">Améliorez votre score en pratiquant un entretien réel.</p>
                </div>
                <button class="btn btn-light rounded-pill px-4 fw-bold text-success mt-3 mt-md-0 shadow-sm" data-bs-toggle="modal" data-bs-target="#interviewModal">
                    <i class="bi bi-mic-fill me-2"></i>Lancer le test
                </button>
            </div>
        </div>
    </div>
</div>
        <div class="card ag-filter-card shadow-sm p-4">
          <form method="get" action="{{ path('app_offre_index_front') }}" class="row g-3 align-items-end" id="formOffres">
            <div class="col-md-5">
              <label class="form-label fw-bold small text-uppercase" style="color: var(--ag-muted);">Recherche</label>
              <input type="text" id="searchInput" name="search" class="form-control ag-input" placeholder="Titre, lieu..." value="{{ app.request.query.get('search') }}">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-bold small text-uppercase" style="color: var(--ag-muted);">Statut</label>
              <select id="statusFilter" name="status" class="form-select ag-input">
                <option value="">Toutes les offres</option>
                <option value="ouvert" {{ app.request.query.get('status') == 'ouvert' ? 'selected' : '' }}>Offres ouvertes</option>
                <option value="clôturée" {{ app.request.query.get('status') == 'clôturée' ? 'selected' : '' }}>Offres clôturées</option>
              </select>
            </div>
            <div class="col-md-3">
              <button type="submit" class="btn ag-btn-primary text-white rounded-pill w-100">
                <i class="bi bi-search me-1"></i>Rechercher
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    {% set ouvertCount = 0 %}
    {% for o in offres %}
      {% if o.statut is defined and o.statut|lower == 'ouvert' %}{% set ouvertCount = ouvertCount + 1 %}{% endif %}
    {% endfor %}
    <p class="ag-meta mb-3">
      <strong>{{ offres|length }}</strong> offre(s) · <strong>{{ ouvertCount }}</strong> ouverte(s)
    </p>

    <div class="row g-4" id="offresGrid">
      {% for offre in offres %}
        {% set totalCand = offre.demandes|length %}
        <div class="col-sm-6 col-xl-4 offre-item"
             data-statut="{{ offre.statut|lower }}"
             data-titre="{{ offre.title|lower }}"
             data-lieu="{{ offre.lieu|lower }}">
          <div class="ag-card">
            <div class="p-4">
              <div class="d-flex justify-content-between align-items-start mb-3">
                <span class="badge rounded-pill {{ offre.statut|lower == 'ouvert' ? 'bg-success' : 'bg-secondary' }}">
                  {{ offre.statut }}
                </span>
                <div class="text-end">
                  <div class="fw-bold" style="color: var(--ag-primary);">
                    {{ offre.salaire ? offre.salaire|number_format(0, ',', ' ') ~ ' TND' : 'À négocier' }}
                  </div>
                  <small class="text-muted">mensuel</small>
                </div>
              </div>
              <h3 class="h6 fw-bold mb-2" style="color: var(--ag-text);">{{ offre.title }}</h3>
              <p class="small mb-3 ag-meta">
                <i class="bi bi-geo-alt me-1"></i>{{ offre.lieu }}
              </p>
              <div class="row g-2 small mb-3">
                <div class="col-6">
                  <span class="ag-meta d-block">Début</span>
                  <span style="color: var(--ag-text);">{{ offre.dateDebut ? offre.dateDebut|date('d/m/Y') : '—' }}</span>
                </div>
                <div class="col-6">
                  <span class="ag-meta d-block">Fin</span>
                  <span style="color: var(--ag-text);">{{ offre.dateFin ? offre.dateFin|date('d/m/Y') : '—' }}</span>
                </div>
              </div>
              <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                <span class="small ag-meta">
                  <i class="bi bi-people me-1"></i>{{ totalCand }} candidature(s)
                </span>
                <a href="{{ path('app_offre_show', {'id': offre.id}) }}" class="btn btn-sm ag-btn-primary text-white rounded-pill">
                  <i class="bi bi-eye me-1"></i>Voir
                </a>
              </div>
            </div>
          </div>
        </div>
      {% else %}
        <div class="col-12">
          <div class="text-center py-5 ag-card p-5">
            <i class="bi bi-briefcase display-5 ag-meta"></i>
            <h4 class="mt-3" style="color: var(--ag-text);">Aucune offre d'emploi</h4>
            <p class="ag-meta mb-4">Aucune offre disponible pour le moment.</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
<div class="modal fade" id="interviewModal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" onclick="stopInterview()"></button>
            </div>
            <div class="modal-body p-5 text-center">
                <div id="ai-avatar-box" class="mb-3 mx-auto" style="width: 80px; height: 80px; background: #f0fdf4; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 3px solid #28a745;">
                    <i class="bi bi-robot fs-2 text-success"></i>
                </div>                
                <h4 id="ai-question-text" class="fw-bold text-dark">Simulateur d'Entretien</h4>
                <p id="ai-status" class="text-muted small mb-4">Entraînement général pour tous les métiers agricoles.</p>
                
                <div id="ai-result-area" class="d-none mt-3 p-4 bg-light rounded-4 text-start border shadow-sm">
                    <div class="text-center mb-3">
                        <h2 class="fw-bold" id="final-score">0%</h2>
                    </div>
                    <div class="small">
                        <div class="mb-3">
                            <h6 class="fw-bold text-success small text-uppercase">Points Forts</h6>
                            <div id="final-pos" class="ps-3 border-start border-success text-dark"></div>
                        </div>
                        <div>
                            <h6 class="fw-bold text-danger small text-uppercase">Conseils d'amélioration</h6>
                            <div id="final-neg" class="ps-3 border-start border-danger text-dark"></div>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <button id="start-btn-ia" class="btn btn-success btn-lg rounded-pill px-5 shadow" onclick="runInterviewStep()">Lancer l'entraînement</button>
                    <div id="ai-wave" class="d-none text-danger fw-bold">
                         <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                         IA en écoute...
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{# --- CHATBOT SECTION --- #}
<style>
  .ag-chat-bubble {
    position: fixed; bottom: 30px; right: 30px; width: 60px; height: 60px;
    background: #28a745; border-radius: 50%; display: flex;
    align-items: center; justify-content: center; box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    cursor: pointer; z-index: 9999; transition: transform 0.2s ease;
  }
  .ag-chat-box {
    position: fixed; bottom: 100px; right: 30px; width: 320px; height: 450px;
    background: white; border-radius: 15px; box-shadow: 0 8px 25px rgba(0,0,0,0.2);
    display: none; flex-direction: column; overflow: hidden; z-index: 9999;
  }
  .ag-chat-box.active { display: flex; }
  .chat-header { background: #28a745; color: white; padding: 12px 15px; display: flex; justify-content: space-between; align-items: center; }
  #chat-messages { flex: 1; padding: 15px; overflow-y: auto; background: #f9f9f9; display: flex; flex-direction: column; gap: 10px; }
  
  .msg { 
    max-width: 85%; padding: 10px 14px; border-radius: 12px; font-size: 13.5px; line-height: 1.5; 
    white-space: pre-wrap; 
    word-wrap: break-word;
  }
  .ai-msg { background: white; border: 1px solid #eee; align-self: flex-start; color: #333; }
  .ai-msg strong { color: #155724; font-weight: bold; }
  .user-msg { background: #28a745; color: white; align-self: flex-end; }
  
  /* Style pour le fichier sélectionné */
  .file-badge { font-size: 11px; background: #e9ecef; padding: 2px 8px; border-radius: 10px; display: none; margin-bottom: 5px; }
</style>

<div class="ag-chat-bubble" id="chatBubble">
  <i class="bi bi-robot text-white" style="font-size: 28px;"></i>
</div>

<div class="ag-chat-box" id="chatBox">
  <div class="chat-header">
    <span class="small fw-bold"><i class="bi bi-stars me-1"></i>Assistant AgriSmart</span>
    <i class="bi bi-x-lg" id="closeChat" style="cursor:pointer"></i>
  </div>
  <div id="chat-messages">
    <div class="msg ai-msg">Bonjour ! 🌱 Je peux analyser votre **CV** pour vous aider à postuler. Cliquez sur le trombone pour m'envoyer votre fichier !</div>
  </div>
  <div class="p-2 border-top">
    <div id="fileInfo" class="file-badge text-truncate"></div>
    <div class="input-group input-group-sm">
      <label class="btn btn-light border" for="cvUpload" title="Joindre un CV (PDF ou Texte)">
        <i class="bi bi-paperclip"></i>
      </label>
      <input type="file" id="cvUpload" hidden accept=".pdf,.txt">
      
      <input type="text" id="chatInput" class="form-control border-0 bg-light" placeholder="Posez votre question...">
      <button class="btn btn-success" id="sendBtn"><i class="bi bi-send"></i></button>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // --- FILTRAGE DES OFFRES (EXISTANT) ---
  var searchInput = document.getElementById('searchInput');
  var statusFilter = document.getElementById('statusFilter');
  var items = document.querySelectorAll('.offre-item');
  
  function filter() {
    var query = (searchInput.value || '').toLowerCase().trim();
    var status = (statusFilter ? statusFilter.value || '' : '').toLowerCase();
    items.forEach(function(item) {
      var matchSearch = !query || item.dataset.titre.includes(query) || item.dataset.lieu.includes(query);
      var matchStatus = !status || item.dataset.statut === status;
      item.style.display = (matchSearch && matchStatus) ? 'block' : 'none';
    });
  }
  if (searchInput) searchInput.addEventListener('input', filter);
  if (statusFilter) statusFilter.addEventListener('change', filter);

  // --- LOGIQUE DU CHATBOT ---
  const bubble = document.getElementById('chatBubble');
  const box = document.getElementById('chatBox');
  const close = document.getElementById('closeChat');
  const input = document.getElementById('chatInput');
  const send = document.getElementById('sendBtn');
  const messages = document.getElementById('chat-messages');
  const cvUpload = document.getElementById('cvUpload');
  const fileInfo = document.getElementById('fileInfo');

  let extractedCvText = ""; // Stockage du texte du CV

  bubble.onclick = () => { box.classList.toggle('active'); if(box.classList.contains('active')) input.focus(); };
  close.onclick = () => box.classList.remove('active');

  // Lecture du fichier lors de la sélection
  cvUpload.onchange = function(e) {
    const file = e.target.files[0];
    if (!file) return;

    fileInfo.style.display = "block";
    fileInfo.innerHTML = `<i class="bi bi-file-earmark-check me-1"></i>${file.name}`;

    const reader = new FileReader();
    reader.onload = function(event) {
        // Note: Pour les PDF complexes, l'extraction de texte brute via FileReader est limitée.
        // On récupère le texte si c'est un .txt, sinon on marque qu'un fichier est joint.
        extractedCvText = event.target.result.substring(0, 3000); // On limite la taille
        messages.innerHTML += `<div class="msg user-msg small">Fichier joint : ${file.name}</div>`;
        messages.scrollTop = messages.scrollHeight;
    };
    reader.readAsText(file);
  };

  async function handleChat() {
    const text = input.value.trim();
    if (!text && !extractedCvText) return;

    if (text) messages.innerHTML += `<div class="msg user-msg">${text}</div>`;
    input.value = '';
    messages.scrollTop = messages.scrollHeight;

    const loadingId = 'ai-load-' + Date.now();
    messages.innerHTML += `<div class="msg ai-msg" id="${loadingId}">...</div>`;
    messages.scrollTop = messages.scrollHeight;

    try {
      const response = await fetch('/assistant/offre/conseil', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
            message: text,
            cvContent: extractedCvText // On envoie le texte du CV au controller
        })
      });
      const data = await response.json();
      const loadingMsg = document.getElementById(loadingId);
      
      let cleanText = data.reply
        .replace(/[#\-]{3,}/g, '') 
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
      
      loadingMsg.innerHTML = ""; 
      let i = 0;
      const speed = 15;

      function typeWriter() {
        if (i < cleanText.length) {
          if (cleanText.charAt(i) === '<') {
            let tagEnd = cleanText.indexOf('>', i);
            loadingMsg.innerHTML += cleanText.substring(i, tagEnd + 1);
            i = tagEnd + 1;
          } else {
            loadingMsg.innerHTML += cleanText.charAt(i);
            i++;
          }
          messages.scrollTop = messages.scrollHeight;
          setTimeout(typeWriter, speed);
        }
      }
      typeWriter();

      // Réinitialiser le fichier après envoi si nécessaire
      // extractedCvText = ""; 
      // fileInfo.style.display = "none";

    } catch (e) {
      document.getElementById(loadingId).innerHTML = "Erreur de connexion...";
    }
  }

  send.onclick = handleChat;
  input.onkeypress = (e) => { if (e.key === 'Enter') handleChat(); };
});
</script>
<script>
// RÉSERVOIR DE QUESTIONS GÉNÉRALISTES
const pool = [
    "Quelles sont vos principales forces pour travailler dans le secteur agricole ?",
    "Comment gérez-vous le travail physique ou les horaires décalés ?",
    "Si vous avez un désaccord avec un collègue sur une tâche, comment réagissez-vous ?",
    "Quelle importance accordez-vous aux consignes de sécurité sur une exploitation ?",
    "Comment vous adaptez-vous si les conditions météo changent vos plans de travail ?",
    "Parlez-moi d'une machine ou d'un outil que vous maîtrisez bien.",
    "Que feriez-vous si vous remarquiez une anomalie ou un danger sur le terrain ?",
    "Qu'est-ce qui vous motive le plus dans les métiers de la terre ?",
    "Comment gérez-vous le stress lors des périodes de grosse activité ?",
    "Selon vous, qu'est-ce qu'un bon employé agricole aujourd'hui ?",
    "Avez-vous une préférence pour le travail en équipe ou en autonomie ?",
    "Comment entretenez-vous vos connaissances sur les nouvelles techniques agricoles ?"
];

let stepIA = 0;
let transcriptIA = "";
let selectedQuestions = [];

window.speak = function(text, callback) {
    window.speechSynthesis.cancel();
    const utter = new SpeechSynthesisUtterance(text);
    utter.lang = 'fr-FR';
    utter.onend = callback;
    window.speechSynthesis.speak(utter);
};

window.runInterviewStep = function() {
    if (stepIA === 0) {
        transcriptIA = "";
        
        // Introduction fixe
        selectedQuestions = ["Bonjour, je suis l'assistant AgriSmart. Ceci est un entretien de réflexion pour vous préparer à postuler sur notre plateforme. Pour commencer, présentez-vous et parlez-moi de votre parcours."];
        
        // NOMBRE ALÉATOIRE : L'IA choisit entre 4 et 7 questions supplémentaires
        let nbQuestions = Math.floor(Math.random() * (7 - 4 + 1)) + 4; 
        let shuffled = pool.sort(() => 0.5 - Math.random()).slice(0, nbQuestions);
        
        selectedQuestions.push(...shuffled);
        selectedQuestions.push("L'entretien touche à sa fin. Merci pour vos réponses, je lance l'analyse de votre performance.");
    }

    document.getElementById('start-btn-ia').classList.add('d-none');
    document.getElementById('ai-result-area').classList.add('d-none');

    if (stepIA < selectedQuestions.length - 1) {
        const currentQ = selectedQuestions[stepIA];
        document.getElementById('ai-question-text').innerText = currentQ;
        // Le compteur est supprimé ici
        speak(currentQ, () => { listenIA(); });
    } else {
        showFinalResult();
    }
};

function listenIA() {
    const SpeechRec = window.SpeechRecognition || window.webkitSpeechRecognition;
    const recIA = new SpeechRec();
    recIA.lang = 'fr-FR';
    recIA.onstart = () => {
        document.getElementById('ai-wave').classList.remove('d-none');
        document.getElementById('ai-status').innerText = "L'IA vous écoute...";
    };
    recIA.onresult = (e) => {
        transcriptIA += " " + e.results[0][0].transcript;
        document.getElementById('ai-wave').classList.add('d-none');
        stepIA++;
        setTimeout(window.runInterviewStep, 800);
    };
    recIA.onerror = () => {
        document.getElementById('ai-wave').classList.add('d-none');
        stepIA++;
        setTimeout(window.runInterviewStep, 500);
    };
    recIA.start();
}

function showFinalResult() {
    let finalScore = 0;
    const text = transcriptIA.toLowerCase();
    const p = []; const n = [];

    // Analyse basée sur le volume de réponse global
    if (text.length > 400) { finalScore += 55; p.push("Excellente argumentation, très riche."); }
    else if (text.length > 200) { finalScore += 35; p.push("Réponses bien développées."); }
    else { finalScore += 10; n.push("Réponses un peu trop courtes pour un entretien."); }

    // Mots-clés
    const keywords = ["sécurité", "équipe", "motivation", "terrain", "responsable", "organisation"];
    let found = keywords.filter(w => text.includes(w));
    finalScore += (found.length * 8);

    if (finalScore > 98) finalScore = 98;

    document.getElementById('ai-question-text').innerText = "Bilan de préparation";
    document.getElementById('ai-status').innerText = "Analyse terminée.";
    
    const scoreBox = document.getElementById('final-score');
    scoreBox.innerText = finalScore + "%";
    scoreBox.className = "fw-bold " + (finalScore < 50 ? "text-danger" : "text-success");
    
    document.getElementById('final-pos').innerHTML = p.join('<br>') || "Points positifs détectés.";
    document.getElementById('final-neg').innerHTML = n.join('<br>') || "Conseils pour la suite.";
    document.getElementById('ai-result-area').classList.remove('d-none');
    
    speak("Entraînement terminé. Votre score est de " + finalScore + " pourcent. Continuez ainsi !");
    stepIA = 0;
    document.getElementById('start-btn-ia').classList.remove('d-none');
    document.getElementById('start-btn-ia').innerText = "Relancer un test";
}

window.stopInterview = function() {
    window.speechSynthesis.cancel();
    stepIA = 0;
};
</script>
{% endblock %}