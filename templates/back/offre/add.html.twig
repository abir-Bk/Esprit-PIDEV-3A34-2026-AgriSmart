{% extends 'back/admin_base.html.twig' %}

{% block title %}Ajouter une Offre - AgriSmart{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-9"> {# J'ai élargi un peu pour plus de confort #}
            
            {# Flash Messages (Optionnel : souvent déjà inclus dans admin_base) #}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }} alert-dismissible fade show shadow-sm mb-4" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            <div class="card shadow border-0">
                <div class="card-header bg-success text-white py-3">
                    <h4 class="mb-0 text-center">Nouvelle Offre d'Emploi</h4>
                </div>

                <div class="card-body p-4">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                        
                        <div class="mb-3">
                            {{ form_row(form.title, {'label': 'Titre de l\'offre'}) }}
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">{{ form_row(form.typePoste) }}</div>
                            <div class="col-md-6">{{ form_row(form.typeContrat) }}</div>
                        </div>

                        <div class="mb-4">
                            {{ form_row(form.description) }}
                        </div>

                        <hr class="text-muted">
                        <h6 class="text-uppercase small fw-bold mb-3 text-secondary">Détails Logistiques</h6>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">{{ form_row(form.lieu) }}</div>
                            <div class="col-md-6">{{ form_row(form.salaire) }}</div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-4">{{ form_row(form.statut) }}</div>
                            <div class="col-md-4">{{ form_row(form.dateDebut) }}</div>
                            <div class="col-md-4">{{ form_row(form.dateFin) }}</div>
                        </div>

                        <div class="d-grid gap-2 mt-5">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm">
                                <i class="bi bi-check-circle me-2"></i>Publier l'offre
                            </button>
                            
                            <a href="{{ path('app_admin_offres') }}" class="btn btn-link text-muted text-decoration-none text-center">Annuler</a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}