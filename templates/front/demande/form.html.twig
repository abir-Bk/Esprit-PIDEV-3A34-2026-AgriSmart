// --- LOGIQUE DU SIMULATEUR D'ENTRETIEN ---
const testPool = [
    "Quelles sont vos principales forces pour travailler dans le secteur agricole ?",
    "Comment gérez-vous le travail physique ou les horaires décalés ?",
    "Si vous avez un désaccord avec un collègue, comment réagissez-vous ?",
    "Quelle importance accordez-vous aux consignes de sécurité ?",
    "Comment vous adaptez-vous si les conditions météo changent vos plans ?",
    "Parlez-moi d'une machine ou d'un outil que vous maîtrisez bien.",
    "Que feriez-vous si vous remarquiez un danger sur le terrain ?",
    "Qu'est-ce qui vous motive le plus dans les métiers de la terre ?",
    "Selon vous, qu'est-ce qu'un bon employé agricole ?",
    "Avez-vous une préférence pour le travail en équipe ?"
];

let testStep = 0;
let testTranscript = "";
let testQuestions = [];

function runInterviewStep() {
    if (testStep === 0) {
        testTranscript = "";
        let intro = "Bonjour, je suis l'assistant AgriSmart. Ceci est un entretien de réflexion. Pour commencer, présentez-vous et parlez-moi de votre parcours.";
        testQuestions = [intro, ...testPool.sort(() => 0.5 - Math.random()).slice(0, 6)];
        testQuestions.push("L'entraînement est terminé. Je calcule vos résultats.");
    }

    document.getElementById('test-start-btn').classList.add('d-none');
    document.getElementById('test-result-area').classList.add('d-none');

    if (testStep < testQuestions.length - 1) {
        const q = testQuestions[testStep];
        document.getElementById('test-question-text').innerText = q;
        speak(q, () => { 
            const rec = new (window.SpeechRecognition || window.webkitSpeechRecognition)();
            rec.lang = 'fr-FR';
            rec.onstart = () => document.getElementById('test-wave').classList.remove('d-none');
            rec.onresult = (e) => {
                testTranscript += " " + e.results[0][0].transcript;
                document.getElementById('test-wave').classList.add('d-none');
                testStep++;
                setTimeout(runInterviewStep, 800);
            };
            rec.start();
        });
    } else {
        finishTest();
    }
}

function finishTest() {
    let score = Math.min(98, Math.floor((testTranscript.length / 10) + (Math.random() * 20)));
    document.getElementById('test-question-text').innerText = "Analyse terminée";
    document.getElementById('test-final-score').innerText = score + "%";
    document.getElementById('test-pos').innerText = "Bonne élocution et motivation détectée.";
    document.getElementById('test-neg').innerText = "Continuez à détailler vos expériences techniques.";
    document.getElementById('test-result-area').classList.remove('d-none');
    document.getElementById('test-start-btn').classList.remove('d-none');
    document.getElementById('test-start-btn').innerText = "Recommencer";
    speak("Analyse terminée. Votre score est de " + score + " pourcent.");
    testStep = 0;
}

function stopInterview() {
    window.speechSynthesis.cancel();
    testStep = 0;
}
</script>
