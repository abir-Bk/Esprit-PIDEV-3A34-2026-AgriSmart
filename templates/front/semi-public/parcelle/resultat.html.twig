<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Résultat du Diagnostic IA</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">

    <div class="modal fade" id="resultatModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="modalTitle" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content shadow-lg">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title" id="modalTitle">
                        <i class="bi bi-cpu"></i> Diagnostic de votre plante
                    </h5>
                    <a href="{{ path('app_parcelle_index') }}" class="btn-close btn-close-white" aria-label="Close"></a>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-5 text-center mb-3 mb-md-0">
                            <h6 class="text-muted">Image analysée</h6>
                            <img src="{{ image_envoyee }}" class="img-fluid rounded border shadow-sm" style="max-height: 300px;" alt="Plante envoyée">
                        </div>
                        <div class="col-md-7">
                            <h6 class="text-muted">Analyse de l'IA</h6>
                            <div class="p-3 bg-light border rounded" style="max-height: 350px; overflow-y: auto; font-size: 0.95rem;">
                                {{ diagnostic|nl2br }}
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <a href="{{ path('app_parcelle_index') }}" class="btn btn-secondary">Fermer et retourner aux parcelles</a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        window.onload = () => {
            const myModal = new bootstrap.Modal(document.getElementById('resultatModal'));
            myModal.show();
        };
    </script>
</body>
</html>