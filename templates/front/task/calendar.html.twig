{% extends 'front/task/layout.html.twig' %}

{% block title %}Calendrier des tâches - AgriSmart{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css" rel="stylesheet">
{% endblock %}

{% block task_content %}
  <div class="container py-3 py-md-4">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <h4 class="mb-0 fw-bold" style="color: var(--ag-text);">Calendrier des tâches agricoles</h4>
    <div class="d-flex gap-2">
      <a href="{{ path('tasks_index') }}" class="btn btn-sm btn-outline-secondary rounded-pill">
        <i class="bi bi-list-ul me-1"></i> Liste des tâches
      </a>
      <a href="{{ path('tasks_new') }}" class="btn btn-sm ag-btn-primary text-white rounded-pill">
        <i class="bi bi-plus-circle me-1"></i> Nouvelle tâche
      </a>
    </div>
  </div>

  <div class="ag-card p-4">
    <div id="task-calendar"></div>
  </div>

  <p class="mt-3 small ag-meta">
    <strong>Légende :</strong> Cliquez sur un événement pour ouvrir la fiche de la tâche. Les tâches sont affichées par date de début.
  </p>
  </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@fullcalendar/core/locales/fr.global.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const eventsData = {{ events|json_encode|raw }};
            const calendarEl = document.getElementById('task-calendar');
            const calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                locale: 'fr',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,listWeek'
                },
                buttonText: {
                    today: 'Aujourd\'hui',
                    month: 'Mois',
                    week: 'Semaine',
                    list: 'Liste'
                },
                events: eventsData,
                eventClick: function(info) {
                    if (info.event.url) {
                        info.jsEvent.preventDefault();
                        window.location.href = info.event.url;
                    }
                }
            });
            calendar.render();
        });
    </script>
{% endblock %}
