{% extends 'front/base.html.twig' %}

{% block body %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0">📦 Gestion du Ressource</h2>
        <a href="{{ path('app_ressource_new') }}" class="btn btn-success px-4 rounded-3 shadow-sm">
            <i class="fas fa-plus me-2"></i>Nouvelle Ressource
        </a>
    </div>

    {% for label, messages in app.flashes %}
        <div class="alert alert-{{ label == 'success' ? 'success' : 'info' }} border-0 shadow-sm mb-3">
            {{ messages[0] }}
        </div>
    {% endfor %}

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <table class="table align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Ressource</th>
                    <th>Type</th>
                    <th>Stock</th>
                    <th>Unité</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for ressource in ressources %}
                <tr>
                    <td class="ps-4 fw-bold text-dark">{{ ressource.nom }}</td>
                    <td><span class="badge bg-light text-dark border px-3">{{ ressource.type }}</span></td>
                    <td>
                        {# Utilisation obligatoire de stockRestan pour correspondre à getStockRestan() #}
                        <span class="badge {{ ressource.stockRestan < 10 ? 'bg-danger' : 'bg-success' }} px-3">
                            {{ ressource.stockRestan }}
                        </span>
                    </td>
                    <td class="text-muted">{{ ressource.unite }}</td>
                    <td class="text-end pe-4">
                        <div class="d-flex justify-content-end gap-2">
                            <a href="{{ path('app_ressource_edit', {'id': ressource.id}) }}" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form method="post" action="{{ path('app_ressource_delete', {'id': ressource.id}) }}" onsubmit="return confirm('Supprimer ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ ressource.id) }}">
                                <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="5" class="text-center py-4">Aucune ressource en stock.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}