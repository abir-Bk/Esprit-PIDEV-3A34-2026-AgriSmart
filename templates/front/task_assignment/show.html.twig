{% extends 'front/task/layout.html.twig' %}

{% block title %}Détail de l'affectation - AgriSmart{% endblock %}

{% block task_content %}
  <div class="ag-card p-4 mb-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
      <h5 class="mb-0 fw-bold" style="color: var(--ag-text);">Détails de l'affectation</h5>
      <div class="d-flex gap-2">
        <a href="{{ path('task_assignments_edit', {id: assignment.idAssignment}) }}" class="btn btn-sm ag-btn-primary text-white rounded-pill">Modifier</a>
        <a href="{{ path('task_assignments_index') }}" class="btn btn-sm btn-outline-secondary rounded-pill">Retour à la liste</a>
      </div>
    </div>
    <dl class="row mb-0">
      <dt class="col-sm-3 ag-meta">ID</dt>
      <dd class="col-sm-9">{{ assignment.idAssignment }}</dd>
      <dt class="col-sm-3 ag-meta">Tâche</dt>
      <dd class="col-sm-9">{{ assignment.task ? assignment.task.titre : '' }}</dd>
      <dt class="col-sm-3 ag-meta">Ouvrier (ID)</dt>
      <dd class="col-sm-9">{{ assignment.workerId }}</dd>
      <dt class="col-sm-3 ag-meta">Date d'affectation</dt>
      <dd class="col-sm-9">{{ assignment.dateAssignment ? assignment.dateAssignment|date('d/m/Y H:i') : '' }}</dd>
      <dt class="col-sm-3 ag-meta">Statut</dt>
      <dd class="col-sm-9">{{ assignment.statut }}</dd>
    </dl>
  </div>

  <form method="post" action="{{ path('task_assignments_delete', {id: assignment.idAssignment}) }}" class="d-inline" onsubmit="return confirm('Supprimer cette affectation ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ assignment.idAssignment) }}">
    <button class="btn btn-outline-danger rounded-pill">Supprimer</button>
  </form>
{% endblock %}
