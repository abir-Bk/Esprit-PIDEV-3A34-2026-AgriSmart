{% extends 'front/base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/parcelle.css') }}">
{% endblock %}

{% block body %}
<script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">

<main x-data="{
    selectedTab: {{ parcelles|length > 0 ? parcelles[0].id : 0 }},
    selectedParcelleId: {{ parcelles|length > 0 ? parcelles[0].id : 0 }},
    selectedCultureName: '',
    weather: { temp: '--', desc: 'Chargement...', icon: 'fa-sun', wind: '--' },
    advice: { text: 'Analyse en cours...', color: '#64748b', icon: 'fa-info-circle', bg: '#f1f5f9' },
   
    parcelles: [
        {% for p in parcelles %}
        {
            id: {{ p.id }},
            nom: '{{ p.nom|e('js') }}',
            surface: '{{ p.surface }}',
            typeSol: '{{ p.typeSol|e('js') }}',
            latitude: {{ p.latitude|default(36.8) }},
            longitude: {{ p.longitude|default(10.2) }},
            csrfToken: '{{ csrf_token('delete' ~ p.id) }}',
            cultures: [
                {% for c in p.cultures %}
                {
                    id: {{ c.id }},
                    typeCulture: '{{ c.typeCulture|e('js') }}',
                    variete: '{{ c.variete|e('js') }}',
                    statut: '{{ c.statut|e('js') }}',
                    datePlantation: '{{ c.datePlantation|date('Y-m-d') }}',
                    dateRecoltePrevue: '{{ c.dateRecoltePrevue|date('Y-m-d') }}',
                    datePFr: '{{ c.datePlantation|date('d/m/Y') }}',
                    dateRFr: '{{ c.dateRecoltePrevue|date('d/m/Y') }}',
                    csrfDeleteToken: '{{ csrf_token('delete' ~ c.id) }}',
                    consommations: [
                        {% for conso in c.consommations %}
                        {
                            ressource: '{{ conso.ressource.nom|e('js') }}',
                            quantite: '{{ conso.quantite }}',
                            unite: '{{ conso.ressource.unite|e('js') }}'
                        },
                        {% endfor %}
                    ]
                },
                {% endfor %}
            ]
        },
        {% endfor %}
    ],
    async getWeather(lat, lng) {
        try {
            const res = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lng}&current_weather=true`);
            const data = await res.json();
            const w = data.current_weather;
           
            const codes = {
                0: { desc: 'Ciel dégagé', icon: 'fa-sun text-warning' },
                1: { desc: 'Principalement dégagé', icon: 'fa-cloud-sun text-warning' },
                2: { desc: 'Partiellement nuageux', icon: 'fa-cloud-sun text-secondary' },
                3: { desc: 'Nuageux', icon: 'fa-cloud text-secondary' },
                45: { desc: 'Brouillard', icon: 'fa-smog text-muted' },
                61: { desc: 'Pluie légère', icon: 'fa-cloud-rain text-primary' },
                80: { desc: 'Averses', icon: 'fa-cloud-showers-heavy text-primary' },
                95: { desc: 'Orage', icon: 'fa-bolt text-dark' }
            };
           
            const config = codes[w.weathercode] || { desc: 'Variable', icon: 'fa-cloud' };
            this.weather = {
                temp: Math.round(w.temperature),
                desc: config.desc,
                icon: config.icon,
                wind: w.windspeed
            };
            if (this.weather.temp > 30) {
                this.advice = { text: 'Forte chaleur : Irriguer impérativement tôt le matin ou tard le soir.', color: '#ef4444', icon: 'fa-droplet', bg: '#fef2f2' };
            } else if (this.weather.wind > 20) {
                this.advice = { text: 'Vent fort : Reportez les traitements par pulvérisation (risque de dérive).', color: '#f59e0b', icon: 'fa-wind', bg: '#fffbe6' };
            } else if (w.weathercode >= 61) {
                this.advice = { text: 'Pluie prévue : Bonne période pour l\'apport d\'engrais solide.', color: '#3b82f6', icon: 'fa-cloud-showers-water', bg: '#eff6ff' };
            } else if (this.weather.temp < 5) {
                this.advice = { text: 'Risque de froid : Surveillez les jeunes plants sensibles au gel.', color: '#0ea5e9', icon: 'fa-snowflake', bg: '#f0f9ff' };
            } else {
                this.advice = { text: 'Conditions idéales pour l\'entretien et la plantation aujourd\'hui.', color: '#10b981', icon: 'fa-check-circle', bg: '#f0fdf4' };
            }
        } catch (e) { this.weather.desc = 'Indisponible'; }
    },
    updatePreviewMap(lat, lng) {
        if (window.previewMap) {
            const coords = [lat, lng];
            window.previewMap.setView(coords, 14);
            if (window.previewMarker) window.previewMarker.setLatLng(coords);
            else window.previewMarker = L.marker(coords).addTo(window.previewMap);
            setTimeout(() => window.previewMap.invalidateSize(), 200);
        }
    },
    editParcelle(p) {
        document.getElementById('parcelle_nom').value = p.nom;
        document.getElementById('parcelle_surface').value = p.surface;
        document.getElementById('parcelle_typeSol').value = p.typeSol;
        document.getElementById('parcelle_latitude').value = p.latitude;
        document.getElementById('parcelle_longitude').value = p.longitude;
        document.getElementById('form-parcelle').action = '/parcelle/' + p.id + '/edit';
        document.querySelector('#modalAjouterParcelle .modal-title').innerText = 'Modifier la Parcelle';
        if (p.latitude && p.longitude) {
            let coords = [p.latitude, p.longitude];
            setTimeout(() => {
                window.map.setView(coords, 13);
                if (window.marker) window.marker.setLatLng(coords);
                else window.marker = L.marker(coords).addTo(window.map);
            }, 200);
        }
    },
    editCulture(c) {
        document.getElementById('edit_typeCulture').value = c.typeCulture;
        document.getElementById('edit_variete').value = c.variete;
        document.getElementById('edit_datePlantation').value = c.datePlantation;
        document.getElementById('edit_dateRecoltePrevue').value = c.dateRecoltePrevue;
        document.getElementById('edit_statut').value = c.statut;
        document.getElementById('form-edit-culture').action = '/culture/' + c.id + '/edit';
    },
    resetForm() {
        document.getElementById('form-parcelle').reset();
        document.getElementById('form-parcelle').action = '/parcelle/';
        document.querySelector('#modalAjouterParcelle .modal-title').innerText = 'Ajouter une Parcelle';
        if (window.marker) window.map.removeLayer(window.marker);
        window.marker = null;
    }
}" x-init="
    $nextTick(() => {
        if(parcelles.length > 0) {
            window.previewMap = L.map('map-preview').setView([parcelles[0].latitude, parcelles[0].longitude], 14);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(window.previewMap);
            window.previewMarker = L.marker([parcelles[0].latitude, parcelles[0].longitude]).addTo(window.previewMap);
            getWeather(parcelles[0].latitude, parcelles[0].longitude);
        }
    })
">

    {# Hero style Marketplace #}
    <section class="ag-hero-parcelle">
        <div class="container">
            <div class="row align-items-center g-4">
                <div class="col-12">
                    <h1 class="ag-title">Parcelles AgriSmart</h1>
                    <p class="ag-subtitle">
                        Gérez vos <strong>parcelles</strong> et suivez vos cultures en un coup d'œil.
                    </p>
                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <button type="button" class="btn btn-parcelle-primary text-white rounded-pill px-4 py-2 fw-bold"
                                data-bs-toggle="modal" data-bs-target="#modalAjouterParcelle" @click="resetForm()">
                            <i class="fa-solid fa-plus me-2"></i>Nouvelle parcelle
                        </button>
                    </div>
                    {# Pills tri = style Marketplace #}
                    <div class="mt-4 d-flex flex-wrap gap-2">
                        <a class="ag-pill {{ (sort|default('nbCultures')) == 'nbCultures' ? 'active' : '' }}"
                           href="{{ path('app_parcelle_index', { search: search|default(''), sort: 'nbCultures', direction: direction|default('DESC') }) }}">
                            <i class="fa-solid fa-seedling"></i> Nombre de cultures
                        </a>
                        <a class="ag-pill {{ (sort|default('')) == 'nom' ? 'active' : '' }}"
                           href="{{ path('app_parcelle_index', { search: search|default(''), sort: 'nom', direction: direction|default('DESC') }) }}">
                            <i class="fa-solid fa-tag"></i> Nom
                        </a>
                        <a class="ag-pill {{ (sort|default('')) == 'surface' ? 'active' : '' }}"
                           href="{{ path('app_parcelle_index', { search: search|default(''), sort: 'surface', direction: direction|default('DESC') }) }}">
                            <i class="fa-solid fa-vector-square"></i> Surface
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="ag-content-parcelle">
        <div class="container">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'danger' ? 'danger' : 'success' }} alert-dismissible fade show rounded-3 shadow-sm mb-3" role="alert">
                        <i class="fa-solid {{ label == 'danger' ? 'fa-triangle-exclamation' : 'fa-circle-check' }} me-2"></i>
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            <div class="row g-4">
                {# Sidebar filtres = style Marketplace #}
                <aside class="col-lg-3">
                    <div class="card ag-filter-card-parcelle shadow-sm p-4 sticky-top" style="top: 18px;">
                        <div class="fw-bold text-uppercase small mb-3" style="color:var(--ag-muted);">Filtrer</div>
                        <form method="get" action="{{ path('app_parcelle_index') }}" class="vstack gap-3" id="form-filter-parcelle">
                            <div>
                                <label class="form-label small fw-bold mb-1" style="color:var(--ag-muted);">Recherche</label>
                                <input type="search" name="search" class="form-control ag-input-parcelle" placeholder="Nom parcelle..." value="{{ search|default('') }}">
                            </div>
                            <div>
                                <label class="form-label small fw-bold mb-1" style="color:var(--ag-muted);">Trier</label>
                                <select name="sort" class="form-select ag-input-parcelle" onchange="this.form.submit()">
                                    <option value="nbCultures" {{ (sort|default('nbCultures')) == 'nbCultures' ? 'selected' : '' }}>Nombre de cultures</option>
                                    <option value="nom" {{ (sort|default('')) == 'nom' ? 'selected' : '' }}>Nom</option>
                                    <option value="surface" {{ (sort|default('')) == 'surface' ? 'selected' : '' }}>Surface</option>
                                </select>
                            </div>
                            <div>
                                <label class="form-label small fw-bold mb-1" style="color:var(--ag-muted);">Ordre</label>
                                <select name="direction" class="form-select ag-input-parcelle" onchange="this.form.submit()">
                                    <option value="DESC" {{ (direction|default('DESC')) == 'DESC' ? 'selected' : '' }}>Décroissant</option>
                                    <option value="ASC" {{ (direction|default('')) == 'ASC' ? 'selected' : '' }}>Croissant</option>
                                </select>
                            </div>
                            <input type="hidden" name="page" value="1">
                            <div class="d-grid gap-2 pt-2">
                                <button type="submit" class="btn btn-parcelle-primary text-white rounded-pill">Appliquer</button>
                                <a href="{{ path('app_parcelle_index') }}" class="btn btn-outline-secondary rounded-pill">Réinitialiser</a>
                            </div>
                            <hr class="my-3">
                            <p class="small mb-0" style="color:var(--ag-muted);">
                                <i class="fa-solid fa-map-location-dot me-1"></i>
                                <strong x-text="parcelles.length"></strong> parcelle<span x-show="parcelles.length > 1">s</span>
                            </p>
                        </form>
                    </div>
                </aside>

                {# Contenu principal: liste + détail #}
                <div class="col-lg-9">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                        <p class="small mb-0" style="color:var(--ag-muted);">
                            <strong>{{ parcelles|length }}</strong> parcelle{{ parcelles|length > 1 ? 's' : '' }}
                            {% if search is defined and search != '' %}
                                · recherche : <span class="badge bg-light text-dark border">{{ search }}</span>
                            {% endif %}
                        </p>
                    </div>

                    <div class="row g-4">
                        <div class="col-lg-4">
                            <div class="d-flex align-items-center mb-3">
                                <h5 class="fw-bold mb-0" style="color:var(--ag-text);">Mes parcelles</h5>
                                <span class="ms-2 badge rounded-pill" style="background:var(--ag-primary); color:#fff;" x-text="parcelles.length"></span>
                            </div>
                            <div class="vstack gap-3">
                                <template x-for="parcelle in parcelles" :key="parcelle.id">
                                    <div class="agri-card p-3 bg-white rounded-4 shadow-sm"
                                         :class="selectedTab == parcelle.id ? 'active' : ''"
                                         @click="selectedTab = parcelle.id; selectedParcelleId = parcelle.id; updatePreviewMap(parcelle.latitude, parcelle.longitude); getWeather(parcelle.latitude, parcelle.longitude)">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <div class="fw-bold text-dark mb-1" x-text="parcelle.nom"></div>
                                                <div class="text-muted small">
                                                    <i class="fa-solid fa-vector-square me-1"></i> <span x-text="parcelle.surface"></span> Ha
                                                </div>
                                            </div>
                                            <div class="icon-circle" style="width:32px; height:32px; font-size:0.9rem">
                                                <i class="fa-solid fa-map-location-dot"></i>
                                            </div>
                                        </div>
                                        <div class="mt-3 pt-2 border-top d-flex justify-content-between align-items-center">
                                            <span class="badge badge-soft-success px-2 py-1" x-text="parcelle.typeSol"></span>
                                            <span class="small text-muted" x-text="parcelle.cultures.length + ' cultures'"></span>
                                        </div>
                                    </div>
                                </template>

                                <template x-if="parcelles.length === 0">
                                    <div class="text-center py-5 bg-white rounded-4 shadow-sm border border-dashed">
                                        <i class="fa-solid fa-seedling fa-3x text-muted opacity-50 mb-3"></i>
                                        <p class="text-muted mb-2">Aucune parcelle trouvée</p>
                                        {% if search is defined and search != '' %}
                                            <p class="small text-muted">Essayez avec un autre nom ou <a href="{{ path('app_parcelle_index') }}">effacez la recherche</a></p>
                                        {% endif %}
                                    </div>
                                </template>
                            </div>
                        </div>

                        <div class="col-lg-8">
                            <div class="bg-white p-4 rounded-4 shadow-sm border mb-4" style="border-radius:20px !important; border:1px solid rgba(17,24,39,.06);">
                                <div class="row align-items-start">
                                    <div class="col-md-7">
                                        <template x-for="parcelle in parcelles" :key="parcelle.id">
                                            <div x-show="selectedTab == parcelle.id">
                                                <h2 class="fw-bold mb-1" style="color:var(--ag-text);" x-text="parcelle.nom"></h2>
                                                <div class="d-flex gap-2 align-items-center mb-3">
                                                    <span class="badge px-3 py-2 rounded-pill" style="background:var(--ag-primary); color:#fff;" x-text="parcelle.typeSol"></span>
                                                    <span class="text-muted small"><i class="fa-solid fa-maximize me-1"></i> <span x-text="parcelle.surface"></span> Ha</span>
                                                </div>
                                                <div class="weather-widget p-3 mb-3 d-flex align-items-center">
                                                    <div class="me-4 fs-1">
                                                        <i :class="'fa-solid ' + weather.icon"></i>
                                                    </div>
                                                    <div class="flex-grow-1">
                                                        <div class="d-flex align-items-baseline">
                                                            <h3 class="fw-bold mb-0 me-2" x-text="weather.temp + '°C'"></h3>
                                                            <span class="text-muted small fw-bold text-uppercase" x-text="weather.desc"></span>
                                                        </div>
                                                        <div class="text-muted small mt-1">
                                                            <i class="fa-solid fa-wind me-1"></i> Vent: <span x-text="weather.wind"></span> km/h
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="advice-card p-3 mb-4 d-flex align-items-center shadow-sm"
                                                     :style="'background-color:' + advice.bg + '; border-color:' + advice.color">
                                                    <div class="me-3 fs-4" :style="'color:' + advice.color">
                                                        <i :class="'fa-solid ' + advice.icon"></i>
                                                    </div>
                                                    <div>
                                                        <div class="fw-bold small text-uppercase opacity-75 mb-1" :style="'color:' + advice.color">Conseil Agricole</div>
                                                        <div class="text-dark fw-600 small" x-text="advice.text"></div>
                                                    </div>
                                                </div>
                                               
                                                <p class="text-muted small mb-0">
                                                    <i class="fa-solid fa-location-dot me-1 text-danger"></i>
                                                    Coordonnées: <span x-text="parseFloat(parcelle.latitude).toFixed(4)"></span>, <span x-text="parseFloat(parcelle.longitude).toFixed(4)"></span>
                                                </p>
                                               
                                                <div class="mt-3">
                                                    <button class="btn btn-sm btn-outline-secondary rounded-pill me-2" @click="editParcelle(parcelle)" data-bs-toggle="modal" data-bs-target="#modalAjouterParcelle">
                                                        <i class="fa-solid fa-pen me-1"></i> Modifier
                                                    </button>
                                                    <form :action="'/parcelle/delete/' + parcelle.id" method="post" class="d-inline" onsubmit="return confirm('Supprimer cette parcelle ?');">
                                                        <input type="hidden" name="_token" :value="parcelle.csrfToken">
                                                        <button class="btn btn-sm btn-outline-danger rounded-pill"><i class="fa-solid fa-trash me-1"></i> Supprimer</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </template>
                                    </div>
                                    <div class="col-md-5">
                                        <div id="map-preview"></div>
                                    </div>
                                </div>

                                <hr class="my-4">

                                <template x-for="parcelle in parcelles" :key="parcelle.id">
                                    <div x-show="selectedTab == parcelle.id">
                                        <div class="d-flex justify-content-between align-items-center mb-4">
                                            <h5 class="fw-bold mb-0" style="color:var(--ag-text);">
                                                <i class="fa-solid fa-seedling me-2" style="color:var(--ag-primary);"></i>
                                                Suivi des cultures
                                            </h5>
                                            <button type="button" class="btn btn-sm btn-parcelle-primary text-white rounded-pill px-4" 
                                                    data-bs-toggle="modal" data-bs-target="#modalAjouterCulture" 
                                                    @click="selectedParcelleId = parcelle.id">
                                                <i class="fa-solid fa-plus me-2"></i>Planter
                                            </button>
                                        </div>

                                        <div class="row g-3">
                                            <template x-for="c in parcelle.cultures" :key="c.id">
                                                <div class="col-md-6">
                                                    <div class="culture-item">
                                                        <!-- En-tête avec icône et actions -->
                                                        <div class="d-flex justify-content-between align-items-start mb-3 culture-header">
                                                            <div class="icon-circle">
                                                                <i class="fa-solid fa-leaf"></i>
                                                            </div>
                                                            <div class="culture-actions">
                                                                <!-- Bouton Utiliser -->
                                                                <button class="btn-action btn-utiliser" 
                                                                        data-bs-toggle="modal"
                                                                        :data-bs-target="'#modalConsommer' + c.id">
                                                                    <i class="fa-solid fa-flask"></i>
                                                                    <span class="d-none d-sm-inline">Utiliser</span>
                                                                </button>
                                                                
                                                                <!-- Bouton IA -->
                                                                <button class="btn-action btn-ia" 
                                                                        data-bs-toggle="modal" 
                                                                        data-bs-target="#modalIAGlobal"
                                                                        @click="selectedCultureName = c.typeCulture">
                                                                    <i class="fa-solid fa-robot"></i>
                                                                    <span class="d-none d-sm-inline">IA</span>
                                                                </button>
                                                                
                                                                <!-- Bouton Modifier -->
                                                                <button class="btn-action btn-edit btn-action-sm" 
                                                                        @click="editCulture(c)" 
                                                                        data-bs-toggle="modal" 
                                                                        data-bs-target="#modalEditCulture"
                                                                        title="Modifier">
                                                                    <i class="fa-solid fa-pencil"></i>
                                                                </button>
                                                                
                                                                <!-- Bouton Supprimer -->
                                                                <form :action="'/culture/' + c.id + '/delete'" method="post" class="d-inline">
                                                                    <input type="hidden" name="_token" :value="c.csrfDeleteToken">
                                                                    <button class="btn-action btn-delete btn-action-sm" 
                                                                            onclick="return confirm('Supprimer cette culture ?')"
                                                                            title="Supprimer">
                                                                        <i class="fa-solid fa-trash"></i>
                                                                    </button>
                                                                </form>
                                                            </div>
                                                        </div>

                                                        <!-- Informations culture -->
                                                        <h6 class="fw-bold mb-1" x-text="c.typeCulture"></h6>
                                                        <p class="text-muted small mb-3">
                                                            Variété : <span class="text-dark fw-600" x-text="c.variete"></span>
                                                        </p>
                                                       
                                                        <!-- Dates -->
                                                        <div class="bg-light rounded-3 p-2 mb-3 d-flex justify-content-around text-center">
                                                            <div>
                                                                <span class="d-block small text-muted">Plantation</span>
                                                                <b class="small" x-text="c.datePFr"></b>
                                                            </div>
                                                            <div class="border-start"></div>
                                                            <div>
                                                                <span class="d-block small text-muted">Récolte</span>
                                                                <b class="small" x-text="c.dateRFr"></b>
                                                            </div>
                                                        </div>
                                                       
                                                        <!-- Statut -->
                                                        <span class="badge badge-soft-info w-100 py-2 rounded-3 mb-3" x-text="c.statut"></span>

                                                        <!-- Ressources utilisées -->
                                                        <div class="mt-2 pt-2 border-top">
                                                            <p class="small fw-bold text-muted mb-2" style="font-size: 0.7rem;">
                                                                <i class="fa-solid fa-box me-1"></i>
                                                                RESSOURCES UTILISÉES
                                                            </p>
                                                            <div class="d-flex flex-wrap gap-1">
                                                                <template x-for="conso in c.consommations">
                                                                    <span class="ressource-badge">
                                                                        <i class="fa-solid fa-droplet"></i>
                                                                        <span x-text="conso.ressource + ': ' + conso.quantite + ' ' + conso.unite"></span>
                                                                    </span>
                                                                </template>
                                                                <template x-if="c.consommations.length === 0">
                                                                    <span class="text-muted small fst-italic" style="font-size: 0.7rem;">
                                                                        Aucun intrant enregistré
                                                                    </span>
                                                                </template>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <!-- Modal Consommer -->
                                                    <div class="modal fade" :id="'modalConsommer' + c.id" tabindex="-1">
                                                        <div class="modal-dialog modal-dialog-centered">
                                                            <div class="modal-content border-0 shadow-lg rounded-4">
                                                                <div class="modal-header border-0 p-4 pb-0">
                                                                    <h5 class="fw-bold">
