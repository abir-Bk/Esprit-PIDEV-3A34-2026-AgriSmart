{% extends 'front/offre/layout.html.twig' %}

{% block title %}Mes Candidatures | AgriSmart{% endblock %}

{% block candidature_content %}
<section class="ag-hero">
  <div class="container">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
    <div>
      <h1 class="ag-title"><i class="bi bi-person-badge me-2" style="color: var(--ag-primary);"></i>Mes Candidatures</h1>
      <p class="ag-subtitle mb-0">Suivez l'état de vos demandes d'emploi</p>
    </div>
    <div class="d-flex align-items-center gap-2">
      <div class="d-flex align-items-center rounded-pill px-4 py-2" style="background: rgba(26,67,49,.08); border: 1px solid rgba(26,67,49,.15);">
        <i class="bi bi-folder-check me-2" style="color: var(--ag-primary);"></i>
        <div>
          <div class="fw-bold" style="color: var(--ag-text);">{{ demandes|length }}</div>
          <small class="ag-meta">Candidatures</small>
        </div>
      </div>
      <a href="{{ path('app_offre_index_front') }}" class="btn ag-btn-primary text-white rounded-pill">
        <i class="bi bi-search me-1"></i>Parcourir les offres
      </a>
    </div>
  </div>
  </div>
</section>

<section class="ag-content mt-0">
  <div class="container">
  {% set acceptees = demandes|filter(d => d.statut|lower in ['acceptée', 'accepte'])|length %}
  {% set en_cours = demandes|filter(d => d.statut|lower in ['en attente', 'en cours', 'pending'])|length %}
  {% set refusees = demandes|filter(d => d.statut|lower in ['refusée', 'refuse', 'rejetée'])|length %}

  {% if demandes|length > 0 %}
  <div class="row g-4 mb-4">
    <div class="col-md-4">
      <div class="ag-card h-100">
        <div class="p-4 d-flex align-items-center">
          <div class="rounded-circle p-3 me-3" style="background: rgba(34,197,94,.15);">
            <i class="bi bi-check-circle fs-4" style="color: #16a34a;"></i>
          </div>
          <div>
            <h3 class="fw-bold mb-0" style="color: var(--ag-text);">{{ acceptees }}</h3>
            <p class="ag-meta mb-0 small">Acceptées</p>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="ag-card h-100">
        <div class="p-4 d-flex align-items-center">
          <div class="rounded-circle p-3 me-3" style="background: rgba(245,158,11,.15);">
            <i class="bi bi-clock-history fs-4" style="color: #d97706;"></i>
          </div>
          <div>
            <h3 class="fw-bold mb-0" style="color: var(--ag-text);">{{ en_cours }}</h3>
            <p class="ag-meta mb-0 small">En cours</p>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="ag-card h-100">
        <div class="p-4 d-flex align-items-center">
          <div class="rounded-circle p-3 me-3" style="background: rgba(239,68,68,.12);">
            <i class="bi bi-x-circle fs-4 text-danger"></i>
          </div>
          <div>
            <h3 class="fw-bold mb-0" style="color: var(--ag-text);">{{ refusees }}</h3>
            <p class="ag-meta mb-0 small">Refusées</p>
          </div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  <div class="ag-card overflow-hidden">
    <div class="p-4 border-bottom" style="border-color: var(--ag-border) !important;">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
        <div>
          <h2 class="h5 fw-bold mb-1" style="color: var(--ag-text);"><i class="bi bi-list-check me-2" style="color: var(--ag-primary);"></i>Historique des candidatures</h2>
          <small class="ag-meta">Toutes vos demandes en un coup d'œil</small>
        </div>
        <div class="d-flex gap-2">
          <a href="{{ path('app_my_demandes_pdf') }}" class="btn btn-outline-dark rounded-pill btn-sm">
            <i class="bi bi-file-earmark-pdf me-1"></i>Analyse PDF
          </a>
          <button type="button" class="btn btn-outline-dark rounded-pill btn-sm" id="exportBtn">
            <i class="bi bi-download me-1"></i>Exporter
          </button>
        </div>
      </div>
    </div>

    <div class="table-responsive">
      <table class="table align-middle mb-0" id="candidaturesTable">
        <thead>
          <tr>
            <th class="ps-4 py-3"><i class="bi bi-briefcase me-2"></i>Offre d'emploi</th>
            <th class="py-3"><i class="bi bi-calendar me-2"></i>Date</th>
            <th class="py-3"><i class="bi bi-files me-2"></i>Documents</th>
            <th class="py-3"><i class="bi bi-hourglass-split me-2"></i>Statut candidature</th>
            <th class="py-3"><i class="bi bi-building me-2"></i>Statut offre</th>
            <th class="pe-4 py-3 text-end"><i class="bi bi-gear me-2"></i>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for demande in demandes %}
          <tr>
            <td class="ps-4 py-4">
              <div class="d-flex">
                <div class="flex-shrink-0">
                  <div class="avatar rounded-circle p-2 me-3" style="background: rgba(26,67,49,.1);">
                    <i class="bi bi-briefcase" style="color: var(--ag-primary);"></i>
                  </div>
                </div>
                <div>
                  <h6 class="fw-bold mb-1" style="color: var(--ag-text);">{{ demande.offre.title }}</h6>
                  <div class="d-flex align-items-center ag-meta small">
                    <i class="bi bi-geo-alt me-1"></i>{{ demande.offre.lieu }}
                    <span class="mx-2">•</span>
                    <i class="bi bi-cash-coin me-1"></i>{{ demande.offre.salaire }} DT
                  </div>
                </div>
              </div>
            </td>
            <td class="py-4">
              <div class="fw-medium" style="color: var(--ag-text);">{{ demande.datePostulation|date('d/m/Y') }}</div>
              <small class="ag-meta">{{ demande.datePostulation|date('H:i') }}</small>
              {% if demande.phoneNumber %}
              <div class="mt-1"><small class="ag-meta"><i class="bi bi-telephone me-1"></i>{{ demande.phoneNumber }}</small></div>
              {% endif %}
            </td>
            <td class="py-4">
              <div class="d-flex flex-column gap-1">
                {% if demande.cv %}
                <a href="{{ asset('uploads/cv/' ~ demande.cv) }}" target="_blank" class="btn btn-sm btn-outline-dark rounded-pill">
                  <i class="bi bi-file-earmark-pdf me-1"></i>CV
                </a>
                {% endif %}
                {% if demande.lettreMotivation %}
                <a href="{{ asset('uploads/lettres/' ~ demande.lettreMotivation) }}" target="_blank" class="btn btn-sm btn-outline-secondary rounded-pill">
                  <i class="bi bi-file-earmark-text me-1"></i>Lettre
                </a>
                {% endif %}
              </div>
            </td>
            <td class="py-4">
              {% set dem_status = demande.statut|lower %}
              {% if dem_status in ['acceptée', 'accepte'] %}
              <span class="badge rounded-pill px-3 py-2 d-inline-flex align-items-center" style="background: rgba(34,197,94,.12); color: #15803d;">
                <i class="bi bi-check-circle me-1"></i>Acceptée
              </span>
              {% elseif dem_status in ['refusée', 'refuse', 'rejetée'] %}
              <span class="badge rounded-pill px-3 py-2 d-inline-flex align-items-center bg-danger bg-opacity-10 text-danger">
                <i class="bi bi-x-circle me-1"></i>Refusée
              </span>
              {% else %}
              <span class="badge rounded-pill px-3 py-2 d-inline-flex align-items-center" style="background: rgba(245,158,11,.15); color: #b45309;">
                <i class="bi bi-clock me-1"></i>En cours
              </span>
              {% endif %}
              <small class="ag-meta d-block mt-1">Postulé le {{ demande.datePostulation|date('d/m/Y') }}</small>
            </td>
            <td class="py-4">
              {% set off_status = demande.offre.statut|lower %}
              {% if off_status in ['ouvert', 'open'] %}
              <span class="badge rounded-pill px-3 py-2" style="background: rgba(26,67,49,.12); color: var(--ag-primary);"><i class="bi bi-unlock me-1"></i>{{ demande.offre.statut }}</span>
              {% elseif off_status in ['clôturée', 'closed', 'fermée'] %}
              <span class="badge rounded-pill px-3 py-2 bg-dark bg-opacity-10 text-dark"><i class="bi bi-lock me-1"></i>{{ demande.offre.statut }}</span>
              {% else %}
              <span class="badge rounded-pill px-3 py-2 bg-secondary bg-opacity-10 text-secondary">{{ demande.offre.statut }}</span>
              {% endif %}
              <div class="mt-1"><small class="ag-meta">Type : {{ demande.offre.typeContrat }}</small></div>
            </td>
            <td class="pe-4 py-4 text-end">
              <div class="d-flex justify-content-end gap-1">
                <a href="{{ path('app_offre_show', {'id': demande.offre.id}) }}" class="btn btn-sm btn-outline-dark rounded-pill" title="Voir l'offre" data-bs-toggle="tooltip"><i class="bi bi-eye"></i></a>
                <a href="{{ path('app_demande_edit', {'id': demande.id}) }}" class="btn btn-sm rounded-pill" style="background: rgba(244,180,0,.2); color: #b45309;" title="Modifier" data-bs-toggle="tooltip"><i class="bi bi-pencil"></i></a>
                <form method="post" action="{{ path('app_demande_delete', {'id': demande.id}) }}" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette candidature ?');">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ demande.id) }}">
                  <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill" title="Supprimer" data-bs-toggle="tooltip"><i class="bi bi-trash"></i></button>
                </form>
              </div>
            </td>
          </tr>
          {% else %}
          <tr>
            <td colspan="6" class="text-center py-5">
              <div class="py-4">
                <div class="rounded-circle d-inline-flex p-4 mb-3" style="background: var(--ag-border);">
                  <i class="bi bi-inbox ag-meta" style="font-size: 2.5rem;"></i>
                </div>
                <h5 class="fw-bold mb-2" style="color: var(--ag-text);">Aucune candidature</h5>
                <p class="ag-meta mb-4">Vous n'avez pas encore postulé à des offres.</p>
                <a href="{{ path('app_offre_index_front') }}" class="btn ag-btn-primary text-white rounded-pill">
                  <i class="bi bi-search me-2"></i>Parcourir les offres
                </a>
              </div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {% if demandes|length > 0 %}
    <div class="p-3 border-top" style="border-color: var(--ag-border) !important; background: rgba(246,248,247,.5);">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <small class="ag-meta"><strong>{{ demandes|length }}</strong> candidature{{ demandes|length > 1 ? 's' : '' }}</small>
        <div class="d-flex align-items-center gap-2">
          <small class="ag-meta">Dernière mise à jour : {{ "now"|date('d/m/Y H:i') }}</small>
          <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" onclick="location.reload()"><i class="bi bi-arrow-clockwise"></i> Actualiser</button>
        </div>
      </div>
    </div>
    {% endif %}
  </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
  tooltipTriggerList.forEach(function(el) { new bootstrap.Tooltip(el); });

  var exportBtn = document.getElementById('exportBtn');
  if (exportBtn) exportBtn.addEventListener('click', function() {
    var table = document.getElementById('candidaturesTable');
    var rows = table ? table.querySelectorAll('tbody tr') : [];
    var csvContent = "data:text/csv;charset=utf-8,";
    var headers = ['Offre', 'Lieu', 'Date', 'Statut', 'Statut Offre', 'Type Contrat'];
    csvContent += headers.join(';') + "\n";
    rows.forEach(function(row) {
      var cells = row.querySelectorAll('td');
      if (cells.length >= 5) {
        var offre = (cells[0].querySelector('.fw-bold') && cells[0].querySelector('.fw-bold').textContent.trim()) || '';
        var lieu = (cells[0].querySelector('.ag-meta') && cells[0].querySelector('.ag-meta').textContent.trim()) || '';
        var date = (cells[1].querySelector('.fw-medium') && cells[1].querySelector('.fw-medium').textContent.trim()) || '';
        var statutEl = cells[3].querySelector('.badge');
        var statut = statutEl ? statutEl.textContent.trim() : '';
        var statutOffreEl = cells[4].querySelector('.badge');
        var statutOffre = statutOffreEl ? statutOffreEl.textContent.trim() : '';
        var typeEl = cells[4].querySelector('.ag-meta');
        var typeContrat = typeEl ? typeEl.textContent.trim().replace('Type : ', '') : '';
        csvContent += [offre, lieu, date, statut, statutOffre, typeContrat].join(';') + "\n";
      }
    });
    var link = document.createElement('a');
    link.setAttribute('href', encodeURI(csvContent));
    link.setAttribute('download', 'mes_candidatures.csv');
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  });
});
</script>
{% endblock %}