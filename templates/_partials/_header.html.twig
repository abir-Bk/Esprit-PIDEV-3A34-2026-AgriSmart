{# templates/_partials/_header.html.twig #}
<header class="navbar-light header-sticky bg-white border-bottom py-1">
    <nav class="navbar navbar-expand-xl py-1">
        <div class="container">

            <a class="navbar-brand d-flex align-items-center py-0" href="{{ path('app_produit_index') }}">
                <img src="{{ asset('assets/images/logo.png') }}" alt="logo" style="height:30px;">
                <span class="fw-bold ms-2" style="color: #1a4331; font-size: 1.1rem;">
                    Agri<span style="color: #28a745;">Smart</span>
                </span>
            </a>

            <button class="navbar-toggler p-2" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarCollapse">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link small px-3" href="#">
                            <i class="bi bi-list-check me-1"></i>Tâches
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link small px-3" href="{{ path('app_produit_index') }}">
                            <i class="bi bi-shop me-1"></i>Marketplace
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link small px-3" href="#">
                            <i class="bi bi-flower1 me-1"></i>Culture
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link small px-3" href="#">
                            <i class="bi bi-person-badge me-1"></i>Candidature
                        </a>
                    </li>
                </ul>
            </div>

            {# DROITE #}
            <div class="d-flex align-items-center gap-3">

                {# PANIER (badge dynamique) #}
                <a href="{{ path('app_panier_index') }}" class="position-relative text-decoration-none" title="Voir le panier">
                    <i class="bi bi-cart3 fs-5 text-muted"></i>
                    {% set panier = app.session.get('panier', {})|default({}) %}
                    {% set panierCount = panier|reduce((carry, qty) => carry + qty, 0) %}

                    {% if panierCount > 0 %}
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-success">
                            {{ panierCount }}
                            <span class="visually-hidden">articles dans le panier</span>
                        </span>
                    {% endif %}
                </a>

                <i class="bi bi-bell fs-5 text-muted" style="cursor:pointer;"></i>

                <div class="avatar-static">
                    <img
                        src="https://ui-avatars.com/api/?name={{ app.user ? (app.user.email|url_encode) : 'DEV' }}&background=1a4331&color=fff"
                        class="rounded-circle border"
                        width="32" height="32"
                        alt="user"
                    >
                </div>
            </div>

        </div>
    </nav>
</header>
