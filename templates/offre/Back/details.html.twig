<!DOCTYPE html>
<html lang="en">
<head>
    <title>Détails Offre - {{ offre.title }}</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Poppins:wght@400;500;700&display=swap">
    <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/bootstrap-icons/bootstrap-icons.css') }}">
    <link rel="stylesheet" type="text/css" href="{{ asset('assets/css/style.css') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>

<body class="bg-light">
<div class="container mt-5 mb-5">
    <a href="{{ path('app_admin_offres') }}" class="btn btn-sm btn-outline-secondary mb-4">
        <i class="bi bi-arrow-left"></i> Retour à la liste
    </a>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0">Détails de l'Offre</h5>
                </div>
                <div class="card-body">
                    <h4 class="text-primary">{{ offre.title }}</h4>
                    <p class="text-muted mb-4"><i class="bi bi-geo-alt me-1"></i> {{ offre.lieu }}</p>
                    
                    <ul class="list-group list-group-flush small">
                        <li class="list-group-item d-flex justify-content-between px-0">
                            <span class="text-secondary">Type:</span> <strong>{{ offre.typeContrat }}</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between px-0">
                            <span class="text-secondary">Salaire:</span> <strong>{{ offre.salaire }} DT</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between px-0">
                            <span class="text-secondary">Statut:</span> 
                            <span class="badge {{ offre.statut|lower == 'ouvert' ? 'bg-success' : 'bg-danger' }}">
                                {{ offre.statut }}
                            </span>
                        </li>
                    </ul>
                    <div class="mt-4">
                        <h6 class="small fw-bold">Description:</h6>
                        <p class="small text-dark">{{ offre.description }}</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Candidatures Reçues ({{ demandes|length }})</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Candidat</th>
                                    <th>Date</th>
                                    <th>Statut</th>
                                    <th class="text-end pe-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for demande in demandes %}
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="avatar avatar-sm bg-light rounded-circle p-2 me-2">
                                                    <i class="bi bi-person text-secondary"></i>
                                                </div>
                                                <div>
                                                    <div class="fw-bold">{{ demande.nom }} {{ demande.prenom }}</div>
                                                    <small class="text-muted">{{ demande.phoneNumber }}</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="small">{{ demande.datePostulation|date('d/m/Y') }}</td>
                                        <td>
                                            {% set d_status = demande.statut|lower %}
                                            <span class="badge rounded-pill {% if d_status == 'acceptée' %}bg-success{% elseif d_status == 'refusée' %}bg-danger{% else %}bg-warning text-dark{% endif %}">
                                                {{ demande.statut }}
                                            </span>
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="btn-group">
                                                <a href="{{ path('app_admin_demande_details', {'id': demande.id}) }}" class="btn btn-sm btn-info text-white" title="Voir les détails">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                
                                               
                                            </div>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted">
                                            Aucune candidature pour le moment.
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>