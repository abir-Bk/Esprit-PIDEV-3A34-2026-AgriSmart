{% extends 'base.html.twig' %}

{% block title %}Verify Your Identity{% endblock %}

{% block body %}
<div class="container d-flex justify-content-center align-items-center min-vh-100">
    <div class="card shadow p-4" style="max-width: 420px; width: 100%;">
        <div class="text-center mb-4">
            <h4 class="fw-bold">🔐 Security Verification</h4>
            <p class="text-muted">
                A 6-digit code was sent to<br>
                <strong>{{ email|u.truncate(30, '…') }}</strong>
            </p>
        </div>

        {% for message in app.flashes('info') %}
            <div class="alert alert-info">{{ message }}</div>
        {% endfor %}

        {% if error %}
            <div class="alert alert-danger">{{ error }}</div>
        {% endif %}

        <form method="post" action="{{ path('app_2fa_check') }}">
            <div class="mb-3">
                <label for="code" class="form-label">Verification Code</label>
                <input
                    type="text"
                    id="code"
                    name="code"
                    class="form-control form-control-lg text-center"
                    maxlength="6"
                    pattern="\d{6}"
                    inputmode="numeric"
                    autocomplete="one-time-code"
                    autofocus
                    placeholder="______"
                    required
                >
            </div>
            <button type="submit" class="btn btn-primary w-100">Verify</button>
        </form>

        <form method="post" action="{{ path('app_2fa_resend') }}" class="mt-3 text-center">
            <button type="submit" class="btn btn-link btn-sm">Didn't receive a code? Resend</button>
        </form>

        <div class="text-center mt-2">
            <a href="{{ path('app_logout') }}" class="text-muted small">Cancel and log out</a>
        </div>
    </div>
</div>
{% endblock %}