{% extends 'front/base.html.twig' %}

{% block title %}AgriSmart | Ressources{% endblock %}

{% block body %}

<style>
/* =========================
   AgriSmart Ressources (same as Marketplace)
   ========================= */
.ag-marketplace{
  --ag-primary:#1A4331;
  --ag-primary-2:#2E7D32;
  --ag-accent:#F4B400;
  --ag-cream:#FBF7EE;
  --ag-bg:#F6F8F7;
  --ag-text:#111827;
  --ag-muted:#6B7280;
  --ag-border:#E5E7EB;
}

.ag-marketplace .ag-title{
  font-size: clamp(2.0rem, 4vw, 3.0rem) !important;
  line-height: 1.05 !important;
  letter-spacing: -0.02em;
  margin: 0;
}
.ag-marketplace .ag-subtitle{
  font-size: 1.05rem !important;
  color: var(--ag-muted) !important;
  margin: .75rem 0 0 0;
}

.ag-marketplace .ag-hero{
  background:
    radial-gradient(900px 420px at 18% 25%, rgba(46,125,50,.16), transparent 60%),
    radial-gradient(700px 320px at 85% 10%, rgba(244,180,0,.14), transparent 55%),
    linear-gradient(180deg, var(--ag-cream), #ffffff);
  border-bottom: 1px solid rgba(17,24,39,.06);
  padding: 3.0rem 0 2.0rem;
}

.ag-marketplace .ag-btn-primary{
  background: var(--ag-primary) !important;
  border: none !important;
}
.ag-marketplace .ag-btn-primary:hover{ background:#163828 !important; color: #fff !important; }

.ag-marketplace a.ag-pill,
.ag-marketplace a.ag-pill:visited{
  display: inline-flex;
  align-items: center;
  gap: .45rem;
  border: 1px solid var(--ag-border);
  background: #fff;
  color: var(--ag-text) !important;
  text-decoration: none !important;
  border-radius: 999px;
  padding: .5rem .9rem;
  font-weight: 600;
  font-size: .92rem;
  transition: .15s;
}
.ag-marketplace a.ag-pill:hover{
  border-color: rgba(26,67,49,.35);
  box-shadow: 0 .4rem 1rem rgba(0,0,0,.06);
  transform: translateY(-1px);
}
.ag-marketplace a.ag-pill.active,
.ag-marketplace a.ag-pill.active:visited{
  border-color: rgba(26,67,49,.35);
  background: rgba(26,67,49,.08);
  color: var(--ag-primary) !important;
}

.ag-marketplace .ag-content{
  background: var(--ag-bg);
  padding: 2.0rem 0 3.0rem;
}

.ag-marketplace .ag-filter-card{
  border: 1px solid rgba(17,24,39,.06) !important;
  border-radius: 20px !important;
}
.ag-marketplace .ag-input{
  border-radius: 14px !important;
  border: 1px solid var(--ag-border) !important;
}
.ag-marketplace .ag-input:focus{
  border-color: rgba(26,67,49,.45) !important;
  box-shadow: 0 0 0 .25rem rgba(26,67,49,.12) !important;
}

.ag-marketplace .ag-card{
  border: 1px solid rgba(17,24,39,.06);
  border-radius: 20px;
  overflow: hidden;
  background: #fff;
  transition: .18s;
}
.ag-marketplace .ag-card:hover{
  box-shadow: 0 .9rem 1.6rem rgba(0,0,0,.08);
}

.ag-marketplace .ag-hero-ornament{
  width: min(420px, 100%);
  height: 170px;
  border-radius: 26px;
  background:
    radial-gradient(120px 120px at 25% 60%, rgba(46,125,50,.18), transparent 60%),
    radial-gradient(140px 140px at 65% 35%, rgba(244,180,0,.18), transparent 60%),
    linear-gradient(135deg, rgba(26,67,49,.10), rgba(46,125,50,.06));
  border: 1px solid rgba(17,24,39,.06);
}

.ag-marketplace .table thead th{
  background: var(--ag-primary);
  color: #fff;
  border: none;
  font-weight: 600;
  padding: 1rem 1.25rem;
}
.ag-marketplace .table tbody td{ padding: 1rem 1.25rem; vertical-align: middle; }
.ag-marketplace .table tbody tr:hover{ background: rgba(26,67,49,.04); }
.ag-marketplace .ag-meta{ color: var(--ag-muted); font-size: .86rem; }
</style>

<div class="ag-marketplace">

  {# HERO #}
  <section class="ag-hero">
    <div class="container">
      <div class="row align-items-center g-4">
        <div class="col-lg-7">
          <h1 class="ag-title" style="color:var(--ag-text);">Ressources & Stock</h1>
          <p class="ag-subtitle">
            Suivez et optimisez vos <strong>stocks agricoles</strong> en temps réel.
          </p>

          <div class="d-flex flex-wrap gap-2 mt-4">
            <a href="{{ path('app_ressource_export_csv') }}" class="btn btn-outline-dark rounded-pill">
              <i class="bi bi-download me-2"></i>Export CSV
            </a>
            <a href="{{ path('app_ressource_new') }}" class="btn ag-btn-primary text-white rounded-pill">
              <i class="bi bi-plus-circle me-2"></i>Nouvelle ressource
            </a>
          </div>

          {# TYPE CHIPS #}
          <div class="mt-4 d-flex flex-wrap gap-2">
            <a class="ag-pill {{ not typeSearch ? 'active' : '' }}"
               href="{{ path('app_ressource_index', { page: 1 }) }}">
              <i class="bi bi-grid-3x3-gap"></i> Tous
            </a>
            {% for t in typesDisponibles %}
              <a class="ag-pill {{ typeSearch == t ? 'active' : '' }}"
                 href="{{ path('app_ressource_index', { type: t, page: 1 }) }}">
                <i class="bi bi-tag"></i> {{ t }}
              </a>
            {% endfor %}
          </div>
        </div>

        <div class="col-lg-5 d-flex justify-content-lg-end">
          <div class="ag-hero-ornament w-100"></div>
        </div>
      </div>
    </div>
  </section>

  {# CONTENT #}
  <section class="ag-content">
    <div class="container">
      <div class="row g-4">

        {# SIDEBAR FILTER #}
        <aside class="col-lg-3">
          <div class="card ag-filter-card shadow-sm p-4 sticky-top" style="top: 18px;">
            <div class="fw-bold text-uppercase small mb-3" style="color:var(--ag-muted);">Filtrer par type</div>
            <form method="get" action="{{ path('app_ressource_index') }}" class="vstack gap-3">
              <select name="type" class="form-select ag-input" onchange="this.form.submit()">
                <option value="">Tous les types</option>
                {% for t in typesDisponibles %}
                  <option value="{{ t }}" {{ t == typeSearch ? 'selected' }}>{{ t }}</option>
                {% endfor %}
              </select>
              <input type="hidden" name="page" value="1">
              <button type="submit" class="btn ag-btn-primary text-white rounded-pill">Appliquer</button>
              <a href="{{ path('app_ressource_index') }}" class="btn btn-outline-secondary rounded-pill">Réinitialiser</a>
            </form>
            <hr class="my-3">
            <p class="small mb-0 ag-meta">
              <i class="bi bi-box-seam me-1"></i>
              <strong>{{ totalResults }}</strong> ressource{{ totalResults > 1 ? 's' : '' }} au total
            </p>
          </div>
        </aside>

        {# MAIN: TABLE #}
        <div class="col-lg-9">
          {% for label, messages in app.flashes %}
            {% for message in messages %}
              <div class="alert alert-{{ label }} alert-dismissible fade show mb-3" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              </div>
            {% endfor %}
          {% endfor %}

          <div class="ag-card p-0">
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead>
                  <tr>
                    <th class="ps-4">Ressource</th>
                    <th>Type</th>
                    <th>État du stock</th>
                    <th class="text-center">Unité</th>
                    <th class="text-end pe-4">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {% for ressource in ressources %}
                  <tr>
                    <td class="ps-4">
                      <div class="d-flex align-items-center">
                        <div class="rounded-3 d-flex align-items-center justify-content-center me-3" style="width:44px;height:44px;background:rgba(26,67,49,.12);color:var(--ag-primary);">
                          <i class="bi bi-archive"></i>
                        </div>
                        <span class="fw-bold" style="color:var(--ag-text);">{{ ressource.nom }}</span>
                      </div>
                    </td>
                    <td>
                      <span class="badge rounded-pill px-3 py-2" style="background:rgba(26,67,49,.12);color:var(--ag-primary);border:1px solid rgba(26,67,49,.2);">
                        {{ ressource.type }}
                      </span>
                    </td>
                    <td>
                      {% if ressource.stockRestant < 10 %}
                        <span class="badge bg-danger rounded-pill px-3">
                          <i class="bi bi-exclamation-triangle me-1"></i>{{ ressource.stockRestant }} (Critique)
                        </span>
                      {% else %}
                        <span class="badge bg-light text-dark border rounded-pill px-3">
                          {{ ressource.stockRestant }} en stock
                        </span>
                      {% endif %}
                    </td>
                    <td class="text-center ag-meta fw-semibold">{{ ressource.unite }}</td>
                    <td class="text-end pe-4">
                      <div class="d-flex gap-1 justify-content-end">
                        <a href="{{ path('app_ressource_edit', {'id': ressource.id}) }}" class="btn btn-sm btn-outline-primary rounded-pill" title="Modifier">
                          <i class="bi bi-pencil"></i>
                        </a>
                        <form method="post" action="{{ path('app_ressource_delete', {'id': ressource.id}) }}" onsubmit="return confirm('Confirmer la suppression ?');" class="d-inline">
                          <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ ressource.id) }}">
                          <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill" title="Supprimer">
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                  {% else %}
                  <tr>
                    <td colspan="5" class="text-center py-5">
                      <div class="py-5">
                        <i class="bi bi-box-seam display-4 text-muted"></i>
                        <h4 class="mt-3" style="color:var(--ag-text);">Aucune ressource</h4>
                        <p class="ag-meta mb-4">Votre inventaire est vide. Ajoutez votre premier stock.</p>
                        <a href="{{ path('app_ressource_new') }}" class="btn ag-btn-primary text-white rounded-pill">
                          <i class="bi bi-plus-circle me-1"></i> Nouvelle ressource
                        </a>
                      </div>
                    </td>
                  </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </div>

          {# PAGINATION #}
          {% if totalPages is defined and totalPages > 1 %}
            <nav class="d-flex justify-content-center mt-4" aria-label="Pagination">
              <ul class="pagination mb-0">
                <li class="page-item {{ currentPage <= 1 ? 'disabled' : '' }}">
                  <a class="page-link rounded-pill me-1 border-0" style="color:var(--ag-primary);" href="{{ path('app_ressource_index', {type: typeSearch, page: currentPage - 1}) }}">
                    <i class="bi bi-chevron-left"></i>
                  </a>
                </li>
                {% for p in 1..totalPages %}
                  <li class="page-item {{ p == currentPage ? 'active' : '' }}">
                    <a class="page-link rounded-pill me-1 border-0 {{ p == currentPage ? 'text-white' : '' }}" style="{{ p == currentPage ? 'background:var(--ag-primary);' : 'color:var(--ag-primary);' }}" href="{{ path('app_ressource_index', {type: typeSearch, page: p}) }}">{{ p }}</a>
                  </li>
                {% endfor %}
                <li class="page-item {{ currentPage >= totalPages ? 'disabled' : '' }}">
                  <a class="page-link rounded-pill border-0" style="color:var(--ag-primary);" href="{{ path('app_ressource_index', {type: typeSearch, page: currentPage + 1}) }}">
                    <i class="bi bi-chevron-right"></i>
                  </a>
                </li>
              </ul>
            </nav>
          {% endif %}
        </div>

      </div>
    </div>
  </section>
</div>

{% endblock %}
