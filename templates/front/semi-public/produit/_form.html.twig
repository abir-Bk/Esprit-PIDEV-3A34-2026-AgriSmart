            {% endif %}

            <div id="section-promo-price" class="mt-3" style="display:none;">
                <label class="form-label fw-bold small text-warning">Prix réduit (TND)</label>
                {{ form_widget(form.promotionPrice, {
                    attr: {
                        class: (form.promotionPrice.vars.errors|length ? 'form-control am-input is-invalid js-sync-promo-price' : 'form-control am-input js-sync-promo-price'),
                        placeholder: '0.00',
                        min: 0,
                        step: '0.01'
                    }
                }) }}
                {% if form.promotionPrice.vars.errors|length %}
                    <div class="invalid-feedback d-block">
                        {{ form_errors(form.promotionPrice) }}
                    </div>
                {% endif %}
                <div class="form-text">Doit être ≤ prix normal.</div>
            </div>
        </div>
    </div>

    {# IMAGE #}
    <div class="col-12">
        <label class="form-label fw-bold">Image du produit</label>
        {{ form_widget(form.imageFile, {
            attr: {
                class: (form.imageFile.vars.errors|length ? 'form-control am-input is-invalid js-image-file' : 'form-control am-input js-image-file'),
                accept: 'image/*'
