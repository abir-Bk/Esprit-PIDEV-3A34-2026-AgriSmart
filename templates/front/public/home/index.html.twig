		.header-landing .btn-landing-primary { background: var(--ag-primary); border: none; color: #fff; font-weight: 600; padding: 0.5rem 1.35rem; border-radius: 999px; box-shadow: 0 4px 14px rgba(26,67,49,0.3); transition: transform 0.2s, box-shadow 0.2s; }
		.header-landing .btn-landing-primary:hover { background: #163828; color: #fff; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(26,67,49,0.35); }
		html { scroll-behavior: smooth; }

		/* ---------- Hero ---------- */
		.landing-hero { min-height: 85vh; display: flex; align-items: center; position: relative; overflow: hidden; }
		.landing-hero .hero-overlay { position: absolute; inset: 0; background: linear-gradient(105deg, rgba(26,67,49,0.78) 0%, rgba(26,67,49,0.45) 45%, rgba(0,0,0,0.3) 100%); }
		.landing-hero .hero-content { position: relative; z-index: 2; }
		.landing-hero .hero-badge { display: inline-block; color: rgba(255,255,255,0.95); font-size: 0.95rem; font-weight: 500; margin-bottom: 1rem; }
		.landing-hero .hero-title { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; line-height: 1.15; letter-spacing: -0.03em; color: #fff; text-shadow: 0 2px 20px rgba(0,0,0,0.2); }
		.landing-hero .btn-hero-cta { padding: 0.85rem 2rem; font-weight: 600; border-radius: 999px; font-size: 1.05rem; transition: transform 0.2s, box-shadow 0.2s; border: none; }
		.landing-hero .btn-hero-cta:hover { transform: translateY(-2px); }
		.landing-hero .btn-hero-cta.btn-light { background: #fff; color: var(--ag-primary); box-shadow: 0 8px 24px rgba(0,0,0,0.15); }
		.landing-hero .btn-hero-cta.btn-light:hover { box-shadow: 0 12px 28px rgba(0,0,0,0.2); }
		.landing-hero .btn-hero-cta.btn-success { background: var(--ag-primary); color: #fff; box-shadow: 0 8px 24px rgba(26,67,49,0.35); }
