{% extends 'back/admin_base.html.twig' %}

{% block title %}Détails Candidature - {{ demande.nom }}{% endblock %}

{% block body %}
<div class="d-flex">
    {% include 'back/components/sidebar.html.twig' %}
    
    <div class="flex-grow-1 p-4 am-content">
        {# Barre de navigation #}
        <div class="mb-4 d-flex justify-content-between align-items-center">
            <a href="{{ path('app_admin_offre_details', {'id': demande.offre.id}) }}" class="btn am-btn-outline">
                <i class="fa-solid fa-arrow-left me-2"></i>Retour à l'offre
            </a>
            <span class="badge am-badge">ID Candidature: #{{ demande.id }}</span>
        </div>

        <div class="row g-4">
            {# --- COLONNE GAUCHE : INFOS CANDIDAT & STATUT --- #}
            <div class="col-lg-5">
                <div class="card border-0 am-card h-100">
                    <div class="card-header am-card-header py-4 border-0 text-center">
                        <div class="bg-white rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 80px; height: 80px;">
                            <i class="fa-solid fa-user-tie fs-1 am-text"></i>
                        </div>
                        <h3 class="mb-1 fw-bold text-white">{{ demande.nom }} {{ demande.prenom }}</h3>
                        <p class="mb-0 text-white-50"><i class="fa-solid fa-phone me-2"></i>{{ demande.phoneNumber }}</p>
                    </div>
                    
                    <div class="card-body p-4">
                        <div class="am-info-box p-3 rounded-3 mb-4">
                            <label class="form-label fw-bold am-text mb-3">
                                <i class="fa-solid fa- Pellegrin-pen me-2"></i>Mettre à jour le statut
                            </label>
                            <form action="{{ path('app_admin_demande_update_status', {'id': demande.id}) }}" method="POST">
                                <div class="input-group">
                                    <select name="statut" class="form-select border-success-subtle">
                                        <option value="En cours" {{ demande.statut == 'En cours' ? 'selected' : '' }}>En cours</option>
                                        <option value="Acceptée" {{ demande.statut == 'Acceptée' ? 'selected' : '' }}>Acceptée</option>
                                        <option value="Refusée" {{ demande.statut == 'Refusée' ? 'selected' : '' }}>Refusée</option>
                                    </select>
                                    <button type="submit" class="btn am-btn-success">Valider</button>
                                </div>
                            </form>
                        </div>

                        <div class="text-muted small">
                            <i class="fa-solid fa-calendar-day me-2"></i>Postulé le : <strong>{{ demande.datePostulation|date('d/m/Y à H:i') }}</strong>
                        </div>
                    </div>
                </div>
            </div>

            {# --- COLONNE DROITE : DOCUMENTS --- #}
            <div class="col-lg-7">
                <div class="card border-0 am-card h-100">
                    <div class="card-header am-card-header-light py-3 border-0">
                        <h5 class="mb-0 fw-semibold am-text">
                            <i class="fa-solid fa-folder-open me-2"></i>Documents joints
                        </h5>
                    </div>
                    
                    <div class="card-body p-4">
                        {# Section CV #}
                        <div class="d-flex align-items-center justify-content-between p-3 border rounded-3 mb-3 hover-doc">
                            <div class="d-flex align-items-center">
                                <div class="bg-danger bg-opacity-10 p-3 rounded-3 me-3">
                                    <i class="fa-solid fa-file-pdf text-danger fs-3"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">Curriculum Vitae (CV)</h6>
                                    <small class="text-muted">Document PDF</small>
                                </div>
                            </div>
                            <a href="{{ asset('uploads/cv/' ~ demande.cv) }}" target="_blank" class="btn btn-sm am-btn-outline">
                                <i class="fa-solid fa-eye me-1"></i>Consulter
                            </a>
                        </div>

                        {# Section Lettre de Motivation #}
                        <div class="d-flex align-items-center justify-content-between p-3 border rounded-3 hover-doc">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-3">
                                    <i class="fa-solid fa-file-lines text-primary fs-3"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">Lettre de Motivation</h6>
                                    <small class="text-muted">Document PDF / Texte</small>
                                </div>
                            </div>
                            <a href="{{ asset('uploads/lettres/' ~ demande.lettreMotivation) }}" target="_blank" class="btn btn-sm am-btn-outline">
                                <i class="fa-solid fa-eye me-1"></i>Consulter
                            </a>
                        </div>

                        {# Note informative #}
                        <div class="mt-4 p-3 bg-light rounded-3 small text-muted">
                            <i class="fa-solid fa-circle-info me-2"></i>
                            Cliquez sur "Consulter" pour ouvrir le document dans un nouvel onglet.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
/* Réutilisation exacte de ta charte AgriSmart */
.am-content { background: #f8f9fa; min-height: 100vh; }
.am-title, .am-text { color: #1a4331; }
.am-card { box-shadow: 0 4px 20px rgba(26, 67, 49, 0.08); border-radius: 15px; overflow: hidden; }
.am-card-header { background: linear-gradient(135deg, #1a4331 0%, #2d5a3d 100%); color: #fff; }
.am-card-header-light { background: rgba(26, 67, 49, 0.05); border-bottom: 1px solid #eee; }
.am-info-box { background: rgba(26, 67, 49, 0.03); border: 1px solid rgba(26, 67, 49, 0.1); }
.am-btn-outline { border: 1.5px solid #1a4331; color: #1a4331; border-radius: 8px; font-weight: 600; transition: 0.3s; }
.am-btn-outline:hover { background: #1a4331; color: #fff; }
.am-btn-success { background: #1a4331; color: #fff; border: none; border-radius: 8px; font-weight: 600; }
.am-badge { background: rgba(26, 67, 49, 0.1); color: #1a4331; padding: 0.5rem 1rem; border-radius: 10px; font-weight: 600; }

.hover-doc { transition: all 0.2s ease; }
.hover-doc:hover { background-color: #f8fffb; border-color: #1a4331 !important; }
</style>
{% endblock %}