<!DOCTYPE html>

<title>Consommation</title>

{% block body %}
    <h1>Consommation</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ consommation.id }}</td>
            </tr>
            <tr>
                <th>Quantite</th>
                <td>{{ consommation.quantite }}</td>
            </tr>
            <tr>
                <th>DateConsommation</th>
                <td>{{ consommation.dateConsommation ? consommation.dateConsommation|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_consommation_index') }}">back to list</a>

    <a href="{{ path('app_consommation_edit', {'id': consommation.id}) }}">edit</a>

    {{ include('consommation/_delete_form.html.twig') }}
{% endblock %}
