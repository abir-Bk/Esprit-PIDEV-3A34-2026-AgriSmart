{% extends '/front/base.html.twig' %}

{% block title %}Login{% endblock %}

{% block body %}
<main class="d-flex align-items-center py-4" style="background: #ffffff; min-height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-11 col-lg-10 col-xl-9">
                <div class="card border-0 shadow-lg" style="border-radius: 20px; overflow: hidden;">
                    <div class="row g-0">
                        
                        <!-- Left Side - Animation (Larger) -->
                        <div class="col-lg-6 d-none d-lg-flex align-items-center justify-content-center p-4" 
                             style="background: linear-gradient(135deg, #1F3D2B 0%, #2a5438 100%);">
                            <div class="text-center">
                                <lottie-player 
                                    src="{{ asset('assets/images/register.json') }}"
                                    background="transparent" 
                                    speed="1" 
                                    style="width: 100%; max-width: 380px; height: auto;"
                                    loop 
                                    autoplay>
                                </lottie-player>
                                
                            </div>
                        </div>

                        <!-- Right Side - Form (Compact) -->
                        <div class="col-lg-6">
                            <div class="p-4">
                                
                                <!-- Logo -->
                                <div class="text-center text-lg-start mb-3">
                                    <a href="{{ path('app_home') }}">
                                        <img class="mb-2" src="{{ asset('assets/images/logo.png') }}" alt="logo" style="height: 45px;">
                                    </a>
                                </div>

                                <!-- Header -->
                                <div class="mb-3">
                                    <h1 class="mb-2" style="color: #1F3D2B; font-size: 26px; font-weight: 600;">Welcome back</h1>
                                    <p class="mb-0" style="color: #6c757d; font-size: 14px;">
                                        New here? 
                                        <a href="{{ path('app_register') }}" style="color: #E6BF4A; text-decoration: none; font-weight: 500;">Create an account</a>
                                    </p>
                                </div>

                                <!-- Error Message -->
                                {% if error %}
                                    <div class="alert alert-danger border-0 shadow-sm mb-3" style="border-radius: 12px; padding: 12px 16px;">
                                        <i class="fas fa-exclamation-circle me-2"></i>
                                        {{ error.messageKey|trans(error.messageData, 'security') }}
                                    </div>
                                {% endif %}
                                <!-- Login Form -->
                                <form method="post" class="mt-3">
                                                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                                    <!-- Email -->
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold mb-2" style="color: #1F3D2B; font-size: 14px;">Email Address</label>
                                        <input 
                                            type="email" 
                                            name="_username" 
                                            value="{{ last_email }}" 
                                            class="form-control" 
                                            placeholder="Enter your email"
                                            style="border: 2px solid #e9ecef; border-radius: 12px; padding: 10px 16px;"
                                            required 
                                            autofocus>
                                    </div>

                                    <!-- Password -->
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold mb-2" style="color: #1F3D2B; font-size: 14px;">Password</label>
                                        <div class="position-relative">
                                            <input 
                                                type="password" 
                                                name="_password" 
                                                class="form-control" 
                                                placeholder="Enter your password"
                                                style="border: 2px solid #e9ecef; border-radius: 12px; padding: 10px 16px; padding-right: 45px;"
                                                required>
                                            <span class="position-absolute end-0 top-50 translate-middle-y pe-3" style="cursor: pointer;">
                                                <i class="fas fa-eye-slash" style="color: #6c757d; font-size: 14px;"></i>
                                            </span>
                                        </div>
                                    </div>

                                    <!-- Remember & Forgot -->
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                
                                        <a href="{{ path('app_forgot_password_request') }}" 
                                           style="color: #E6BF4A; text-decoration: none; font-weight: 500; font-size: 13px;">
                                            Forgot password?
                                        </a>
                                    </div>
                                    <div class="mb-3 d-flex justify-content-center">
                                        <div class="g-recaptcha" data-sitekey="{{ recaptcha_site_key }}"></div>
                                    </div>  
                                                <!-- Submit Button -->
                                    <button 
                                        type="submit" 
                                        class="btn w-100 mb-3 text-white fw-semibold" 
                                        style="background: linear-gradient(135deg, #1F3D2B 0%, #2a5438 100%); 
                                               border: none; 
                                               border-radius: 12px; 
                                               padding: 12px; 
                                               transition: all 0.3s ease;
                                               font-size: 15px;">
                                        Login to Account
                                    </button>

                                    <!-- Divider -->
                                    <div class="position-relative my-3">
                                        <hr style="border-color: #e9ecef;">
                                        <span class="position-absolute top-50 start-50 translate-middle px-3 bg-white" 
                                              style="color: #6c757d; font-size: 13px;">
                                            Or continue with
                                        </span>
                                    </div>
<!-- Social Buttons -->
                                        <div class="mb-3">
                                            <a href="{{ path('connect_google_start') }}"
                                            class="btn w-100 d-flex align-items-center justify-content-center fw-semibold"
                                            style="border: 2px solid #e9ecef;
                                                    border-radius: 12px;
                                                    padding: 12px;
                                                    background: white;
                                                    color: #1F3D2B;
                                                    font-size: 15px;
                                                    height:48px;
                                                    transition: all 0.3s ease;">

                                                <i class="fab fa-google me-2" style="color:#DB4437;"></i>
                                                Google
                                            </a>
                                        </div>

                                </form>

                              
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<style>
    /* Focus states */
    .form-control:focus {
        border-color: #E6BF4A !important;
        box-shadow: 0 0 0 0.2rem rgba(230, 191, 74, 0.15) !important;
    }

    .form-check-input:checked {
        background-color: #1F3D2B !important;
        border-color: #1F3D2B !important;
    }

    /* Button hover */
    button[type="submit"]:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(31, 61, 43, 0.3) !important;
    }

    /* Social button hover */
    .btn[href="#"]:hover {
        border-color: #E6BF4A !important;
        background: #fffbf0 !important;
    }

    /* Link hover */
    a:hover {
        opacity: 0.8;
    }

    /* Card shadow */
    .card {
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1) !important;
    }

    /* Mobile responsive */
    @media (max-width: 991px) {
        .card {
            margin: 20px;
        }
    }
</style>

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    <script>
        // Password toggle
        document.querySelector('.fa-eye-slash').addEventListener('click', function() {
            const passwordInput = document.querySelector('input[name="_password"]');
            const icon = this;
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            } else {
                passwordInput.type = 'password';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            }
        });
    </script>
{% endblock %}

{% endblock %}
