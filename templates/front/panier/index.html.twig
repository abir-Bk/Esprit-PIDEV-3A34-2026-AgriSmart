{% extends 'front/base.html.twig' %}

{% block title %}Mon panier - AgriSmart{% endblock %}

{% block body %}
<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Mon panier</h1>

    {% if items|length > 0 %}
      <form method="post" action="{{ path('app_panier_clear') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('panier_clear') }}">
        <button class="btn btn-outline-danger btn-sm">
          <i class="bi bi-trash3 me-1"></i> Vider
        </button>
      </form>
    {% endif %}
  </div>

  {% if items|length == 0 %}
    <div class="alert alert-info">
      Ton panier est vide. <a href="{{ path('app_produit_index') }}">Retour à la marketplace</a>
    </div>
  {% else %}
    <div class="card shadow-sm border-0 rounded-4">
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead class="table-light">
          <tr>
            <th>Produit</th>
            <th class="text-center">Qté</th>
            <th class="text-end">Prix unitaire</th>
            <th class="text-end">Total</th>
            <th class="text-end">Actions</th>
          </tr>
          </thead>

          <tbody>
          {% for row in items %}
            <tr>
              <td style="min-width:320px">
                <div class="d-flex align-items-center gap-3">
                  <img src="{{ asset(row.produit.image ?: 'assets/images/placeholder-product.png') }}"
                       style="width:64px;height:52px;object-fit:cover"
                       class="rounded-3 border" alt="">
                  <div>
                    <div class="fw-bold">{{ row.produit.nom }}</div>
                    <div class="small text-muted">{{ row.produit.categorie }}</div>
                  </div>
                </div>
              </td>

              <td class="text-center fw-semibold">{{ row.qty }}</td>

              {# ✅ FIX: c’est unitPrice pas unit #}
              <td class="text-end">{{ row.unitPrice }} TND</td>
              <td class="text-end fw-bold">{{ row.lineTotal }} TND</td>

              <td class="text-end">
                <div class="d-inline-flex gap-2">
                  <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_panier_remove', {id: row.produit.id}) }}" title="Retirer 1">
                    <i class="bi bi-dash"></i>
                  </a>
                  <a class="btn btn-sm btn-outline-success" href="{{ path('app_panier_add', {id: row.produit.id}) }}" title="Ajouter 1">
                    <i class="bi bi-plus"></i>
                  </a>
                  <a class="btn btn-sm btn-outline-danger" href="{{ path('app_panier_remove_all', {id: row.produit.id}) }}" title="Supprimer">
                    <i class="bi bi-trash"></i>
                  </a>
                </div>
              </td>
            </tr>
          {% endfor %}
          </tbody>
        </table>
      </div>

      <div class="card-body d-flex justify-content-between align-items-center border-top">
        <div class="text-muted">
          Articles: <strong>{{ totalQty }}</strong>
        </div>
        <div class="fs-5">
          Total: <strong>{{ total }} TND</strong>
        </div>
      </div>
    </div>

    <div class="d-flex justify-content-end mt-3 gap-2">
      <a href="{{ path('app_produit_index') }}" class="btn btn-outline-secondary rounded-pill">
        Continuer les achats
      </a>
      <a href="#" class="btn btn-success rounded-pill disabled">
        Passer commande (bientôt)
      </a>
    </div>
  {% endif %}
</div>
{% endblock %}
