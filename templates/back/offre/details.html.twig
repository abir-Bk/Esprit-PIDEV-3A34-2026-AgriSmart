{% extends 'back/admin_base.html.twig' %}

{% block title %}Détails offre - {{ offre.title }}{% endblock %}

{% block body %}
<div class="d-flex">
    {% include 'back/components/sidebar.html.twig' %}
    <div class="flex-grow-1 p-4 am-content">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show am-alert" role="alert">{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        <div class="mb-4 d-flex flex-wrap justify-content-between align-items-center gap-3">
            <a href="{{ path('app_offre_index_front') }}" class="btn am-btn-outline">
                <i class="fa-solid fa-arrow-left me-1"></i>Retour aux offres
            </a>
            <a href="{{ path('app_offre_show', {id: offre.id}) }}" target="_blank" class="btn am-btn-success">
                <i class="fa-solid fa-eye me-2"></i>Voir l'offre (public)
            </a>
        </div>

        {% set validation = offre.statutValidation|default('en_attente') %}
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card border-0 am-card h-100">
                    <div class="card-header am-card-header py-3 border-0">
                        <h5 class="mb-0 fw-semibold am-title"><i class="fa-solid fa-file-lines me-2"></i>Détails de l'offre</h5>
                    </div>
                    <div class="card-body p-4">
                        <h4 class="am-text fw-bold mb-2">{{ offre.title }}</h4>
                        <span class="badge am-badge mb-3">{{ offre.typeContrat|default('CDI') }}</span>
                        <div class="d-flex align-items-center text-muted mb-3">
                            <i class="fa-solid fa-location-dot me-2 am-text-muted"></i>{{ offre.lieu|default('—') }}
                        </div>
                        <div class="am-info-box p-3 rounded-3 mb-3">
                            <div class="row g-2">
                                <div class="col-6">
                                    <small class="text-muted d-block">Salaire</small>
                                    <span class="fw-bold am-text">{{ offre.salaire ? (offre.salaire|number_format(0, ',', ' ') ~ ' DT') : '—' }}</span>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted d-block">Validation</small>
                                    {% if validation == 'approuvée' %}
                                        <span class="badge am-badge-success">Approuvée</span>
                                    {% elseif validation == 'refusée' %}
                                        <span class="badge am-badge-danger">Refusée</span>
                                    {% else %}
                                        <span class="badge am-badge-warning">En attente</span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                        <div class="bg-light p-3 rounded-3 mb-3">
                            <h6 class="fw-bold am-text mb-2"><i class="fa-solid fa-align-left me-2"></i>Description</h6>
                            <div class="text-dark small">{{ offre.description|nl2br }}</div>
                        </div>

                        <div class="mt-3">
                            <a href="{{ path('app_offre_edit', {id: offre.id}) }}" class="btn am-btn-outline w-100"><i class="fa-solid fa-pencil me-2"></i>Modifier</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="card border-0 am-card h-100">
                    <div class="card-header am-card-header-light py-3 border-0">
                        <h5 class="mb-0 fw-semibold am-text"><i class="fa-solid fa-users me-2"></i>Candidatures ({{ demandes|length }})</h5>
                    </div>
                    <div class="card-body p-0">
                        {% if demandes|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 am-table">
                                <thead>
                                    <tr>
                                        <th class="am-th">Candidat</th>
                                        <th class="am-th">Date</th>
                                        <th class="am-th">Statut</th>
                                        <th class="am-th text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for demande in demandes %}
                                    <tr>
                                        <td class="py-3">
                                            <div class="fw-bold am-text">{{ demande.nom }} {{ demande.prenom }}</div>
                                            <small class="text-muted">{% if demande.phoneNumber %}{{ demande.phoneNumber }}{% else %}—{% endif %}</small>
                                        </td>
                                        <td class="py-3">{{ demande.datePostulation|date('d/m/Y H:i') }}</td>
                                        <td class="py-3">
                                            {% set ds = demande.statut|lower %}
                                            {% if ds == 'acceptée' %}<span class="badge am-badge-success">{{ demande.statut }}</span>
                                            {% elseif ds == 'refusée' %}<span class="badge am-badge-danger">{{ demande.statut }}</span>
                                            {% else %}<span class="badge am-badge-warning">{{ demande.statut }}</span>{% endif %}
                                        </td>
                                        <td class="py-3 text-end">
                                            <a href="{{ path('app_admin_demande_details', {id: demande.id}) }}" class="btn btn-sm am-btn-outline">Voir</a>
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        {% else %}
                        <div class="text-center py-5 text-muted">
                            <i class="fa-solid fa-inbox fa-2x mb-2 d-block"></i>
                            Aucune candidature.
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<style>
.am-content { background: #f8f9fa; }
.am-title, .am-text { color: #1a4331; }
.am-text-muted { color: #6c757d; }
.am-card { box-shadow: 0 2px 12px rgba(26, 67, 49, 0.06); border-radius: 12px; }
.am-card-header { background: linear-gradient(135deg, #1a4331 0%, #2d5a3d 100%); color: #fff; border-radius: 12px 12px 0 0; }
.am-card-header-light { background: rgba(26, 67, 49, 0.06); border-radius: 12px 12px 0 0; }
.am-info-box { background: rgba(26, 67, 49, 0.06); }
.am-th { color: #1a4331; font-weight: 600; padding: 0.75rem 1rem; border-bottom: 1px solid #e2e8e6; }
.am-table tbody tr { border-bottom: 1px solid #f0f0f0; }
.am-badge { background: rgba(26, 67, 49, 0.1); color: #1a4331; padding: 0.35rem 0.65rem; border-radius: 8px; font-weight: 500; }
.am-badge-success { background: rgba(40, 167, 69, 0.12); color: #28a745; padding: 0.35rem 0.65rem; border-radius: 8px; }
.am-badge-warning { background: rgba(230, 191, 74, 0.2); color: #b8860b; padding: 0.35rem 0.65rem; border-radius: 8px; }
.am-badge-danger { background: rgba(220, 53, 69, 0.12); color: #dc3545; padding: 0.35rem 0.65rem; border-radius: 8px; }
.am-btn-outline { border: 1px solid #1a4331; color: #1a4331; border-radius: 8px; }
.am-btn-outline:hover { background: #1a4331; color: #fff; }
.am-btn-success { background: #28a745; color: #fff; border: none; border-radius: 8px; }
.am-btn-success:hover { background: #218838; color: #fff; }
.am-btn-danger { background: #dc3545; color: #fff; border: none; border-radius: 8px; }
.am-btn-danger:hover { background: #c82333; color: #fff; }
.am-alert { border-radius: 12px; }
</style>
{% endblock %}
