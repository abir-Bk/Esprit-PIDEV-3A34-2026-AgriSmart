{% extends 'back/admin_base.html.twig' %}

{% block title %}Mes offres - AgriSmart{% endblock %}

{% block body %}
<div class="d-flex">
    {% include 'back/components/sidebar.html.twig' %}
    <div class="flex-grow-1 p-4 am-content">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
            <div>
                <h1 class="h3 am-title mb-1"><i class="fa-solid fa-briefcase me-2"></i>Mes offres d'emploi</h1>
                <p class="text-muted small mb-0">Gérez vos offres et suivez les candidatures.</p>
            </div>
            <a href="{{ path('app_offre_new') }}" class="btn am-btn-success">
                <i class="fa-solid fa-plus me-2"></i>Nouvelle offre
            </a>
        </div>

        {% set count_attente = 0 %}
        {% set count_approuvee = 0 %}
        {% for o in offres %}
            {% if o.statutValidation|default('en_attente') == 'en_attente' %}{% set count_attente = count_attente + 1 %}{% endif %}
            {% if o.statutValidation|default('en_attente') == 'approuvée' %}{% set count_approuvee = count_approuvee + 1 %}{% endif %}
        {% endfor %}
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card border-0 am-card h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="am-icon-wrap am-icon-success me-3"><i class="fa-solid fa-briefcase"></i></div>
                        <div><span class="text-muted small d-block">Total</span><span class="fw-bold fs-4 am-text">{{ offres|length }}</span></div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 am-card h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="am-icon-wrap am-icon-warning me-3"><i class="fa-solid fa-clock"></i></div>
                        <div><span class="text-muted small d-block">En attente</span><span class="fw-bold fs-4 am-text">{{ count_attente }}</span></div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 am-card h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="am-icon-wrap am-icon-success me-3"><i class="fa-solid fa-check"></i></div>
                        <div><span class="text-muted small d-block">Approuvées</span><span class="fw-bold fs-4 am-text-success">{{ count_approuvee }}</span></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 am-card mb-4">
            <div class="card-body p-4">
                <div class="row g-3 align-items-center">
                    <div class="col-md-8">
                        <div class="input-group am-input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-search am-text-muted"></i></span>
                            <input id="offreSearchInput" class="form-control border-start-0" type="search" placeholder="Rechercher par titre ou lieu..." aria-label="Recherche">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <select id="filterContract" class="form-select am-select">
                            <option value="">Tous les contrats</option>
                            <option value="cdi">CDI</option>
                            <option value="cdd">CDD</option>
                            <option value="stage">Stage</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        {% if offres is empty %}
        <div class="text-center py-5 my-4">
            <div class="card border-0 am-card py-5">
                <i class="fa-solid fa-briefcase fa-2x am-text-muted mb-3 d-block"></i>
                <h5 class="am-text mb-2">Aucune offre</h5>
                <p class="text-muted mb-4">Créez votre première offre d'emploi.</p>
                <a href="{{ path('app_offre_new') }}" class="btn am-btn-success"><i class="fa-solid fa-plus me-1"></i>Créer une offre</a>
            </div>
        </div>
        {% else %}
        <div class="row g-4" id="offreList">
            {% for offre in offres %}
            {% set validation = offre.statutValidation|default('en_attente') %}
            <div class="col-md-6 col-lg-4 col-xl-3 offre-card"
                 data-title="{{ offre.title|lower }}"
                 data-lieu="{{ offre.lieu|default('')|lower }}"
                 data-contrat="{{ offre.typeContrat|default('')|lower }}">
                <div class="card h-100 border-0 am-card am-card-hover">
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge am-badge">{{ offre.typeContrat|default('CDI') }}</span>
                            {% if validation == 'approuvée' %}
                                <span class="badge am-badge-success small">Approuvée</span>
                            {% elseif validation == 'refusée' %}
                                <span class="badge am-badge-danger small">Refusée</span>
                            {% else %}
                                <span class="badge am-badge-warning small">En attente</span>
                            {% endif %}
                        </div>
                        <h6 class="card-title fw-bold mb-2 am-text offre-title">{{ offre.title }}</h6>
                        <div class="mb-2 small text-muted"><i class="fa-solid fa-location-dot me-1"></i>{{ offre.lieu|default('—') }}</div>
                        <div class="mb-3 fw-semibold am-text">
                            {% if offre.salaire %}{{ offre.salaire|number_format(0, ',', ' ') }} DT{% else %}—{% endif %}
                        </div>
                        {% if offre.demandes is defined %}<div class="mb-3 small text-muted"><i class="fa-solid fa-users me-1"></i>{{ offre.demandes|length }} candidature(s)</div>{% endif %}
                        <div class="mt-auto pt-3 border-top">
                            <a href="{{ path('app_admin_offre_details', {id: offre.id}) }}" class="btn am-btn-success w-100"><i class="fa-solid fa-eye me-2"></i>Voir l'offre</a>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    var searchInput = document.getElementById('offreSearchInput');
    var filterContract = document.getElementById('filterContract');
    var cards = document.querySelectorAll('.offre-card');
    function filterCards() {
        var search = (searchInput && searchInput.value) ? searchInput.value.toLowerCase().trim() : '';
        var contrat = (filterContract && filterContract.value) ? filterContract.value.toLowerCase() : '';
        cards.forEach(function(card) {
            var title = (card.dataset.title || '');
            var lieu = (card.dataset.lieu || '');
            var c = (card.dataset.contrat || '').toLowerCase();
            var matchSearch = !search || title.indexOf(search) !== -1 || lieu.indexOf(search) !== -1;
            var matchContrat = !contrat || c.indexOf(contrat) !== -1;
            card.style.display = (matchSearch && matchContrat) ? '' : 'none';
        });
    }
    if (searchInput) searchInput.addEventListener('input', filterCards);
    if (filterContract) filterContract.addEventListener('change', filterCards);
});
</script>

<style>
.am-content { background: #f8f9fa; }
.am-title, .am-text { color: #1a4331; }
.am-text-muted { color: #6c757d; }
.am-text-success { color: #28a745; }
.am-card { box-shadow: 0 2px 12px rgba(26, 67, 49, 0.06); border-radius: 12px; }
.am-card-hover:hover { box-shadow: 0 8px 24px rgba(26, 67, 49, 0.1); transform: translateY(-2px); transition: all 0.2s ease; }
.am-icon-wrap { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; }
.am-icon-success { background: rgba(40, 167, 69, 0.12); color: #28a745; }
.am-icon-warning { background: rgba(230, 191, 74, 0.2); color: #b8860b; }
.am-input-group .form-control:focus { border-color: #E6BF4A; box-shadow: 0 0 0 0.2rem rgba(230, 191, 74, 0.2); }
.am-select { border-radius: 10px; border: 1px solid #e2e8e6; }
.am-select:focus { border-color: #E6BF4A; }
.am-badge { background: rgba(26, 67, 49, 0.1); color: #1a4331; padding: 0.35rem 0.65rem; border-radius: 8px; font-weight: 500; }
.am-badge-success { background: rgba(40, 167, 69, 0.12); color: #28a745; padding: 0.35rem 0.65rem; border-radius: 8px; }
.am-badge-warning { background: rgba(230, 191, 74, 0.2); color: #b8860b; padding: 0.35rem 0.65rem; border-radius: 8px; }
.am-badge-danger { background: rgba(220, 53, 69, 0.12); color: #dc3545; padding: 0.35rem 0.65rem; border-radius: 8px; }
.am-btn-success { background: #28a745; color: #fff; border: none; border-radius: 8px; }
.am-btn-success:hover { background: #218838; color: #fff; }
</style>
{% endblock %}