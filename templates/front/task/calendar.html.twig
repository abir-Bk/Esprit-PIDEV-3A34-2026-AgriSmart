{% extends 'front/task/layout.html.twig' %}

{% block title %}Calendrier des tâches - AgriSmart{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css" rel="stylesheet">
    <style>
        :root {
            --fc-border-color: #eee;
            --fc-daygrid-event-dot-width: 8px;
            --fc-today-bg-color: rgba(26, 67, 49, 0.05);
            --fc-button-bg-color: var(--ag-primary);
            --fc-button-border-color: var(--ag-primary);
            --fc-button-hover-bg-color: #143527;
            --fc-button-hover-border-color: #143527;
            --fc-button-active-bg-color: #0d251b;
            --fc-button-active-border-color: #0d251b;
        }

        .calendar-wrapper {
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 1.5rem;
            align-items: start;
        }

        @media (max-width: 991px) {
            .calendar-wrapper {
                grid-template-columns: 1fr;
            }
        }

        .calendar-sidebar {
            position: sticky;
            top: 2rem;
        }

        #task-calendar {
            background: #fff;
            padding: 1.5rem;
            border-radius: 1rem;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        /* FullCalendar Customization */
        .fc {
            font-family: inherit;
        }

        .fc .fc-toolbar-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--ag-text);
        }

        .fc .fc-button {
            border-radius: 2rem;
            text-transform: capitalize;
            font-weight: 500;
            padding: 0.4rem 1.2rem;
            font-size: 0.85rem;
            transition: all 0.2s ease;
        }

        .fc .fc-button-primary:not(:disabled).fc-button-active, 
        .fc .fc-button-primary:not(:disabled):active {
            background-color: var(--ag-primary);
            border-color: var(--ag-primary);
        }

        .fc-theme-standard td, .fc-theme-standard th {
            border-color: #f0f0f0;
        }

        .fc-col-header-cell {
            padding: 1rem 0 !important;
            background: #f8f9fa;
            font-weight: 600;
            color: #666;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .fc-daygrid-day-number {
            font-weight: 500;
            color: #444;
            padding: 8px !important;
        }

        .fc-v-event {
            border-radius: 6px;
            border: none;
            padding: 2px 4px;
        }

        .fc-h-event {
            border-radius: 4px;
            border: none;
            padding: 1px 4px;
        }

        .ag-calendar-google-event {
            box-shadow: 0 2px 4px rgba(219, 68, 55, 0.2);
        }

        .legend-card {
            background: #fff;
            border-radius: 1rem;
            padding: 1.5rem;
            border: 1px solid rgba(0, 0, 0, 0.05);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1rem;
            padding: 0.5rem;
            border-radius: 0.5rem;
            transition: background 0.2s;
        }

        .legend-item:hover {
            background: #f8f9fa;
        }

        .legend-color {
            width: 12px;
            height: 12px;
            border-radius: 3px;
            flex-shrink: 0;
        }

        .sync-card {
            background: linear-gradient(135deg, #1A4331 0%, #2d6e52 100%);
            color: #fff;
            border-radius: 1rem;
            padding: 1.5rem;
            margin-top: 1.5rem;
        }

        .btn-copy-link {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: #fff;
            width: 100%;
            text-align: left;
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: all 0.2s;
        }

        .btn-copy-link:hover {
            background: rgba(255, 255, 255, 0.2);
            color: #fff;
        }
    </style>
{% endblock %}

{% block task_content %}
<div class="container-fluid px-md-4 py-4">
    <!-- Header -->
    <div class="row align-items-end mb-4">
        <div class="col-md-8">
            <h2 class="h3 fw-bold mb-1" style="color: var(--ag-text);">Calendrier de Production</h2>
            <p class="text-muted mb-0">Gérez le planning des cultures et les interventions de l'équipe.</p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <a href="{{ path('tasks_new') }}" class="btn ag-btn-primary text-white rounded-pill px-4">
                <i class="bi bi-plus-lg me-2"></i>Nouvelle Intervention
            </a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="calendar-wrapper">
        <!-- Sidebar -->
        <aside class="calendar-sidebar">
            <div class="legend-card">
                <h6 class="fw-bold mb-3">Sources de données</h6>
                <div class="legend-item">
                    <div class="legend-color" style="background-color: var(--ag-primary);"></div>
                    <div>
                        <div class="fw-semibold small">AgriSmart Tasks</div>
                        <div class="text-muted" style="font-size: 0.75rem;">Planning interne</div>
                    </div>
                </div>
                <div class="legend-item">
                    <div class="legend-color" style="background-color: #DB4437;"></div>
                    <div>
                        <div class="fw-semibold small">Google Calendar</div>
                        <div class="text-muted" style="font-size: 0.75rem;">Événements externes</div>
                    </div>
                </div>

                <hr class="my-4 opacity-50">

                <h6 class="fw-bold mb-3">Outils</h6>
                <a href="{{ path('tasks_index') }}" class="btn btn-light w-100 text-start mb-2 rounded-3 py-2">
                    <i class="bi bi-list-task me-2"></i>Vue Liste
                </a>
                <a href="{{ path('tasks_dashboard') }}" class="btn btn-light w-100 text-start rounded-3 py-2">
                    <i class="bi bi-grid-1x2 me-2"></i>Tableau de bord
                </a>
            </div>

            <div class="sync-card">
                <h6 class="fw-bold mb-2">Synchronisation mobile</h6>
                <p class="small opacity-75 mb-3">Ajoutez ce planning à votre téléphone via Google Calendar.</p>
                <button id="btn-copy-ical" class="btn-copy-link" data-url="{{ url('tasks_export_ical') }}">
                    <span>Copier le lien iCal</span>
                    <i class="bi bi-clipboard"></i>
                </button>
            </div>
        </aside>

        <!-- Calendar Area -->
        <main class="calendar-main">
            <div id="task-calendar"></div>
        </main>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@fullcalendar/google-calendar@6.1.10/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@fullcalendar/core/locales/fr.global.min.js"></script>
    <script>
        (function() {
            function initCalendar() {
                const calendarEl = document.getElementById('task-calendar');
                if (!calendarEl || calendarEl.dataset.initialized) return;

                const eventsData = {{ events|json_encode|raw }};
                const GOOGLE_API_KEY = '{{ google_api_key }}';
                const PROJECT_CALENDAR_ID = '{{ google_calendar_id }}';

                const calendar = new FullCalendar.Calendar(calendarEl, {
                    initialView: 'dayGridMonth',
                    locale: 'fr',
                    googleCalendarApiKey: GOOGLE_API_KEY,
                    headerToolbar: {
                        left: 'prev,next today',
                        center: 'title',
                        right: 'dayGridMonth,timeGridWeek,listWeek'
                    },
                    buttonText: {
                        today: 'Aujourd\'hui',
                        month: 'Mois',
                        week: 'Semaine',
                        list: 'Planning'
                    },
                    eventSources: [
                        {
                            events: eventsData,
                            id: 'local_tasks',
                            color: '#1A4331',
                            textColor: '#ffffff'
                        },
                        {
                            googleCalendarId: PROJECT_CALENDAR_ID,
                            id: 'google_project_tasks',
                            className: 'ag-calendar-google-event',
                            color: '#DB4437'
                        }
                    ],
                    eventClick: function(info) {
                        if (info.event.url && !info.event.url.includes('google.com')) {
                            info.jsEvent.preventDefault();
                            window.location.href = info.event.url;
                        }
                    },
                    height: 'auto',
                    dayMaxEvents: 3,
                    eventTimeFormat: {
                        hour: '2-digit',
                        minute: '2-digit',
                        meridiem: false
                    }
                });

                calendar.render();
                calendarEl.dataset.initialized = "true";
            }

            // Sync with Turbo and standard load
            document.addEventListener('turbo:load', () => {
                const el = document.getElementById('task-calendar');
                if (el) delete el.dataset.initialized;
                initCalendar();
            });
            document.addEventListener('DOMContentLoaded', initCalendar);
            if (document.readyState === 'complete') initCalendar();

            // iCal Copy Link
            document.addEventListener('click', function(e) {
                if (e.target.closest('#btn-copy-ical')) {
                    const btn = e.target.closest('#btn-copy-ical');
                    const url = btn.dataset.url;
                    navigator.clipboard.writeText(url).then(() => {
                        const originalContent = btn.innerHTML;
                        btn.innerHTML = '<span>Lien copié !</span><i class="bi bi-check2"></i>';
                        btn.classList.add('bg-success');
                        setTimeout(() => {
                            btn.innerHTML = originalContent;
                            btn.classList.remove('bg-success');
                        }, 3000);
                    });
                }
            });
        })();
    </script>
{% endblock %}
