{% extends 'front/base.html.twig' %}

{% block title %}Offres d'emploi | AgriSmart{% endblock %}

{% block body %}
<style>
/* =========================
   Candidature : même design que Marketplace (AgriSmart)
   ========================= */
.ag-candidature {
  --ag-primary: #1A4331;
  --ag-primary-2: #2E7D32;
  --ag-accent: #F4B400;
  --ag-cream: #FBF7EE;
  --ag-bg: #F6F8F7;
  --ag-text: #111827;
  --ag-muted: #6B7280;
  --ag-border: #E5E7EB;
}
.ag-candidature .ag-title { font-size: clamp(2.0rem, 4vw, 3.0rem) !important; line-height: 1.05 !important; letter-spacing: -0.02em; color: var(--ag-text); margin: 0; }
.ag-candidature .ag-subtitle { font-size: 1.05rem !important; color: var(--ag-muted) !important; margin: .75rem 0 0 0; }
.ag-candidature .ag-hero {
  background:
    radial-gradient(900px 420px at 18% 25%, rgba(46,125,50,.16), transparent 60%),
    radial-gradient(700px 320px at 85% 10%, rgba(244,180,0,.14), transparent 55%),
    linear-gradient(180deg, var(--ag-cream), #ffffff);
  border-bottom: 1px solid rgba(17,24,39,.06);
  padding: 3rem 0 2rem;
}
.ag-candidature .ag-btn-primary { background: var(--ag-primary) !important; border: none !important; color: #fff !important; }
.ag-candidature .ag-btn-primary:hover { background: #163828 !important; color: #fff !important; }
.ag-candidature .ag-content { background: var(--ag-bg); padding: 2rem 0 3rem; }
.ag-candidature .ag-card {
  border: 1px solid rgba(17,24,39,.06);
  border-radius: 20px;
  background: #fff;
  transition: .18s;
  height: 100%;
}
.ag-candidature .ag-card:hover { transform: translateY(-2px); box-shadow: 0 .9rem 1.6rem rgba(0,0,0,.08); }
.ag-candidature .ag-input { border-radius: 14px !important; border: 1px solid var(--ag-border) !important; }
.ag-candidature .ag-input:focus { border-color: rgba(26,67,49,.45) !important; box-shadow: 0 0 0 .25rem rgba(26,67,49,.12) !important; }
.ag-candidature .ag-filter-card { border: 1px solid rgba(17,24,39,.06) !important; border-radius: 20px !important; }
.ag-candidature .ag-hero-ornament {
  width: min(420px, 100%);
  height: 170px;
  border-radius: 26px;
  background:
    radial-gradient(120px 120px at 25% 60%, rgba(46,125,50,.18), transparent 60%),
    radial-gradient(140px 140px at 65% 35%, rgba(244,180,0,.18), transparent 60%),
    linear-gradient(135deg, rgba(26,67,49,.10), rgba(46,125,50,.06));
  border: 1px solid rgba(17,24,39,.06);
}
</style>

<div class="ag-candidature">
  <section class="ag-hero">
    <div class="container">
      <div class="row align-items-center g-4">
        <div class="col-lg-7">
          <h1 class="ag-title">Offres d'emploi</h1>
          <p class="ag-subtitle">
            Consultez les <strong>offres d'emploi agricole</strong> et postulez en quelques clics.
          </p>
          <div class="d-flex flex-wrap gap-2 mt-4">
            {% if app.user and (app.user.role == 'agriculteur' or app.user.role == 'admin') %}
              <a href="{{ path('app_admin_offres') }}" class="btn btn-outline-dark rounded-pill">
                <i class="bi bi-list-ul me-2"></i>Mes offres
              </a>
              <a href="{{ path('app_offre_new') }}" class="btn ag-btn-primary text-white rounded-pill">
                <i class="bi bi-plus-circle me-2"></i>Publier une offre
              </a>
            {% endif %}
            <a href="{{ path('app_my_demandes') }}" class="btn btn-outline-secondary rounded-pill">
              <i class="bi bi-person-badge me-2"></i>Mes candidatures
            </a>
          </div>
        </div>
        <div class="col-lg-5 d-flex justify-content-lg-end">
          <div class="ag-hero-ornament w-100"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="ag-content">
    <div class="container">
      {# Filtres (même style que marketplace) #}
      <div class="row mb-4">
        <div class="col-12">
          <div class="card ag-filter-card shadow-sm p-4">
            <form method="get" action="{{ path('app_offre_index_front') }}" class="row g-3 align-items-end" id="formOffres">
              <div class="col-md-5">
                <label class="form-label fw-bold small text-uppercase" style="color: var(--ag-muted);">Recherche</label>
                <input type="text" id="searchInput" name="search" class="form-control ag-input" placeholder="Titre, lieu..." value="{{ app.request.query.get('search') }}">
              </div>
              <div class="col-md-4">
                <label class="form-label fw-bold small text-uppercase" style="color: var(--ag-muted);">Statut</label>
                <select id="statusFilter" name="status" class="form-select ag-input">
                  <option value="">Toutes les offres</option>
                  <option value="ouvert" {{ app.request.query.get('status') == 'ouvert' ? 'selected' : '' }}>Offres ouvertes</option>
                  <option value="clôturée" {{ app.request.query.get('status') == 'clôturée' ? 'selected' : '' }}>Offres clôturées</option>
                </select>
              </div>
              <div class="col-md-3">
                <button type="submit" class="btn ag-btn-primary text-white rounded-pill w-100">
                  <i class="bi bi-search me-1"></i>Rechercher
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>

      {# Stats rapide #}
      {% set ouvertCount = 0 %}
      {% for o in offres %}
        {% if o.statut is defined and o.statut|lower == 'ouvert' %}{% set ouvertCount = ouvertCount + 1 %}{% endif %}
      {% endfor %}
      <p class="text-muted small mb-3">
        <strong>{{ offres|length }}</strong> offre(s) · <strong>{{ ouvertCount }}</strong> ouverte(s)
      </p>

      {# Grille des offres #}
      <div class="row g-4" id="offresGrid">
        {% for offre in offres %}
          {% set totalCand = offre.demandes|length %}
          <div class="col-sm-6 col-xl-4 offre-item"
               data-statut="{{ offre.statut|lower }}"
               data-titre="{{ offre.title|lower }}"
               data-lieu="{{ offre.lieu|lower }}">
            <div class="ag-card">
              <div class="p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                  <span class="badge rounded-pill {{ offre.statut|lower == 'ouvert' ? 'bg-success' : 'bg-secondary' }}">
                    {{ offre.statut }}
                  </span>
                  <div class="text-end">
                    <div class="fw-bold" style="color: var(--ag-primary);">
                      {{ offre.salaire ? offre.salaire|number_format(0, ',', ' ') ~ ' TND' : 'À négocier' }}
                    </div>
                    <small class="text-muted">mensuel</small>
                  </div>
                </div>
                <h3 class="h6 fw-bold mb-2" style="color: var(--ag-text);">{{ offre.title }}</h3>
                <p class="small mb-3" style="color: var(--ag-muted);">
                  <i class="bi bi-geo-alt me-1"></i>{{ offre.lieu }}
                </p>
                <div class="row g-2 small mb-3">
                  <div class="col-6">
                    <span class="text-muted d-block">Début</span>
                    <span style="color: var(--ag-text);">{{ offre.dateDebut ? offre.dateDebut|date('d/m/Y') : '—' }}</span>
                  </div>
                  <div class="col-6">
                    <span class="text-muted d-block">Fin</span>
                    <span style="color: var(--ag-text);">{{ offre.dateFin ? offre.dateFin|date('d/m/Y') : '—' }}</span>
                  </div>
                </div>
                <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                  <span class="small text-muted">
                    <i class="bi bi-people me-1"></i>{{ totalCand }} candidature(s)
                  </span>
                  <a href="{{ path('app_offre_show', {'id': offre.id}) }}" class="btn btn-sm ag-btn-primary text-white rounded-pill">
                    <i class="bi bi-eye me-1"></i>Voir
                  </a>
                </div>
              </div>
            </div>
          </div>
        {% else %}
          <div class="col-12">
            <div class="text-center py-5 bg-white rounded-4 border shadow-sm">
              <i class="bi bi-briefcase display-5 text-muted"></i>
              <h4 class="mt-3">Aucune offre d'emploi</h4>
              <p class="text-muted mb-4">Aucune offre disponible pour le moment.</p>
              {% if app.user and (app.user.role == 'agriculteur' or app.user.role == 'admin') %}
                <a href="{{ path('app_offre_new') }}" class="btn ag-btn-primary text-white rounded-pill">
                  <i class="bi bi-plus-circle me-1"></i>Publier une offre
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var searchInput = document.getElementById('searchInput');
  var statusFilter = document.getElementById('statusFilter');
  var items = document.querySelectorAll('.offre-item');
  if (!searchInput || !items.length) return;
  function filter() {
    var query = (searchInput.value || '').toLowerCase().trim();
    var status = (statusFilter ? statusFilter.value || '' : '').toLowerCase();
    items.forEach(function(item) {
      var title = (item.dataset.titre || '');
      var location = (item.dataset.lieu || '');
      var itemStatus = (item.dataset.statut || '');
      var matchSearch = !query || title.indexOf(query) !== -1 || location.indexOf(query) !== -1;
      var matchStatus = !status || itemStatus === status;
      item.style.display = (matchSearch && matchStatus) ? 'block' : 'none';
    });
  }
  searchInput.addEventListener('input', filter);
  if (statusFilter) statusFilter.addEventListener('change', filter);
});
</script>
{% endblock %}
