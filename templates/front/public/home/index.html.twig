		.solution-card .card-text { color: var(--ag-muted); font-size: 0.9rem; line-height: 1.55; margin-bottom: 1rem; }
		.solution-card .btn-card { font-weight: 600; font-size: 0.9rem; padding: 0.5rem 1.25rem; border-radius: 999px; background: var(--ag-primary); border: none; color: #fff; transition: background 0.2s; }
