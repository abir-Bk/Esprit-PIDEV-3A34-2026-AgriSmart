{% extends 'back/admin_base.html.twig' %}

{% block title %}Détails utilisateur - {{ user.firstName }} {{ user.lastName }} - AgriSmart{% endblock %}

{% block body %}
<!-- Contenu de la page START -->
    {% include 'back/components/sidebar.html.twig' %}

    <!-- Contenu principal START -->
    <div class="page-content-wrapper p-xxl-4">

        <!-- Messages flash -->
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
            </div>
        {% endfor %}

        <!-- Titre et bouton retour -->
        <div class="row">
            <div class="col-12 mb-4 mb-sm-5">
                <div class="d-sm-flex justify-content-between align-items-center">
                    <div>
                        <a href="{{ path('admin_users') }}" class="btn btn-link text-secondary mb-0 p-0">
                            <i class="bi bi-arrow-left me-2"></i>Retour à la liste
                        </a>
                        <h1 class="h3 mb-0 mt-2">Détails de l'utilisateur</h1>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Colonne gauche : carte profil -->
            <div class="col-lg-4">
                <div class="card shadow">
                    <div class="card-body text-center">
                        <!-- Avatar -->
                        <div class="avatar avatar-xxl mb-3 mx-auto">
                            {% if user.image %}
                            <img class="avatar-img rounded-circle" src="{{ asset('uploads/users/images/' ~ user.image) }}" alt="avatar">
                            {% else %}
                            <div class="avatar-img rounded-circle text-white d-flex align-items-center justify-content-center" style="font-size: 3rem;background: linear-gradient(135deg, #1F3D2B, #2d9c5a);">
                                {{ user.firstName|slice(0, 1)|upper }}{{ user.lastName|slice(0, 1)|upper }}
                            </div>
                            {% endif %}
                        </div>

                        <!-- Nom -->
                        <h4 class="mb-1">{{ user.firstName }} {{ user.lastName }}</h4>
                        <p class="text-muted mb-3">{{ user.email }}</p>

                        <!-- Badge statut -->
                        <div class="mb-3">
                            <span class="badge 
                                {% if user.status == 'active' %}
                                    bg-success bg-opacity-10 text-success
                                {% elseif user.status == 'pending' %}
                                    bg-warning bg-opacity-10 text-warning
                                {% else %}
                                    bg-danger bg-opacity-10 text-danger
                                {% endif %} 
                                px-3 py-2">
                                <i class="bi 
                                    {% if user.status == 'active' %}bi-check-circle
                                    {% elseif user.status == 'pending' %}bi-clock
                                    {% else %}bi-x-circle{% endif %} me-1"></i>
                                {% if user.status == 'active' %}Actif
                                {% elseif user.status == 'pending' %}En attente
                                {% else %}Désactivé{% endif %}
                            </span>
                        </div>

                        <!-- Badge rôle -->
                        <div class="mb-3">
                            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2">
                                <i class="bi bi-person-badge me-1"></i>
                                {% if user.role == 'admin' %}Administrateur
                                {% elseif user.role == 'employee' %}Employé
                                {% elseif user.role == 'agriculteur' %}Agriculteur
                                {% elseif user.role == 'fournisseur' %}Fournisseur
                                {% else %}{{ user.role|capitalize }}{% endif %}
                            </span>
                        </div>

                        <hr>

                        <!-- Actions rapides -->
                        <div class="d-grid gap-2">
                            <div class="dropdown">
                                <button class="btn btn-sm btn-light dropdown-toggle w-100" type="button" id="statusChangeDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-gear me-2"></i>Changer le statut
                                </button>
                                <ul class="dropdown-menu w-100" aria-labelledby="statusChangeDropdown">
                                    <li>
                                        <a class="dropdown-item" href="{{ path('admin_user_status', {'id': user.id, 'status': 'active'}) }}">
                                            <i class="bi bi-check-circle text-success me-2"></i>Définir comme Actif
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="{{ path('admin_user_status', {'id': user.id, 'status': 'pending'}) }}">
                                            <i class="bi bi-clock text-warning me-2"></i>Définir comme En attente
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="{{ path('admin_user_status', {'id': user.id, 'status': 'disabled'}) }}">
                                            <i class="bi bi-x-circle text-danger me-2"></i>Définir comme Désactivé
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Carte documents -->
                <div class="card shadow mt-4">
                    <div class="card-header bg-transparent border-bottom">
                        <h5 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Documents</h5>
                    </div>
                    <div class="card-body">
                        {% if user.documentFile %}
                        <div class="d-flex align-items-center p-3 bg-light rounded">
                            <i class="bi bi-file-earmark-pdf fs-3 text-danger me-3"></i>
                            <div class="flex-grow-1">
                                <h6 class="mb-0">Document justificatif</h6>
                                <small class="text-muted">{{ user.documentFile }}</small>
                            </div>
                            <a href="{{ asset('uploads/users/documents/' ~ user.documentFile) }}" class="btn btn-sm btn-primary-soft" download>
                                <i class="bi bi-download"></i>
                            </a>
                        </div>
                        {% else %}
                        <p class="text-muted mb-0 text-center">
                            <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                            Aucun document téléversé
                        </p>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- Colonne droite : informations -->
            <div class="col-lg-8">
                <!-- Informations personnelles -->
                <div class="card shadow mb-4">
                    <div class="card-header bg-transparent border-bottom">
                        <h5 class="mb-0"><i class="bi bi-person me-2"></i>Informations personnelles</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Prénom</label>
                                <p class="mb-0">{{ user.firstName }}</p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Nom</label>
                                <p class="mb-0">{{ user.lastName }}</p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Adresse e-mail</label>
                                <p class="mb-0">
                                    <i class="bi bi-envelope me-2"></i>{{ user.email }}
                                </p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Numéro de téléphone</label>
                                <p class="mb-0">
                                    {% if user.phone %}
                                        <i class="bi bi-telephone me-2"></i>{{ user.phone }}
                                    {% else %}
                                        <span class="text-muted">Non renseigné</span>
                                    {% endif %}
                                </p>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold">Adresse</label>
                                <p class="mb-0">
                                    {% if user.address %}
                                        <i class="bi bi-geo-alt me-2"></i>{{ user.address }}
                                    {% else %}
                                        <span class="text-muted">Non renseignée</span>
                                    {% endif %}
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Informations du compte -->
                <div class="card shadow mb-4">
                    <div class="card-header bg-transparent border-bottom">
                        <h5 class="mb-0"><i class="bi bi-shield-check me-2"></i>Informations du compte</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">ID utilisateur</label>
                                <p class="mb-0">#{{ user.id }}</p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Rôle</label>
                                <p class="mb-0">
                                    <span class="badge bg-primary bg-opacity-10 text-primary">
                                        {% if user.role == 'admin' %}Administrateur
                                        {% elseif user.role == 'employee' %}Employé
                                        {% elseif user.role == 'agriculteur' %}Agriculteur
                                        {% elseif user.role == 'fournisseur' %}Fournisseur
                                        {% else %}{{ user.role|capitalize }}{% endif %}
                                    </span>
                                </p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Statut du compte</label>
                                <p class="mb-0">
                                    <span class="badge 
                                        {% if user.status == 'active' %}
                                            bg-success bg-opacity-10 text-success
                                        {% elseif user.status == 'pending' %}
                                            bg-warning bg-opacity-10 text-warning
                                        {% else %}
                                            bg-danger bg-opacity-10 text-danger
                                        {% endif %}">
                                        {% if user.status == 'active' %}Actif
                                        {% elseif user.status == 'pending' %}En attente
                                        {% else %}Désactivé{% endif %}
                                    </span>
                                </p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Date d'inscription</label>
                                <p class="mb-0">
                                    <i class="bi bi-calendar-event me-2"></i>{{ user.createdAt|date('d/m/Y') }}
                                </p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Dernière mise à jour</label>
                                <p class="mb-0">
                                    <i class="bi bi-clock-history me-2"></i>{{ user.updatedAt|date('d/m/Y H:i') }}
                                </p>
                            </div>
                            {% if user.googleId %}
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Compte Google</label>
                                <p class="mb-0">
                                    <i class="bi bi-google me-2 text-danger"></i>Connecté
                                </p>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>
    <!-- Contenu principal END -->
</div>
<!-- Contenu de la page END -->

<style>
.avatar-xxl {
    width: 120px;
    height: 120px;
}

.avatar-xxl .avatar-img {
    width: 120px;
    height: 120px;
    object-fit: cover;
}
</style>

{% endblock %}
