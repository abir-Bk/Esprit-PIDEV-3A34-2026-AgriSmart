{% extends 'base.html.twig' %}

{% block title %}Login{% endblock %}

{% block body %}
<main>
<section class="vh-xxl-100">
    <div class="container h-100 d-flex px-0 px-sm-4">
        <div class="row justify-content-center align-items-center m-auto">
            <div class="col-12">
                <div class="bg-mode shadow rounded-3 overflow-hidden">
                    <div class="row g-0">

                        <!-- Vector Image -->
                        <div class="col-lg-6 d-flex align-items-center order-2 order-lg-1">
                            <div class="p-3 p-lg-5">
                                <img src="{{ asset('assets/images/element/signin.svg') }}" alt="">
                            </div>
                            <div class="vr opacity-1 d-none d-lg-block"></div>
                        </div>

                        <!-- Login Form -->
                        <div class="col-lg-6 order-1">
                            <div class="p-4 p-sm-7">
                                <!-- Logo -->
                                <a href="{{ path('app_home') }}">
                                    <img class="h-50px mb-4" src="{{ asset('assets/images/logo-icon.svg') }}" alt="logo">
                                </a>

                                <h1 class="mb-2 h3">Welcome back</h1>
                                <p class="mb-0">New here? <a href="{{ path('app_register') }}">Create an account</a></p>

                                {% if error %}
                                    <div class="alert alert-danger mt-3">
                                        {{ error.messageKey|trans(error.messageData, 'security') }}
                                    </div>
                                {% endif %}

                                <form method="post" class="mt-4 text-start">
                                    <!-- Email -->
                                    <div class="mb-3">
                                        <label class="form-label">Enter email id</label>
                                        <input type="email" name="_username" value="{{ last_email }}" class="form-control" required autofocus>
                                    </div>

                                    <!-- Password -->
                                    <div class="mb-3 position-relative">
                                        <label class="form-label">Enter password</label>
                                        <input type="password" name="_password" class="form-control" required>
                                        <span class="position-absolute top-50 end-0 translate-middle-y p-0 mt-3">
                                            <i class="fas fa-eye-slash cursor-pointer p-2"></i>
                                        </span>
                                    </div>

                                    <!-- Remember me -->
                                    <div class="mb-3 d-sm-flex justify-content-between">
                                        <div>
                                            <input type="checkbox" class="form-check-input" name="_remember_me" id="rememberCheck">
                                            <label class="form-check-label" for="rememberCheck">Remember me?</label>
                                        </div>
                                    </div>

                                    <!-- Submit Button -->
                                    <div>
                                        <button type="submit" class="btn btn-primary w-100 mb-0">Login</button>
                                    </div>

                                    <!-- Divider -->
                                    <div class="position-relative my-4">
                                        <hr>
                                        <p class="small bg-mode position-absolute top-50 start-50 translate-middle px-2">Or sign in with</p>
                                    </div>

                                    <!-- Social Buttons -->
                                    <div class="vstack gap-3">
                                        <a href="#" class="btn btn-light mb-0"><i class="fab fa-google me-2"></i>Sign in with Google</a>
                                        <a href="#" class="btn btn-light mb-0"><i class="fab fa-facebook-f me-2"></i>Sign in with Facebook</a>
                                    </div>

                                    <!-- Copyright -->
                                    <div class="text-primary-hover text-body mt-3 text-center">
                                        Copyrights ©2023 Booking. Build by <a href="https://www.webestica.com/" class="text-body">Webestica</a>
                                    </div>
                                </form>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
      </div>
</section>
</main>

<div class="back-top"></div>
{% endblock %}