			--ag-primary: #1A4331;
			--ag-primary-2: #2E7D32;
			--ag-accent: #F4B400;
			--ag-cream: #FBF7EE;
			--ag-bg: #F6F8F7;
			--ag-text: #111827;
			--ag-muted: #6B7280;
			--ag-border: #E5E7EB;
		}

		/* ---------- Landing navbar ---------- */
		.header-landing { background: rgba(255,255,255,0.98); backdrop-filter: blur(12px); box-shadow: 0 1px 0 rgba(26,67,49,0.08); position: sticky; top: 0; z-index: 1030; }
		.header-landing .navbar { padding: 0.6rem 0; }
		.header-landing .logo-text { color: var(--ag-primary); font-size: 1.25rem; letter-spacing: -0.02em; }
		.header-landing .logo-accent { color: var(--ag-primary-2); }
		.header-landing .nav-link { color: var(--ag-text) !important; font-weight: 500; font-size: 0.95rem; padding: 0.5rem 0.85rem !important; border-radius: 999px; transition: color 0.2s, background 0.2s; }
		.header-landing .nav-link:hover { color: var(--ag-primary) !important; background: rgba(26,67,49,0.08); }
		.header-landing .btn-landing-outline { border: 2px solid var(--ag-primary); color: var(--ag-primary); font-weight: 600; padding: 0.5rem 1.25rem; border-radius: 999px; transition: all 0.2s; }
