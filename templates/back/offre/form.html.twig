{% extends 'back/admin_base.html.twig' %}

{% block title %}{{ editMode ? 'Modifier' : 'Créer' }} - Offre d'emploi{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="card shadow border-0">
                
                {# En-tête dynamique : Vert si création, Orange si modification #}
                <div class="card-header {{ editMode ? 'bg-warning' : 'bg-success' }} text-white py-3">
                    <h4 class="mb-0 text-center text-white">
                        <i class="bi {{ editMode ? 'bi-pencil-square' : 'bi-plus-circle' }} me-2"></i>
                        {{ editMode ? 'Modifier l\'offre d\'emploi' : 'Nouvelle Offre d\'Emploi' }}
                    </h4>
                </div>

                <div class="card-body p-4">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                        
                        {# Titre de l'offre #}
                        <div class="mb-3">
                            {{ form_row(form.title, {'label': 'Titre du poste', 'attr': {'placeholder': 'Ex: Ingénieur Agronome'}}) }}
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                {{ form_row(form.typePoste, {'label': 'Département'}) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.typeContrat, {'label': 'Type de Contrat'}) }}
                            </div>
                        </div>

                        <div class="mb-4">
                            {{ form_row(form.description, {'label': 'Description détaillée', 'attr': {'rows': '6'}}) }}
                        </div>

                        <hr class="text-muted">
                        <h6 class="text-uppercase small fw-bold mb-3 text-secondary">Logistique et Conditions</h6>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                {{ form_row(form.lieu, {'label': 'Localisation', 'attr': {'placeholder': 'Ex: Tunis, Remote...'}}) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.salaire, {'label': 'Salaire (DT)'}) }}
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                {{ form_row(form.statut, {'label': 'Statut'}) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.dateDebut, {'label': 'Date de Début'}) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.dateFin, {'label': 'Date d\'Expiration'}) }}
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-5">
                            <button type="submit" class="btn {{ editMode ? 'btn-warning' : 'btn-success' }} btn-lg shadow-sm text-white">
                                {{ editMode ? 'Enregistrer les modifications' : 'Publier cette offre' }}
                            </button>
                            <a href="{{ path('app_admin_offres') }}" class="btn btn-link text-muted text-decoration-none text-center">
                                <i class="bi bi-arrow-left me-1"></i> Annuler et retourner à la liste
                            </a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}