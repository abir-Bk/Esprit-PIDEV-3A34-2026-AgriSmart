<!DOCTYPE html>
<html lang="fr">
<head>
	<title>{% block title %}AgriSmart{% endblock %}</title>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

	{# Favicon (logo in browser tab) #}
	<link rel="icon" href="{{ asset('assets/images/logo.png') }}" type="image/svg+xml">
	<link rel="alternate icon" href="{{ asset('assets/images/logo.png') }}" type="image/svg+xml">

	<script>
		// Force le thème clair (white theme) partout
		document.documentElement.setAttribute('data-bs-theme', 'light');
	</script>

	{% block stylesheets %}
		<link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/font-awesome/css/all.min.css') }}">
		<link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/bootstrap-icons/bootstrap-icons.css') }}">
		<link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/overlay-scrollbar/css/overlayscrollbars.min.css') }}">
		<link rel="stylesheet" type="text/css" href="{{ asset('assets/css/style.css') }}">
	{% endblock %}
</head>

<body class="d-flex flex-column min-vh-100">

    {% block header %}
        {{ include('_partials/_header.html.twig') }}
    {% endblock %}

    {# Toast Container pour les notifications pop-up #}
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1080;">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="toast align-items-center text-white bg-{{ label == 'success' ? 'success' : (label == 'danger' ? 'danger' : (label == 'warning' ? 'warning' : 'info')) }} border-0 shadow-lg mb-2" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="5000">
                    <div class="d-flex">
                        <div class="toast-body">
                            <i class="bi {{ label == 'success' ? 'bi-check-circle' : 'bi-exclamation-triangle' }} me-2"></i>
                            {{ message }}
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var toastElList = [].slice.call(document.querySelectorAll('.toast'))
            var toastList = toastElList.map(function (toastEl) {
                var toast = new bootstrap.Toast(toastEl, { autohide: true, delay: 5000 });
                toast.show();
                return toast;
            });
        });
    </script>

    <main class="flex-grow-1">
        {% block body %}{% endblock %}
    </main>

    {% block footer %}
    <footer class="bg-light border-top py-4 mt-auto">
        <div class="container text-center text-muted small">
            <span>© {{ 'now'|date('Y') }} AgriSmart · Marketplace agricole</span>
        </div>
    </footer>
    {% endblock %}

    {% block javascripts %}
        <script src="{{ asset('assets/vendor/bootstrap/dist/js/bootstrap.bundle.min.js') }}"></script>
    {% endblock %}
</body>
</html>
