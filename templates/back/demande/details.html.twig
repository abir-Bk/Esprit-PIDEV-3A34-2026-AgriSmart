{% extends 'back/admin_base.html.twig' %}

{% block title %}Détails Candidature - {{ demande.nom }}{% endblock %}

{% block body %}
<div class="container mt-5">
    {# Bouton retour vers les détails de l'offre #}
    <div class="d-flex justify-content-between mb-4">
        <a href="{{ path('app_admin_offre_details', {'id': demande.offre.id}) }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Retour
        </a>
    </div>

    <div class="row g-4">
        {# Colonne de gauche : Infos et Statut #}
        <div class="col-md-5">
            <div class="card shadow-sm border-0 text-center p-4">
                <div class="bg-primary text-white rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                    <i class="bi bi-person fs-1"></i>
                </div>
                <h3>{{ demande.nom }} {{ demande.prenom }}</h3>
                <p class="text-muted">{{ demande.phoneNumber }}</p>
                
                <hr>

                <div class="text-start mt-3">
                    <label class="form-label fw-bold">Modifier le Statut :</label>
                    <form action="{{ path('app_admin_demande_update_status', {'id': demande.id}) }}" method="POST" class="input-group">
                        <select name="statut" class="form-select">
                            <option value="En cours" {{ demande.statut == 'En cours' ? 'selected' : '' }}>En cours</option>
                            <option value="Acceptée" {{ demande.statut == 'Acceptée' ? 'selected' : '' }}>Acceptée</option>
                            <option value="Refusée" {{ demande.statut == 'Refusée' ? 'selected' : '' }}>Refusée</option>
                        </select>
                        <button type="submit" class="btn btn-dark">Valider</button>
                    </form>
                </div>
            </div>
        </div>

        {# Colonne de droite : Documents PDF #}
        <div class="col-md-7">
            <div class="card shadow-sm border-0 p-4">
                <h5 class="mb-4">Documents du candidat</h5>
                
                {# Section CV #}
                <div class="d-flex align-items-center justify-content-between p-3 border rounded mb-3">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-file-pdf text-danger fs-2 me-3"></i>
                        <div>
                            <h6 class="mb-0">CV</h6>
                            <small>Fichier PDF</small>
                        </div>
                    </div>
                    <a href="{{ asset('uploads/cv/' ~ demande.cv) }}" target="_blank" class="btn btn-outline-primary btn-sm">Consulter</a>
                </div>

                {# Section Lettre de Motivation #}
                <div class="d-flex align-items-center justify-content-between p-3 border rounded">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-file-text text-primary fs-2 me-3"></i>
                        <div>
                            <h6 class="mb-0">Lettre de Motivation</h6>
                            <small>Fichier PDF</small>
                        </div>
                    </div>
                    <a href="{{ asset('uploads/lettres/' ~ demande.lettreMotivation) }}" target="_blank" class="btn btn-outline-primary btn-sm">Consulter</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}