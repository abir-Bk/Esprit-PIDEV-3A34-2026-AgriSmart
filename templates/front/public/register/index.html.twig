{% extends 'front/base.html.twig' %}
{% block title %}Inscription - AgriSmart{% endblock %}

{% block body %}
<main>
<section class="vh-xxl-100">
  <div class="container h-100 d-flex px-0 px-sm-4">
    <div class="row justify-content-center align-items-center m-auto">
      <div class="col-12">
        <div class="bg-mode shadow rounded-3 overflow-hidden">
          <div class="row g-0">

            <!-- IMAGE -->
            <div class="col-lg-6 d-flex align-items-center order-2 order-lg-1">
              <div class="p-3 p-lg-5 text-center">
                <img src="{{ asset('assets/images/element/signin.svg') }}" class="img-fluid" alt="Sign In">
              </div>
              <div class="vr opacity-1 d-none d-lg-block"></div>
            </div>

            <!-- FORM -->
            <div class="col-lg-6 order-1">
              <div class="p-4 p-sm-5">
                <h1 class="mb-2 h3">Créer un compte</h1>
                <p class="mb-4">Déjà inscrit ? <a href="{{ path('app_login') }}">Se connecter</a></p>

                {% for message in app.flashes('success') %}
                  <div class="alert alert-success">{{ message }}</div>
                {% endfor %}

                {{ form_start(registrationForm, { attr: { class: 'mt-4 text-start', enctype:'multipart/form-data', novalidate:'novalidate' } }) }}

                {% for field in registrationForm %}
                  {% set isPassword = field.vars.block_prefixes|last == 'password' %}
                  <div class="mb-3">
                    {{ form_label(field, null, { label_attr: { class: 'form-label fw-bold' } }) }}
                    
                    {% if isPassword %}
                      <div class="input-group">
                        {{ form_widget(field, { attr: { class: 'form-control'~(field.vars.valid ? '' : ' is-invalid'), type:'password', id:'password-field' } }) }}
                        <button class="btn btn-outline-secondary" type="button" id="togglePassword">
                          <i class="bi bi-eye"></i>
                        </button>
                      </div>
                    {% else %}
                      {{ form_widget(field, { attr: { class: 'form-control'~(field.vars.valid ? '' : ' is-invalid') } }) }}
                    {% endif %}
                    
                    {{ form_errors(field) }}
                  </div>
                {% endfor %}

                <button type="submit" class="btn btn-success w-100">Créer mon compte</button>

                {{ form_end(registrationForm) }}
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>
</section>
</main>

{% block javascripts %}
<script>
  const togglePassword = document.querySelector('#togglePassword');
  const passwordField = document.querySelector('#password-field');

  togglePassword.addEventListener('click', function () {
    const type = passwordField.getAttribute('type') === 'password' ? 'text' : 'password';
    passwordField.setAttribute('type', type);
    this.querySelector('i').classList.toggle('bi-eye');
    this.querySelector('i').classList.toggle('bi-eye-slash');
  });
</script>
{% endblock %}
{% endblock %}