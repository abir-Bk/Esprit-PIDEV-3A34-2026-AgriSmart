		.about-section { background: var(--ag-bg); position: relative; overflow: hidden; }
		.about-section::before { content: ''; position: absolute; top: -40%; right: -15%; width: 550px; height: 550px; background: radial-gradient(circle, rgba(46,125,50,0.06) 0%, transparent 70%); border-radius: 50%; pointer-events: none; }
		.about-section::after { content: ''; position: absolute; bottom: -20%; left: -10%; width: 400px; height: 400px; background: radial-gradient(circle, rgba(26,67,49,0.04) 0%, transparent 70%); border-radius: 50%; pointer-events: none; }
		.stat-card { background: #fff; border-radius: 20px; padding: 2rem 1.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.04); transition: transform 0.3s ease, box-shadow 0.3s ease; border: 1px solid var(--ag-border); text-align: center; }
		.stat-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(26,67,49,0.08); }
		.stat-number { font-size: 2.5rem; font-weight: 800; color: var(--ag-primary); line-height: 1.2; }
		.stat-card p { color: var(--ag-muted); font-weight: 500; margin-bottom: 0; font-size: 0.95rem; }
		.feature-icon { width: 64px; height: 64px; background: linear-gradient(135deg, var(--ag-primary) 0%, var(--ag-primary-2) 100%); border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 1.75rem; color: #fff; margin-bottom: 1.25rem; box-shadow: 0 8px 24px rgba(26,67,49,0.2); }
		.value-card { background: #fff; border-radius: 20px; padding: 2rem; height: 100%; transition: all 0.3s ease; border: 1px solid rgba(17,24,39,0.06); box-shadow: 0 4px 20px rgba(0,0,0,0.04); }
		.value-card:hover { border-color: rgba(26,67,49,0.2); transform: translateY(-4px); box-shadow: 0 12px 36px rgba(26,67,49,0.08); }
		.value-card h5 { font-weight: 700; color: var(--ag-text); margin-bottom: 0.6rem; }
		.value-card .text-muted { color: var(--ag-muted) !important; font-size: 0.9rem; line-height: 1.55; }
		.section-badge { display: inline-block; padding: 0.45rem 1.25rem; background: rgba(26,67,49,0.1); color: var(--ag-primary); border-radius: 999px; font-weight: 600; font-size: 0.8rem; letter-spacing: 0.05em; margin-bottom: 0.75rem; text-transform: uppercase; }
		.cta-box { background: var(--ag-cream); border: 1px solid rgba(26,67,49,0.12); border-radius: 24px; padding: 3rem 2rem; text-align: center; }
		.cta-box .btn-success { padding: 0.75rem 2rem; font-weight: 600; border-radius: 999px; background: var(--ag-primary); border: none; box-shadow: 0 6px 20px rgba(26,67,49,0.3); }
		.cta-box .btn-success:hover { background: #163828; }
		.cta-box .btn-outline-success { padding: 0.75rem 2rem; font-weight: 600; border-radius: 999px; border-width: 2px; border-color: var(--ag-primary); color: var(--ag-primary); }
		.cta-box .btn-outline-success:hover { background: rgba(26,67,49,0.08); color: var(--ag-primary); }

		/* ---------- Contact strip ---------- */
		#contact { scroll-margin-top: 80px; }
		.contact-strip { background: linear-gradient(135deg, var(--ag-primary) 0%, #1e5138 100%); color: #fff; padding: 3rem 0; }
		.contact-strip .contact-title { font-weight: 700; font-size: 1.35rem; margin-bottom: 0.5rem; }
		.contact-strip .contact-text { opacity: 0.9; font-size: 0.95rem; margin-bottom: 0; }
		.contact-strip .btn-light { background: #fff; color: var(--ag-primary); font-weight: 600; }
		.contact-strip .btn-light:hover { background: var(--ag-cream); color: var(--ag-primary); }

		/* ---------- Footer landing ---------- */
		.footer-landing { background: #0f2e24; color: rgba(255,255,255,0.88); padding: 2.5rem 0; }
		.footer-landing .logo-text { color: #fff; }
		.footer-landing .logo-accent { color: #7dd892; }
		.footer-landing a { color: rgba(255,255,255,0.85); text-decoration: none; transition: color 0.2s; }
		.footer-landing a:hover { color: #7dd892; }
		.footer-landing .copy { font-size: 0.9rem; opacity: 0.8; }

		/* ---------- Boutons globaux section solutions ---------- */
		#solutions .btn-success { background: var(--ag-primary); border: none; border-radius: 999px; font-weight: 600; }
		#solutions .btn-success:hover { background: #163828; }
	</style>
{% endblock %}

