{% extends 'front/base.html.twig' %}

{% block title %}AgriSmart | Nouvelle ressource{% endblock %}

{% block body %}

<style>
.ag-marketplace{
  --ag-primary:#1A4331;
  --ag-bg:#F6F8F7;
  --ag-text:#111827;
  --ag-muted:#6B7280;
  --ag-border:#E5E7EB;
  --ag-cream:#FBF7EE;
}
.ag-marketplace .ag-hero{
  background:
    radial-gradient(600px 280px at 20% 30%, rgba(46,125,50,.12), transparent 55%),
    linear-gradient(180deg, var(--ag-cream), #ffffff);
  border-bottom: 1px solid rgba(17,24,39,.06);
  padding: 2rem 0 1.5rem;
}
.ag-marketplace .ag-content{ background: var(--ag-bg); padding: 2rem 0 3rem; }
.ag-marketplace .ag-card{
  border: 1px solid rgba(17,24,39,.06);
  border-radius: 20px;
  background: #fff;
  overflow: hidden;
}
.ag-marketplace .ag-btn-primary{ background: var(--ag-primary) !important; border: none !important; }
.ag-marketplace .ag-btn-primary:hover{ background:#163828 !important; color: #fff !important; }
.ag-marketplace .ag-input{
  border-radius: 14px !important;
  border: 1px solid var(--ag-border) !important;
}
.ag-marketplace .ag-input:focus{
  border-color: rgba(26,67,49,.45) !important;
  box-shadow: 0 0 0 .25rem rgba(26,67,49,.12) !important;
}
</style>

<div class="ag-marketplace">
  <section class="ag-hero">
    <div class="container">
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
          <h1 class="h2 fw-bold mb-1" style="color:#111827;">Nouvelle ressource</h1>
          <p class="text-muted mb-0">Remplissez les informations de votre stock agricole.</p>
        </div>
        <a href="{{ path('app_ressource_index') }}" class="btn btn-outline-dark rounded-pill">
          <i class="bi bi-arrow-left me-2"></i>Retour à l'inventaire
        </a>
      </div>
    </div>
  </section>

  <section class="ag-content">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-7 col-xl-6">
          <div class="card ag-card shadow-sm p-4 p-md-5">
            {% for label, messages in app.flashes %}
              {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show mb-4" role="alert">
                  {{ message }}
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              {% endfor %}
            {% endfor %}

            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <div class="mb-4">
              <label class="form-label fw-bold text-uppercase small" style="color:var(--ag-muted);">Nom de la ressource</label>
              {{ form_widget(form.nom, {'attr': {'class': 'form-control ag-input', 'placeholder': 'Ex: Engrais Bio'}}) }}
              <div class="text-danger small mt-1">{{ form_errors(form.nom) }}</div>
            </div>

            <div class="row g-3 mb-4">
              <div class="col-md-6">
                <label class="form-label fw-bold text-uppercase small" style="color:var(--ag-muted);">Catégorie</label>
                {{ form_widget(form.type, {'attr': {'class': 'form-select ag-input'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(form.type) }}</div>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold text-uppercase small" style="color:var(--ag-muted);">Unité</label>
                {{ form_widget(form.unite, {'attr': {'class': 'form-select ag-input'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(form.unite) }}</div>
              </div>
            </div>

            <div class="mb-4">
              <label class="form-label fw-bold text-uppercase small" style="color:var(--ag-muted);">Quantité disponible</label>
              {{ form_widget(form.stockRestant, {'attr': {'class': 'form-control ag-input', 'placeholder': '0.00'}}) }}
              <div class="text-danger small mt-1">{{ form_errors(form.stockRestant) }}</div>
            </div>

            <button type="submit" class="btn ag-btn-primary text-white w-100 py-3 rounded-pill fw-bold">
              <i class="bi bi-plus-circle me-2"></i>Enregistrer dans le stock
            </button>

            {{ form_end(form) }}
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

{% endblock %}
