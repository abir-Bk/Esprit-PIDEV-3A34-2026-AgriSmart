{% extends 'front/task/layout.html.twig' %}

{% block title %}Dashboard tâches - AgriSmart{% endblock %}

{% block task_content %}
    <div class="container-fluid py-3">
        <div class="row g-3 mb-4">
            <div class="col-md-3 col-sm-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h6 class="text-muted text-uppercase small">Total tâches</h6>
                        <h3 class="fw-bold mb-0">{{ totalTasks }}</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h6 class="text-muted text-uppercase small">À faire</h6>
                        <h3 class="fw-bold mb-0 text-primary">{{ todoTasks }}</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h6 class="text-muted text-uppercase small">En cours</h6>
                        <h3 class="fw-bold mb-0 text-warning">{{ inProgressTasks }}</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h6 class="text-muted text-uppercase small">Terminées</h6>
                        <h3 class="fw-bold mb-0 text-success">{{ doneTasks }}</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body d-flex flex-column">
                        <h6 class="text-muted text-uppercase small mb-2">Affectations</h6>
                        <h3 class="fw-bold mb-1">{{ totalAssignments }}</h3>
                        <span class="text-muted small">Nombre total d'affectations de tâches</span>
                        <div class="mt-auto pt-2">
                            <a href="{{ path('task_assignments_index') }}" class="btn btn-link btn-sm p-0">Voir les affectations</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="text-muted text-uppercase small mb-0">
                                Tâches d'aujourd'hui ({{ today|date('d/m/Y') }})
                            </h6>
                            <a href="{{ path('tasks_calendar') }}" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-calendar3 me-1"></i> Calendrier
                            </a>
                        </div>
                        {% if todayTasks is empty %}
                            <p class="text-muted small mb-0">Aucune tâche planifiée pour aujourd'hui.</p>
                        {% else %}
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <thead class="table-light">
                                    <tr>
                                        <th>Titre</th>
                                        <th>Type</th>
                                        <th>Priorité</th>
                                        <th>Statut</th>
                                        <th>Heure</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    {% for task in todayTasks %}
                                        <tr>
                                            <td>{{ task.titre }}</td>
                                            <td>{{ task.type }}</td>
                                            <td>{{ task.priorite }}</td>
                                            <td>{{ task.statut }}</td>
                                            <td>{{ task.dateDebut ? task.dateDebut|date('H:i') : '' }}</td>
                                            <td class="text-end">
                                                <a href="{{ path('tasks_show', {id: task.idTask}) }}" class="btn btn-xs btn-outline-secondary">Voir</a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

