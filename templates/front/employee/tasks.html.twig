{% extends 'front/task/layout.html.twig' %}

{% block title %}Mes tâches - AgriSmart{% endblock %}

{% block task_content %}
    <div class="container py-4">
        <h3 class="mb-4 fw-bold" style="color: var(--ag-text);">Mes tâches affectées</h3>

        <div class="row g-3 mb-4">
            <div class="col-md-3 col-sm-6">
                <div class="ag-card p-3 h-100">
                    <h6 class="text-muted text-uppercase small">Total</h6>
                    <h3 class="fw-bold mb-0">{{ totalAssignments }}</h3>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="ag-card p-3 h-100">
                    <h6 class="text-muted text-uppercase small">Assignées</h6>
                    <h3 class="fw-bold mb-0" style="color: var(--ag-primary);">{{ assignesCount }}</h3>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="ag-card p-3 h-100">
                    <h6 class="text-muted text-uppercase small">Acceptées</h6>
                    <h3 class="fw-bold mb-0 text-warning">{{ accepteesCount }}</h3>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="ag-card p-3 h-100">
                    <h6 class="text-muted text-uppercase small">Réalisées</h6>
                    <h3 class="fw-bold mb-0 text-success">{{ realiseesCount }}</h3>
                </div>
            </div>
        </div>

        <div class="ag-card border-0">
            <div class="p-3 border-bottom bg-light d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold" style="color: var(--ag-text);">Liste de mes tâches</h5>
            </div>
            <div class="card-body">
                {% if assignments is empty %}
                    <p class="text-muted mb-0">Aucune tâche ne vous a encore été affectée.</p>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-striped align-middle">
                            <thead>
                            <tr>
                                <th>Tâche</th>
                                <th>Type</th>
                                <th>Priorité</th>
                                <th>Statut</th>
                                <th>Début</th>
                                <th>Fin</th>
                                <th class="text-end">Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for assignment in assignments %}
                                {% set task = assignment.task %}
                                <tr>
                                    <td>{{ task ? task.titre : '—' }}</td>
                                    <td>{{ task ? task.type : '—' }}</td>
                                    <td>{{ task ? task.priorite : '—' }}</td>
                                    <td>
                                        {% if task %}
                                            {% if task.statut == 'todo' %}
                                                <span class="badge bg-secondary">À faire</span>
                                            {% elseif task.statut == 'en_cours' %}
                                                <span class="badge bg-primary">En cours</span>
                                            {% elseif task.statut == 'a_valider' %}
                                                <span class="badge bg-warning text-dark">À valider</span>
                                            {% elseif task.statut == 'termine' %}
                                                <span class="badge bg-success">Terminé</span>
                                            {% endif %}
                                        {% else %}
                                            {{ assignment.statut }}
                                        {% endif %}
                                    </td>
                                    <td>{{ task and task.dateDebut ? task.dateDebut|date('d/m/Y H:i') : '' }}</td>
                                    <td>{{ task and task.dateFin ? task.dateFin|date('d/m/Y H:i') : '' }}</td>
                                    <td class="text-end">
                                        <a href="{{ path('employee_tasks_show', {id: assignment.idAssignment}) }}" class="btn btn-sm btn-outline-primary rounded-pill">
                                            <i class="bi bi-eye"></i> Voir
                                        </a>
                                        {% if task %}
                                            {% if task.statut == 'todo' %}
                                                <form method="post" action="{{ path('employee_tasks_start', {id: assignment.idAssignment}) }}" class="d-inline">
                                                    <button class="btn btn-sm btn-primary rounded-pill">
                                                        <i class="bi bi-play-fill"></i> Commencer
                                                    </button>
                                                </form>
                                            {% elseif task.statut == 'en_cours' %}
                                                <a href="{{ path('suivi_tache_new', {id: task.idTask}) }}" class="btn btn-sm btn-success rounded-pill">
                                                    <i class="bi bi-check2"></i> Terminer
                                                </a>
                                            {% endif %}
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}

