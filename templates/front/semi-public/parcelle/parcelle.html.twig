            </div>
            <form :action="'/culture/' + c.id + '/consommer'" method="POST"
                  x-data="{
                      stockError: false,
                      maxStock: 0,
                      unite: '',
                      checkStock() {
                          const form = this.$el;
                          const sel = form.querySelector('select[name=ressource_id]');
                          const qtyInput = form.querySelector('input[name=quantite]');
                          if (!sel || !qtyInput) return;
                          const opt = sel.options[sel.selectedIndex];
                          const ressourceChoisie = opt && opt.value !== '';
                          if (!ressourceChoisie) {
                              this.stockError = false;
                              this.maxStock = 0;
                              this.unite = '';
                              return;
                          }
                          const stockStr = String(opt.dataset.stock || '0').replace(',', '.');
                          this.maxStock = parseFloat(stockStr) || 0;
                          this.unite = (opt.dataset.unite || '');
                          const qtyStr = String(qtyInput.value || '').trim().replace(',', '.');
                          const qty = parseFloat(qtyStr) || 0;
                          this.stockError = qty > 0 && qty > this.maxStock;
                      }
                  }"
