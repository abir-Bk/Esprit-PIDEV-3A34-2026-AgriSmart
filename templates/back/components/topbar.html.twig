<header class="ag-topbar">
    <div class="ag-topbar-inner">

        {# Page title — injected from child templates #}
        <div class="ag-topbar-left">
            <h6 class="ag-topbar-title">{{ topbar_title ?? 'Dashboard' }}</h6>
        </div>

        {# Right side — actions #}
        <div class="ag-topbar-right">

            {# Notification Bell #}
            <div class="notif-wrap" id="notif-wrap">
                <button class="topbar-icon-btn" id="bell-btn" onclick="toggleDropdown(event)">
                    <i class="bi bi-bell"></i>
                    <span class="notif-badge d-none" id="badge-count">0</span>
                </button>

                <div class="notif-dropdown d-none" id="notif-dropdown">
                    <div class="notif-dropdown-header">
                        <span>Notifications</span>
                        <button onclick="markAllRead()">Mark all read</button>
                    </div>
                    <div id="notif-list">
                        <div class="notif-empty">No notifications yet</div>
                    </div>
                </div>
            </div>

            {# Admin avatar #}
            <div class="topbar-avatar" title="{{ app.user ? app.user.firstName : 'Admin' }}">
                {% if app.user and app.user.image %}
                    <img src="{{ asset('uploads/users/images/' ~ app.user.image) }}"
                         alt="avatar">
                {% else %}
                    <i class="bi bi-person"></i>
                {% endif %}
            </div>

        </div>
    </div>
</header>

<style>
/* ── Topbar ──────────────────────────────────────────────── */
.ag-topbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #ffffff;
    border-bottom: 1px solid #dde8d0;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
}

.ag-topbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
}

.ag-topbar-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 0.9rem;
    color: #5a6e55;
    margin: 0;
    letter-spacing: 0.3px;
}

.ag-topbar-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

/* ── Icon button ─────────────────────────────────────────── */
.topbar-icon-btn {
    position: relative;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    border: 1px solid #dde8d0;
    background: #f7f4ee;
    color: #4a7c3f;
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
}

.topbar-icon-btn:hover {
    background: #eef6e8;
    border-color: #c8e0b8;
}

/* ── Badge ───────────────────────────────────────────────── */
.notif-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    background: #e74c3c;
    color: white;
    font-size: 0.6rem;
    font-weight: 700;
    min-width: 16px;
    height: 16px;
    border-radius: 99px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
    border: 2px solid #fff;
}

/* ── Avatar ──────────────────────────────────────────────── */
.topbar-avatar {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    border: 1px solid #dde8d0;
    background: #eef6e8;
    color: #4a7c3f;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    cursor: default;
}

.topbar-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* ── Notification dropdown ───────────────────────────────── */
.notif-wrap { position: relative; }

.notif-dropdown {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    width: 300px;
    background: #fff;
    border: 1px solid #dde8d0;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(45,90,39,0.12);
    z-index: 9999;
    overflow: hidden;
}

.notif-dropdown-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid #dde8d0;
    font-size: 0.85rem;
    font-weight: 600;
    color: #1e2d1a;
}

.notif-dropdown-header button {
    background: none;
    border: none;
    font-size: 0.72rem;
    color: #4a7c3f;
    cursor: pointer;
    padding: 0;
}

.notif-dropdown-header button:hover {
    text-decoration: underline;
}

#notif-list {
    max-height: 320px;
    overflow-y: auto;
}

.notif-item {
    display: flex;
    gap: 10px;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #f0f5ea;
    cursor: pointer;
    transition: background 0.15s;
}

.notif-item:last-child { border-bottom: none; }
.notif-item:hover      { background: #f7f4ee; }
.notif-item.unread     { background: #f0f7eb; }

.notif-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    margin-top: 5px;
    flex-shrink: 0;
}

.notif-dot.warning { background: #e67e22; }
.notif-dot.info    { background: #4a7c3f; }
.notif-dot.success { background: #27ae60; }

.notif-item-body   { flex: 1; min-width: 0; }

.notif-item-title {
    font-size: 0.8rem;
    font-weight: 600;
    color: #1e2d1a;
    margin-bottom: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.notif-item-msg {
    font-size: 0.75rem;
    color: #5a6e55;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.notif-item-time {
    font-size: 0.68rem;
    color: #a0b090;
    margin-top: 3px;
}

.notif-empty {
    padding: 2rem;
    text-align: center;
    font-size: 0.82rem;
    color: #a0b090;
}

.d-none { display: none !important; }
</style>

<script>
let dropdownOpen = false;

function toggleDropdown(e) {
    e.stopPropagation();
    dropdownOpen = !dropdownOpen;
    document.getElementById('notif-dropdown').classList.toggle('d-none', !dropdownOpen);
}

document.addEventListener('click', function(e) {
    if (!document.getElementById('notif-wrap').contains(e.target)) {
        dropdownOpen = false;
        document.getElementById('notif-dropdown').classList.add('d-none');
    }
});

async function pollNotifications() {
    try {
        const res  = await fetch('/admin/notifications/poll');
        const data = await res.json();

        const badge = document.getElementById('badge-count');
        if (data.unread > 0) {
            badge.textContent = data.unread > 99 ? '99+' : data.unread;
            badge.classList.remove('d-none');
        } else {
            badge.classList.add('d-none');
        }

        const list = document.getElementById('notif-list');
        if (!data.notifications.length) {
            list.innerHTML = '<div class="notif-empty">No notifications yet</div>';
            return;
        }

        list.innerHTML = data.notifications.map(n => `
            <div class="notif-item ${n.isRead ? '' : 'unread'}"
                 onclick="handleNotifClick(${n.id}, '${n.link ?? ''}')">
                <div class="notif-dot ${n.type}"></div>
                <div class="notif-item-body">
                    <div class="notif-item-title">${n.title}</div>
                    <div class="notif-item-msg">${n.message}</div>
                    <div class="notif-item-time">${n.createdAt}</div>
                </div>
            </div>
        `).join('');

    } catch(e) { /* silent */ }
}

async function handleNotifClick(id, link) {
    await fetch(`/admin/notifications/${id}/read`, { method: 'POST' });
    if (link) {
        window.location.href = link;
    } else {
        dropdownOpen = false;
        document.getElementById('notif-dropdown').classList.add('d-none');
        pollNotifications();
    }
}

async function markAllRead() {
    await fetch('/admin/notifications/read-all', { method: 'POST' });
    pollNotifications();
}

pollNotifications();
setInterval(pollNotifications, 10000);
</script>