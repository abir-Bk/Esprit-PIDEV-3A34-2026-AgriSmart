<!DOCTYPE html>
<html lang="fr">
<head>
    {# Ligne unique pour le titre #}
    <title>{% block title %}AgriSmart Admin{% endblock %}</title>
    
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    {# Google Fonts #}
    <link rel="preconnect" href="https://fonts.googleapis.com/">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Poppins:wght@400;500;700&display=swap">
    
    {# CSS unique #}
    {% block stylesheets %}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/font-awesome/css/all.min.css') }}">
        <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/bootstrap-icons/bootstrap-icons.css') }}">
        <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/overlay-scrollbar/css/overlayscrollbars.min.css') }}">
        <link rel="stylesheet" type="text/css" href="{{ asset('assets/css/style.css') }}">
        <style>
            :root { --am-green: #1a4331; }
            body { background-color: #f8f9fa; }
            .search-focus:focus { box-shadow: none !important; background-color: #fff !important; }
        </style>
    {% endblock %}

    <script>
        const storedTheme = localStorage.getItem('theme')
        const getPreferredTheme = () => { if (storedTheme) return storedTheme; return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light' }
        const setTheme = function (theme) {
            document.documentElement.setAttribute('data-bs-theme', (theme === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches) ? 'dark' : theme)
        }
        setTheme(getPreferredTheme())
    </script>
</head>

<body>
<main>
    {# Sidebar de gauche #}
    <nav class="navbar sidebar navbar-expand-xl navbar-light">
        <div class="d-flex align-items-center">
            <a class="navbar-brand" href="#">
                <img class="navbar-brand-item" src="{{ asset('assets/images/logo.png') }}" alt="logo" style="height:35px;">
            </a>
        </div>

        <div class="offcanvas offcanvas-start flex-row custom-scrollbar h-100" tabindex="-1" id="offcanvasSidebar">
            <div class="offcanvas-body sidebar-content d-flex flex-column pt-4">
                <ul class="navbar-nav flex-column" id="navbar-sidebar">
                    <li class="nav-item">
                        <a class="nav-link" href="#">
                            <i class="bi bi-house fa-fw me-2"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="#">
                            <i class="bi bi-briefcase fa-fw me-2"></i>Gestion des Offres
                        </a>
                    </li> 
                    <li class="nav-item">
                        <a class="nav-link" href="#">
                            <i class="bi bi-people fa-fw me-2"></i>Utilisateurs
                        </a>
                    </li>
                </ul>

                <div class="mt-auto p-3 bg-light rounded">
                    <div class="d-flex align-items-center">
                        <div class="avatar avatar-sm me-2">
                            <img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/01.jpg') }}" alt="avatar" style="width: 35px;">
                        </div>
                        <h6 class="mb-0">Admin PIDEV</h6>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    {# Contenu de la page #}
    <div class="page-content">
        <nav class="navbar top-bar navbar-light py-0 py-xl-3">
            <div class="container-fluid p-0">
                <div class="d-flex align-items-center w-100 px-3">
                    <h4 class="m-0 d-none d-md-block">Administration</h4>

                    {# --- BARRE DE RECHERCHE FONCTIONNELLE --- #}
                    <form action="{{ app.request.pathinfo }}" method="get" class="ms-auto d-flex align-items-center bg-light rounded-pill border px-3 py-1 shadow-sm">
                        <i class="bi bi-search text-muted me-2"></i>
                        <input 
                            type="text" 
                            name="search" 
                            class="form-control border-0 bg-transparent search-focus" 
                            placeholder="Rechercher une offre, un lieu..." 
                            value="{{ app.request.query.get('search') }}"
                            style="width: 250px;"
                        >
                        <button type="submit" class="btn btn-sm btn-primary rounded-pill px-3">OK</button>
                        
                        {# Croix pour réinitialiser la recherche #}
                        {% if app.request.query.get('search') %}
                            <a href="{{ app.request.pathinfo }}" class="ms-2 text-danger" title="Effacer la recherche">
                                <i class="bi bi-x-circle-fill"></i>
                            </a>
                        {% endif %}
                    </form>
                </div>
            </div>
        </nav>

        <div class="page-content-wrapper p-xxl-4">
            {% block body %}{% endblock %}
        </div>
    </div>
</main>

{# Javascripts #}
{% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="{{ asset('assets/vendor/overlay-scrollbar/js/overlayscrollbars.min.js') }}"></script>
{% endblock %}
</body>
</html>