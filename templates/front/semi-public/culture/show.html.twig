{% extends 'base.html.twig' %}

{% block title %}Culture{% endblock %}

{% block body %}
    <h1>Culture</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ culture.id }}</td>
            </tr>
            <tr>
                <th>TypeCulture</th>
                <td>{{ culture.typeCulture }}</td>
            </tr>
            <tr>
                <th>Variete</th>
                <td>{{ culture.variete }}</td>
            </tr>
            <tr>
                <th>DatePlantation</th>
                <td>{{ culture.datePlantation ? culture.datePlantation|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>DateRecoltePrevue</th>
                <td>{{ culture.dateRecoltePrevue ? culture.dateRecoltePrevue|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Statut</th>
                <td>{{ culture.statut }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_culture_index') }}">back to list</a>

    <a href="{{ path('app_culture_edit', {'id': culture.id}) }}">edit</a>

    {{ include('culture/_delete_form.html.twig') }}
{% endblock %}
